---
import Layout from '../../layouts/Layout.astro';
import ArticleByline from '../../components/ArticleByline.astro';
import { getAdjacentArticles, getArticle } from '../../data/articles';
import { formatThaiDate } from '../../lib/dates';
import CodeBlock from '../../components/CodeBlock.astro';

const { prev, next } = getAdjacentArticles('grill-and-loop/');
const article = getArticle('grill-and-loop/')!;
const published = formatThaiDate(article.dateISO!);
const updated = article.updatedISO ? formatThaiDate(article.updatedISO) : undefined;
---
<Layout title="ให้ AI ซักจนงานชัด ด้วย /grill-me กับ /loop-me | หมวดความรู้" description="AI ไม่ได้พังเพราะเขียนโค้ดไม่เป็น แต่เพราะเราบอกงานไม่ครบ — 2 สกิลนี้กลับด้านให้ AI ซักถามเราจนสเปกชัดก่อนลงมือ" prev={prev} next={next} type="article" dateISO={article.dateISO} updatedISO={article.updatedISO} headline={article.title}>
  <div class="article-head">
    <div class="breadcrumb"><a href="../">หมวดความรู้</a> / ให้ AI ซักจนงานชัด ด้วย <code>/grill-me</code> กับ <code>/loop-me</code></div>
    <ArticleByline published={published} updated={updated} />
  </div>

  <span class="tag">Claude Code</span>
  <h1>ให้ AI ซักจนงานชัด ด้วย <code>/grill-me</code> กับ <code>/loop-me</code></h1>
  <p class="subtitle">งานส่วนใหญ่ที่ AI ทำพลาด ไม่ได้พังเพราะมันเขียนโค้ดไม่เป็น แต่เพราะเราบอกงานไม่ครบตั้งแต่แรก — สองสกิลของ Matt Pocock นี้กลับด้าน ให้ AI เป็นฝ่ายซักถามเราจนสเปกชัดก่อนลงมือ</p>

  <p>
    เวลาให้ AI ทำงานแล้วผลออกมาไม่ตรงใจ เรามักโทษว่ามันไม่เก่งพอ แต่ความจริงที่เจอบ่อยกว่าคือ<strong>เราเองที่บอกงานไม่ครบ</strong> —
    ในหัวเรามีรายละเอียดที่คิดว่า "ก็รู้ ๆ กันอยู่" เต็มไปหมด แต่ไม่เคยพูดออกมา AI เลยต้องเดาเอง แล้วก็เดาผิดบ้างถูกบ้าง
    สกิล <code>/grill-me</code> กับ <code>/loop-me</code> ของ Matt Pocock แก้ปัญหานี้ด้วยวิธีที่ฟังดูสวนทาง คือ<strong>ให้ AI ซักถามเรากลับ</strong>
    ยิงคำถามไล่ทีละจุดจนความเข้าใจของสองฝ่ายตรงกัน แล้วค่อยลงมือ (เรื่องสกิลคืออะไร ติดตั้งยังไง ดูได้ในบทความก่อนหน้า)
  </p>

  <h2>หัวใจร่วมกัน: การ "grilling"</h2>
  <p>
    ทั้งสองสกิลใช้เครื่องยนต์ตัวเดียวกันที่ Matt Pocock เรียกว่า <strong>grilling</strong> (อ่านว่า <strong>"กริลลิง"</strong>) — คำว่า <i>grill</i> แปลตรงตัวคือ "ย่างบนเตา" แต่ในภาษาอังกฤษ <i>to grill someone</i> เป็นสำนวนแปลว่า "ซักไซ้ไล่เลียงอย่างหนัก" (เหมือนจับไปย่างบนเตาร้อน ๆ) ก็คือซักให้อยู่หมัดนั่นเอง
    หัวใจของมันสรุปได้เป็นคำสั่งสั้น ๆ ในไฟล์สกิลจริง ซึ่งอ่านแล้วเข้าใจแนวคิดทั้งหมดได้เลย
  </p>
  <CodeBlock lang="text" title="แก่นของ grilling (แปลจาก SKILL.md จริง)" code={`ซักผมอย่างไม่ปรานีในทุกแง่มุมของแผนนี้ จนกว่าเราจะเข้าใจตรงกัน
ไล่ลงไปทีละกิ่งของ "ต้นไม้การตัดสินใจ" แก้ทีละจุดตามลำดับ
แต่ละคำถาม ให้เสนอคำตอบที่คุณแนะนำมาด้วย
ถามทีละคำถาม รอฟังคำตอบก่อนค่อยถามข้อถัดไป — ถามรัวหลายข้อพร้อมกันมันชวนงง
ถ้าคำถามไหนหาคำตอบเองได้จากในโค้ด ให้ไปดูโค้ดเองแทนที่จะถาม
อย่าเพิ่งลงมือทำ จนกว่าผมจะยืนยันว่าเราเข้าใจตรงกันแล้ว`} />
  <p>จับหลักการสำคัญได้ 4 ข้อจากตรงนี้ ซึ่งเป็นสิ่งที่ทำให้มันต่างจากการพิมพ์สั่งงานปกติ</p>
  <div class="card">
    <ul>
      <li><strong>ถามทีละคำถาม</strong> — ไม่ยิงเป็นชุด ๆ ให้เราตอบทีละข้อ จะได้ไม่งงและไม่ตอบข้าม</li>
      <li><strong>แนบคำตอบที่แนะนำมาด้วยทุกข้อ</strong> — ไม่ใช่ถามลอย ๆ แต่เดาให้ก่อนว่าน่าจะเป็นแบบไหน เราแค่กด "เอาตามนั้น" หรือแก้เฉพาะจุดที่ไม่เห็นด้วย เร็วกว่าคิดเองจากศูนย์</li>
      <li><strong>หาคำตอบเองจากโค้ดถ้าหาได้</strong> — คำถามที่ดูจากโปรเจกต์แล้วรู้เลย มันจะไปเช็คเอง ไม่มากวนถามให้เสียเวลา</li>
      <li><strong>ยังไม่ลงมือจนกว่าจะเข้าใจตรงกัน</strong> — วนถาม-ตอบไปเรื่อย ๆ จนเราพอใจ แล้วค่อยเริ่มทำจริง</li>
    </ul>
  </div>

  <figure class="diagram">
    <svg viewBox="0 0 720 210" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="แผนภาพวงจร grilling: AI ถามทีละคำถามพร้อมคำตอบที่แนะนำ เราตอบหรือปรับแก้ ถ้ายังไม่ตรงกันก็วนถามต่อ ถ้าคำถามไหนดูจากโค้ดได้ AI เช็คเอง สุดท้ายเมื่อเข้าใจตรงกันจะได้สเปกที่พร้อมลงมือ" style="font-family:'Sarabun',sans-serif">
      <defs>
        <marker id="ar" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0 0 L10 5 L0 10 z" fill="#4d72a9"/>
        </marker>
      </defs>
      <!-- return arc label -->
      <text x="290" y="34" font-size="12" font-weight="700" fill="#294266" text-anchor="middle">ยังไม่ตรงกัน ➔ วนถามต่อ</text>
      <!-- return arc from box2 top to box1 top -->
      <path d="M405 92 C405 50 240 50 145 50 L145 88" fill="none" stroke="#4d72a9" stroke-width="2" stroke-dasharray="5 4" marker-end="url(#ar)"/>

      <!-- Box 1 -->
      <rect x="40" y="92" width="205" height="66" rx="14" fill="#ecf3fc" stroke="#bcd3f8" stroke-width="1.5"/>
