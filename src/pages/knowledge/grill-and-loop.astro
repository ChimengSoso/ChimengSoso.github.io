      <text x="142" y="139" font-size="11" fill="#5a6a85" text-anchor="middle">พร้อมคำตอบที่แนะนำ</text>

      <!-- arrow 1 -->
      <text x="290" y="115" font-size="11" font-weight="700" fill="#294266" text-anchor="middle">เราตอบ</text>
      <line x1="245" y1="125" x2="333" y2="125" stroke="#4d72a9" stroke-width="2" marker-end="url(#ar)"/>

      <!-- Box 2 -->
      <rect x="338" y="92" width="180" height="66" rx="14" fill="#ecf3fc" stroke="#bcd3f8" stroke-width="1.5"/>
      <text x="428" y="120" font-size="13" font-weight="700" fill="#294266" text-anchor="middle">เราตอบ / ปรับแก้</text>
      <text x="428" y="139" font-size="11" fill="#5a6a85" text-anchor="middle">จนพอใจ</text>

      <!-- arrow 2 to exit -->
      <line x1="520" y1="125" x2="548" y2="125" stroke="#4d72a9" stroke-width="2" marker-end="url(#ar)"/>

      <!-- exit pill -->
      <rect x="553" y="98" width="140" height="54" rx="27" fill="#eafaf0" stroke="#2f9e5c" stroke-width="1.5"/>
      <text x="623" y="120" font-size="12" font-weight="700" fill="#1f7a45" text-anchor="middle">ได้สเปกที่ชัด</text>
      <text x="623" y="138" font-size="11" fill="#1f7a45" text-anchor="middle">พร้อมลงมือ</text>

