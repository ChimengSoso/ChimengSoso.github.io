      <text x="118" y="102" font-size="11" fill="#7a869a" text-anchor="middle">โค้ด + ไลบรารีที่ใช้</text>

      <!-- arrow 1 -->
      <text x="238" y="80" font-size="11" font-weight="700" fill="#294266" text-anchor="middle">สแกน</text>
      <line x1="212" y1="87" x2="264" y2="87" stroke="#4d72a9" stroke-width="2.2" marker-end="url(#tv-arr)"/>

      <!-- box 2: report -->
      <rect x="266" y="40" width="188" height="94" rx="14" fill="#fff7e6" stroke="#e6b422" stroke-width="1.5"/>
      <text x="360" y="62" font-size="15" font-weight="700" fill="#8a6a12" text-anchor="middle">รายงานผล</text>
      <text x="282" y="84" font-size="11" fill="#5a6a85">• ช่องโหว่ (CVE) ในไลบรารี</text>
      <text x="282" y="102" font-size="11" fill="#5a6a85">• secret ที่เผลอหลุด</text>
      <text x="282" y="120" font-size="11" fill="#5a6a85">• config ที่เสี่ยง</text>

      <!-- arrow 2 -->
      <text x="480" y="80" font-size="11" font-weight="700" fill="#294266" text-anchor="middle">อ่านผล</text>
