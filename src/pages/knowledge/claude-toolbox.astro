      <text x="602" y="112" font-size="11" fill="#5a6a85" text-anchor="middle">คลิกปุ่ม · แคปหน้าจอ</text>

      <!-- loop back -->
      <path d="M602 134 L602 206 L118 206 L118 138" fill="none" stroke="#4d72a9" stroke-width="2.2" stroke-dasharray="6 5" marker-end="url(#pw-arr)"/>
