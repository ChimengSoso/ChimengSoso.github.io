      <text x="602" y="94" font-size="10.5" fill="#5a6a85" text-anchor="middle">อัป lib · ถอด secret</text>
      <text x="602" y="111" font-size="10.5" fill="#5a6a85" text-anchor="middle">· ปรับ config ที่เสี่ยง</text>

      <!-- loop back -->
      <path d="M602 134 L602 206 L118 206 L118 138" fill="none" stroke="#4d72a9" stroke-width="2.2" stroke-dasharray="6 5" marker-end="url(#tv-arr)"/>
