---
import Layout from '../../layouts/Layout.astro';
import ArticleByline from '../../components/ArticleByline.astro';
import { getAdjacentArticles, getArticle } from '../../data/articles';
import { formatThaiDate } from '../../lib/dates';
import CodeBlock from '../../components/CodeBlock.astro';

const { prev, next } = getAdjacentArticles('handoff/');
const article = getArticle('handoff/')!;
const published = formatThaiDate(article.dateISO!);
const updated = article.updatedISO ? formatThaiDate(article.updatedISO) : undefined;
---
<Layout title="ส่งงานต่อข้ามแชทแบบไม่เสีย Context ด้วย /handoff | หมวดความรู้" description="พอแชทยาวจน AI เริ่มเอ๋อ อย่าเพิ่งเปิดแชทใหม่แล้วเล่าใหม่ทั้งหมด — สกิล /handoff สรุปงานให้ Agent ตัวใหม่รับช่วงต่อได้ใน 3 ขั้นตอน" prev={prev} next={next} type="article" dateISO={article.dateISO} updatedISO={article.updatedISO} headline={article.title}>
  <div class="article-head">
    <div class="breadcrumb"><a href="../">หมวดความรู้</a> / ส่งงานต่อข้ามแชทแบบไม่เสีย Context</div>
    <ArticleByline published={published} updated={updated} />
  </div>

  <span class="tag">Claude Code</span>
  <h1>ส่งงานต่อข้ามแชทแบบไม่เสีย Context</h1>
  <p class="subtitle">พอคุยยาว ๆ จน AI เริ่มมึน การเปิดแชทใหม่แล้วเล่าใหม่ทั้งหมดคือการเสียเวลาฟรี ๆ — มาดูวิธีส่งไม้ต่อให้ Agent ตัวใหม่รับงานได้ทันที ด้วยสกิล <code>/handoff</code> ของ Matt Pocock</p>

  <p>
    เวลาคุยกับ AI นอกจากการเขียน prompt ให้ชัดและให้บริบทครบแล้ว ยังมีอีกเรื่องที่ส่งผลกับคุณภาพงานมากกว่าที่หลายคนคิด
    นั่นคือ<strong>การจัดการ context window</strong> — พื้นที่ความจำที่ AI ใช้เก็บทุกอย่างในบทสนทนาปัจจุบัน (บทความก่อนหน้าเรียกสั้น ๆ ว่า context)
    ปัญหาคลาสสิกที่เจอกันคือ "ยิ่งคุยยิ่งเอ๋อ" คุยไปสักพักแล้วรู้สึกว่า AI เริ่มลืมสิ่งที่ตกลงกันไว้ ตอบวน หรือจับประเด็นพลาด
    ทั้งที่โมเดลตัวท็อป ๆ ทุกวันนี้โฆษณาว่ารับ context ได้ถึง 1 ล้านโทเคน (token — หน่วยย่อยของข้อความที่โมเดลใช้นับความยาว)
  </p>

  <h2>ทำไม 1 ล้านโทเคนถึงยังไม่พอ</h2>
  <p>
    กุญแจสำคัญคือ "รับได้" กับ "ใช้ได้ดี" เป็นคนละเรื่องกัน หน้าต่าง context ไม่ได้ฉลาดเท่ากันตลอดทั้งเส้น
    ช่วงต้น ๆ ของบทสนทนาโมเดลจดจ่อกับเนื้อหาได้แม่นที่สุด แต่พอโทเคนสะสมมากขึ้นเรื่อย ๆ ความสนใจจะเริ่มกระจายจนจับใจความหลุด
    Matt Pocock (อ่านว่า <strong>"แมตต์ โพค็อก"</strong> — วิศวกร AI ที่ทำสกิลตัวนี้) อธิบายไว้ตรง ๆ ว่าพอเลยราว ๆ <strong>120,000 โทเคน</strong> เขา "รู้สึกเหมือนเข้าสู่โซนมึน (dumb zone) แล้ว"
    แปลว่าถึงเพดานจะเขียนว่า 1 ล้าน แต่ช่วงที่ทำงานได้คุณภาพจริง ๆ มีอยู่แค่ประมาณ 120K แรกเท่านั้น
  </p>

  <figure class="diagram">
    <svg viewBox="0 0 720 175" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="แผนภาพหน้าต่าง context: ประมาณ 120,000 โทเคนแรกเป็นโซนฉลาดที่โมเดลจดจ่อได้แม่น ส่วนที่เหลือไปจนถึง 1 ล้านโทเคนเป็นโซนมึนที่ยิ่งไกลยิ่งเบลอ" style="font-family:'Sarabun',sans-serif">
      <defs>
        <linearGradient id="smart" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#2f9e5c"/>
          <stop offset="1" stop-color="#57c185"/>
        </linearGradient>
        <linearGradient id="dumb" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#c9dcf6"/>
          <stop offset="1" stop-color="#eef3fb"/>
        </linearGradient>
        <clipPath id="barclip"><rect x="40" y="60" width="640" height="50" rx="12"/></clipPath>
      </defs>
      <text x="40" y="38" font-size="15" font-weight="700" fill="#131e30">หน้าต่าง Context หนึ่งอัน — เพดานสูงสุด ~1,000,000 โทเคน</text>
      <g clip-path="url(#barclip)">
        <rect x="40" y="60" width="640" height="50" fill="url(#dumb)"/>
        <rect x="40" y="60" width="150" height="50" fill="url(#smart)"/>
      </g>
      <rect x="40" y="60" width="640" height="50" rx="12" fill="none" stroke="#bcd3f8" stroke-width="1.5"/>
      <line x1="190" y1="52" x2="190" y2="118" stroke="#294266" stroke-width="1.5" stroke-dasharray="4 4"/>
      <text x="115" y="90" font-size="13" font-weight="700" fill="#ffffff" text-anchor="middle">โซนฉลาด</text>
      <text x="435" y="83" font-size="13" font-weight="700" fill="#294266" text-anchor="middle">โซนมึน</text>
      <text x="435" y="100" font-size="11" fill="#5a6a85" text-anchor="middle">ยิ่งไกลยิ่งเบลอ จับประเด็นพลาด</text>
      <text x="190" y="140" font-size="11" fill="#5a6a85" text-anchor="middle">~120K โทเคนแรก</text>
      <text x="680" y="140" font-size="11" fill="#5a6a85" text-anchor="end">ปลายทาง ~1M</text>
    </svg>
    <figcaption>ช่วงที่โมเดลจดจ่อได้แม่นจริง ๆ คือ ~120K โทเคนแรก เลยจากนั้นความแม่นจะค่อย ๆ ลดลง</figcaption>
  </figure>

  <h2>วิธีเดิมที่หลายคนใช้ (แล้วมันเสียเวลาตรงไหน)</h2>
  <p>
    พอ context เริ่มเต็มหรือเริ่มมึน คนส่วนใหญ่มีอยู่สองทางเลือกหลัก ๆ ซึ่งทั้งคู่ก็พอใช้ได้ แต่มีจุดอ่อนของมันอยู่
  </p>
  <div class="card">
    <ul>
      <li>
        <strong>ใช้ <code>/compact</code></strong> — สรุปบทสนทนาที่ผ่านมาให้สั้นลงเพื่อคืนพื้นที่ แต่ยังอยู่ในแชทเดิม ต่องานเดิมได้เลย
        ข้อจำกัดคือมันยัง "ลาก" ทุกเรื่องที่คุยมาไว้ในแชทเดียวกันหมด รวมถึงเรื่องที่ออกทะเลระหว่างทางด้วย งานเดียวจึงกินพื้นที่บวมขึ้นเรื่อย ๆ
      </li>
      <li>
        <strong>เปิดแชทใหม่แล้วเริ่มทำงานต่อ</strong> — ได้ context โล่ง ๆ กลับมา แต่ต้องมานั่งเล่าเองว่า "เมื่อกี้ทำถึงไหนแล้ว ตกลงอะไรกันไว้บ้าง ไฟล์ไหนที่เกี่ยวข้อง"
        ทุกครั้งที่ย้ายแชท เท่ากับเสียเวลาปูพื้นใหม่ทั้งหมด และถ้าเล่าตกหล่นไปนิดเดียว AI ตัวใหม่ก็ทำงานพลาดได้ทันที
      </li>
    </ul>
  </div>
  <p>
    ขั้นตอน "ย้ายแชทแล้วเล่าใหม่" นี่แหละที่กินเวลาโดยไม่จำเป็น สกิล <code>/handoff</code> เกิดมาเพื่อตัดงานตรงนี้ทิ้งไปเลย
  </p>
  <p>
    ชื่อสกิลก็บอกใบ้อยู่แล้ว — คำว่า <strong>handoff</strong> อ่านออกเสียงว่า <strong>"แฮนด์-ออฟ"</strong> แปลว่า <strong>"การส่งต่อ" หรือ "ส่งมอบงาน"</strong>
    มาจากศัพท์กีฬาวิ่งผลัดตอนที่นักวิ่งส่งไม้ต่อให้คนถัดไปโดยไม่หยุดวิ่ง — ตรงกับสิ่งที่สกิลนี้ทำเป๊ะ คือส่งไม้งานต่อให้ Agent ตัวใหม่รับช่วงวิ่งต่อทันที
  </p>

  <h2><code>/handoff</code> ต่างจาก <code>/compact</code> ยังไง</h2>
  <p>
    สองอย่างนี้ฟังดูคล้ายกันเพราะต่างก็ "บีบสรุป" บทสนทนาเหมือนกัน แต่เป้าหมายคนละทางกันเลย
  </p>
  <div class="card">
    <ul>
      <li><strong><code>/compact</code> = อยู่แชทเดิม</strong> — ย่อบทสนทนาลงแล้วทำงาน<strong>ต่อในแชทเดียวกัน</strong> เหมาะกับงานยาวเรื่องเดียวที่ไม่อยากตัดขาด</li>
      <li><strong><code>/handoff</code> = ส่งต่อไปแชทใหม่</strong> — หยิบ<strong>เฉพาะส่วนที่เกี่ยวข้อง</strong>ออกมาเป็นเอกสารสรุป เพื่อให้ Agent อีกตัว (แชทใหม่) รับไปทำต่อ โดยแชทเดิมยัง "สะอาด" อยู่</li>
    </ul>
  </div>
  <p>
    ความต่างนี้เปิดทางให้ทำงานแบบ<strong>แยกสายพร้อมกันได้</strong> เช่นกำลังคุยเรื่องหลักอยู่ แล้วจู่ ๆ เจองานแยกที่ต้องทำ (เช่นต้องไป refactor โมดูลนึงก่อน)
    แทนที่จะลากงานแยกนั้นมาถมในแชทหลักจน context บวม ก็แค่ <code>/handoff</code> ตัดเฉพาะบริบทที่เกี่ยวกับงานแยกออกไปให้อีกแชททำ
    ส่วนแชทหลักก็ยังโฟกัสเรื่องเดิมต่อได้แบบไม่มึน — ทั้งสองแชทเลยฉลาดพร้อมกันทั้งคู่
  </p>

  <figure class="diagram">
    <svg viewBox="0 0 720 210" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="แผนภาพการส่งงานต่อ: Session เดิมที่ context ใกล้เต็ม พิมพ์ /handoff เพื่อสร้างไฟล์ handoff.md เซฟไว้ในโฟลเดอร์ temp แล้ว Session ใหม่อ่านไฟล์นั้นเพื่อรับงานต่อโดย context ยังโล่ง" style="font-family:'Sarabun',sans-serif">
