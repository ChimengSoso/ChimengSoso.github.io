      <text x="410" y="120" font-size="10.5" fill="#b23b3b">(เคยชินว่าไวกว่านี้)</text>

      <!-- actual task effort bar, same height both sides -->
      <rect x="150" y="70" width="26" height="110" fill="#5a6a85" opacity="0.55"/>
      <rect x="530" y="70" width="26" height="110" fill="#5a6a85" opacity="0.55"/>
