---
import Layout from '../../layouts/Layout.astro';
import ArticleByline from '../../components/ArticleByline.astro';
import { getAdjacentArticles, getArticle } from '../../data/articles';
import { formatThaiDate } from '../../lib/dates';
import CodeBlock from '../../components/CodeBlock.astro';

const { prev, next } = getAdjacentArticles('video-editing/');
const article = getArticle('video-editing/')!;
const published = formatThaiDate(article.dateISO!);
const updated = article.updatedISO ? formatThaiDate(article.updatedISO) : undefined;
---
<Layout title={`${article.title} | หมวดความรู้`} description={article.desc} prev={prev} next={next} type="article" dateISO={article.dateISO} updatedISO={article.updatedISO} headline={article.title}>
  <div class="article-head">
    <div class="breadcrumb"><a href="../">หมวดความรู้</a> / ให้ Claude ตัดต่อวิดีโอแทนเรา</div>
    <ArticleByline published={published} updated={updated} />
  </div>

  <span class="tag">Claude Code</span>
  <h1>ให้ Claude ตัดต่อวิดีโอแทนเรา: FFmpeg, CapCut หรือคุม Premiere สด ๆ</h1>
  <p class="subtitle">คลิปพูดหน้ากล้อง 10 นาที ใช้เวลาตัดเป็นชั่วโมง — แล้ววันหนึ่งก็เห็นคนในเน็ตพิมพ์สั่ง AI ให้ตัดแทนทั้งคลิป มันทำได้จริงแค่ไหน? บทความนี้พาลงลึก 3 เส้นทางจริงพร้อมวิธีติดตั้ง เทียบจุดแข็ง-จุดเสี่ยงทีละทาง และอนาคตที่เพิ่งเปิดประตูเมื่อเดือนที่แล้ว</p>

  <p>
    ใครเคยตัดคลิปเองจะรู้ — ถ่าย 10 นาที แต่ตัดเป็น<strong>ชั่วโมง</strong> นั่งไล่หาช่วงเงียบ ลบเทคที่พูดผิดแล้วอัดใหม่
    ลากซับให้ตรงปาก ทำเสร็จรอบนึงก็เจออีกจุด วนไปจนตาลาย งาน "ถ่าย" กลายเป็นส่วนที่สั้นที่สุดของการทำคลิป
  </p>
  <p>
    แล้ววันหนึ่งคุณก็เห็นคลิปในเน็ต — คนพิมพ์ข้อความสั่ง AI ว่า "ตัดช่วงเงียบออก ใส่ซับ แล้วเซฟเข้า CapCut ให้หน่อย"
    บางคนไปไกลกว่านั้น สั่ง Premiere Pro ให้ลงมือ<strong>บนไทม์ไลน์จริงต่อหน้าต่อตา</strong> คำถามที่ผุดขึ้นทันทีคือ:
    ของพวกนี้ทำได้จริง หรือตัดต่อคลิปมาโชว์?
  </p>
  <p>
    คำตอบคือ<strong>ทำได้จริง — แต่ไม่ได้ทำแบบที่ภาพในหัวเราคิด</strong> และแต่ละวิธีมีข้อแลกเปลี่ยนที่ต่างกันมาก
    บทความนี้จะพาไล่ทีละเส้นทาง แบบที่อ่านจบแล้วลงมือตามได้เลย
  </p>

  <hr class="divider" />

  <h2>หลักข้อเดียวที่ต้องเข้าใจก่อน: Claude จับเมาส์ไม่ได้</h2>
  <p>
    ใน<a href="../watch/">บทความ <code>/watch</code></a> เราสรุปไว้ว่า Claude ไม่ได้ลากไทม์ไลน์เอง
    มันเป็น "คนคุมวง" ที่สั่งงานเครื่องมืออื่นอีกที คำถามสำคัญเวลาเลือกวิธีจึงไม่ใช่ "Claude ตัดเก่งไหม" แต่คือ
    <strong>"เราจะให้มันคุยกับอะไร"</strong> — ซึ่งมีให้เลือก 3 เส้นทาง ที่คุมได้ลึกขึ้นเรื่อย ๆ และแลกมาด้วยความยุ่งยากที่มากขึ้นเรื่อย ๆ เช่นกัน
  </p>

  <figure class="diagram">
    <svg viewBox="0 0 720 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="แผนภาพสามเส้นทางที่ Claude ใช้ตัดต่อวิดีโอ กล่อง Claude อยู่ซ้าย มีลูกศรสามเส้นไปหาสามกล่องขวา เส้นบนไปกล่อง FFmpeg คือเขียนคำสั่งจัดการไฟล์ตรง ได้ไฟล์ผลลัพธ์เลย เส้นกลางไปกล่องดราฟต์ CapCut คือเขียนไฟล์โปรเจกต์ให้เราเปิดเก็บงานต่อใน CapCut เส้นล่างไปกล่อง Premiere Pro คือส่งคำสั่งคุมโปรแกรมที่เปิดอยู่ให้ลงมือบนไทม์ไลน์สด" style="font-family:'Sarabun',sans-serif">
