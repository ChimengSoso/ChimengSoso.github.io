---
import Layout from '../../layouts/Layout.astro';
import ArticleByline from '../../components/ArticleByline.astro';
import { getAdjacentArticles, getArticle } from '../../data/articles';
import { formatThaiDate } from '../../lib/dates';
import CodeBlock from '../../components/CodeBlock.astro';

const { prev, next } = getAdjacentArticles('claude-agent-team/');
const article = getArticle('claude-agent-team/')!;
const published = formatThaiDate(article.dateISO!);
const updated = article.updatedISO ? formatThaiDate(article.updatedISO) : undefined;
---
<Layout title={`${article.title} | หมวดความรู้`} description={article.desc} prev={prev} next={next} type="article" dateISO={article.dateISO} updatedISO={article.updatedISO} headline={article.title}>
  <div class="article-head">
    <div class="breadcrumb"><a href="../">หมวดความรู้</a> / ตั้งบริษัทซอฟต์แวร์ที่ไม่มีพนักงานเป็นคนสักคน</div>
    <ArticleByline published={published} updated={updated} />
  </div>

  <span class="tag">Claude Code</span>
  <h1>ตั้งบริษัทซอฟต์แวร์ที่ไม่มีพนักงานเป็นคนสักคน</h1>
  <p class="subtitle">เปิดบริษัทซอฟต์แวร์ของตัวเอง แต่ไม่ต้องจ้างพนักงานสักคน — ทีมที่มี Lead แบ่งงาน มีลูปแก้งาน และเด้งกลับมาถามเราเมื่อโจทย์ไม่ชัด คือของจริงที่ทำได้วันนี้แค่ไหน</p>

  <h2>ลองสวมบทเป็นเจ้าของบริษัทซอฟต์แวร์ดูสักตั้ง</h2>
  <p>
    สมมติคุณเปิดบริษัทพัฒนาซอฟต์แวร์ของตัวเองขึ้นมา เริ่มจากศูนย์ ยังไม่มีพนักงานสักคน มีแค่โจทย์งานกองอยู่ตรงหน้า
    กับตัวคุณคนเดียวที่ต้องทำทุกอย่าง — คิดสเปก เขียนโค้ด ตรวจงานตัวเอง ส่งงานเอง
  </p>
  <p>
    ทำไปสักพักก็เริ่มรู้ตัวว่านี่ไม่ใช่ทางที่ยั่งยืน คุณอยากมี<strong>ทีม</strong> — คนที่รับสเปกจากคุณแล้วแตกงานเป็น
    คนที่ลงมือเขียนจริง กับคนที่คอยตรวจก่อนงานจะถึงมือคุณ ทำงานประสานกันเองได้ในระดับหนึ่ง
    โดยที่คุณแค่คอยตัดสินใจเรื่องที่สำคัญจริง ๆ
  </p>
  <p>
    ฟังดูเหมือนต้องรอเปิดรับสมัครงาน สัมภาษณ์ อบรม จ่ายเงินเดือนอีกหลายเดือนกว่าจะได้ทีมแบบนั้นจริง —
    แต่ถ้าบอกว่า<strong>ตั้งทีมแบบนี้ได้ตั้งแต่วันนี้เลย</strong> โดยไม่ต้องจ้างใครสักคนล่ะ
  </p>

  <h2>แกะศัพท์ก่อน</h2>
  <p>
    เฉลยเลยแล้วกันครับ — "พนักงาน" ที่ว่านั้นคือ Claude นี่แหละ ไม่ใช่คนจริง ๆ สิ่งที่ผมทำไปเมื่อกี้ไม่ใช่แค่จินตนาการลอย ๆ
    แต่ลองเอาโจทย์เขียนโค้ดจริงไปให้ "ทีม Claude" ทำดูจริง แล้วมันก็ทำได้จริง — reject กันเอง แก้กันเอง จนงานผ่าน
    (รายละเอียดเต็ม ๆ อยู่ท้ายบทความ) ก่อนไปถึงตรงนั้น ขอแกะศัพท์ที่จะเจอถี่ ๆ ตลอดบทความนี้กันก่อน
  </p>
  <div class="card">
    <ul>
      <li>
        <strong>agent</strong> อ่านออกเสียงว่า <strong>"เอเจนต์"</strong> แปลว่า <strong>"ตัวแทน" หรือ "ผู้ทำงานแทน"</strong>
        ในบริบทนี้คือ Claude หนึ่ง instance ที่ทำงานแทนคนหนึ่งคน มีความจำ (context) และหน้าที่ของตัวเอง แยกจาก instance อื่น
      </li>
      <li>
        <strong>sub-agent</strong> = agent ที่ถูกเรียกใช้ "ระหว่างทาง" โดย agent อีกตัว ทำงานเสร็จแล้วรายงานผลกลับ
        ไม่ใช่ทีมที่คุยกันเองได้ — เคยพูดถึงละเอียดแล้วในบทความเรื่อง
        <a href="../context-pollution/">Context Pollution</a>
      </li>
      <li>
        <strong>workflow</strong> อ่านออกเสียงว่า <strong>"เวิร์กโฟลว์"</strong> แปลว่า <strong>"สายพานงาน"</strong>
        ในที่นี้หมายถึงสคริปต์ที่กำหนดลำดับขั้นตอนตายตัวไว้ล่วงหน้าว่า agent ไหนทำอะไรก่อนหลัง
      </li>
      <li>
        <strong>orchestrator</strong> — เคยแกะไปแล้วในบทความ
        <a href="../context-pollution/">Context Pollution</a> (คำอ่าน "ออร์เคสเทรเตอร์" มาจาก orchestra วงออร์เคสตรา)
        ในบทความนี้จะใช้คำว่า <strong>Lead</strong> แทน เพราะมันคือบทบาทที่คุมทีมจริง ๆ
      </li>
    </ul>
  </div>

  <h2>ทำไมต้องเป็น "ทีม" ไม่ใช่ AI ตัวเดียว</h2>
  <p>
    ถ้าสั่งงาน Claude ตัวเดียวตรง ๆ มันก็เขียนโค้ดได้ ตรวจโค้ดตัวเองได้ในระดับหนึ่ง — แต่นั่นเหมือน<strong>จ้างฟรีแลนซ์คนเดียวทำทุกขั้นตอน</strong>
    ตั้งแต่วางแผน เขียน จนถึงตรวจงานตัวเอง จุดอ่อนคือ <strong>คนตรวจกับคนทำเป็นคนเดียวกัน</strong> อคติเดิมที่ทำให้เขียนพลาดตอนแรก
    ก็มักจะเป็นอคติเดียวกับตอนตรวจทานเองด้วย มองไม่เห็นจุดบอดของตัวเอง
  </p>
  <p>
    การแบ่งเป็นทีม — Lead คนหนึ่งตั้งเกณฑ์ dev คนหนึ่งลงมือ QA อีกคนตรวจ — คือการ<strong>ตัดบทบาทออกจากกัน</strong>
    ให้แต่ละ agent โฟกัสอยู่กับงานของตัวเอง และที่สำคัญกว่านั้นคือ QA ไม่ได้เห็น context เดียวกับตอนที่ dev กำลังปวดหัวเขียนโค้ด
    มันมาไล่โค้ดด้วยสายตาที่สดกว่า จับจุดที่ dev มองข้ามได้ง่ายกว่า
  </p>

  <figure class="diagram">
    <svg viewBox="0 0 740 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="แผนภาพทีม: Lead ตั้งเกณฑ์รับงานแล้วส่งให้ dev เขียนโค้ด dev ส่งโค้ดให้ QA ตรวจ ถ้า QA ไม่ผ่านจะส่งเหตุผลย้อนกลับไปให้ dev แก้ วนซ้ำจนผ่าน เมื่อ QA อนุมัติจะแจ้งกลับ Lead แล้ว Lead อ้อมทางขวาไปส่งมอบให้คุณ" style="font-family:'Sarabun',sans-serif">
      <defs>
        <marker id="team-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path d="M0 0 L10 5 L0 10 z" fill="#4d72a9"/>
        </marker>
        <marker id="team-arrow-green" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path d="M0 0 L10 5 L0 10 z" fill="#2f9e5c"/>
        </marker>
        <marker id="team-arrow-red" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto">
          <path d="M0 0 L10 5 L0 10 z" fill="#b23b3b"/>
        </marker>
      </defs>

      <!-- boss -->
      <rect x="275" y="20" width="170" height="52" rx="12" fill="#fdf1de" stroke="#c99a4a" stroke-width="1.5"/>
      <text x="360" y="51" font-size="14" font-weight="700" fill="#8a5a1a" text-anchor="middle">Lead</text>

      <!-- dev -->
      <rect x="50" y="150" width="170" height="56" rx="12" fill="#e9f0fb" stroke="#4d72a9" stroke-width="1.5"/>
      <text x="135" y="183" font-size="14" font-weight="700" fill="#294266" text-anchor="middle">dev</text>

      <!-- qa -->
      <rect x="500" y="150" width="170" height="56" rx="12" fill="#e9f0fb" stroke="#4d72a9" stroke-width="1.5"/>
      <text x="585" y="183" font-size="14" font-weight="700" fill="#294266" text-anchor="middle">QA</text>

      <!-- you -->
      <rect x="275" y="248" width="170" height="52" rx="12" fill="#e6f4ec" stroke="#2f9e5c" stroke-width="1.5"/>
      <text x="360" y="279" font-size="14" font-weight="700" fill="#1f7a45" text-anchor="middle">คุณ (you)</text>

      <!-- boss -> dev -->
      <line x1="310" y1="72" x2="165" y2="150" stroke="#4d72a9" stroke-width="1.5" marker-end="url(#team-arrow)"/>
      <text x="150" y="110" font-size="11" fill="#5a6a85">ตั้งเกณฑ์ + สั่งงาน</text>

      <!-- dev -> qa -->
      <line x1="220" y1="178" x2="500" y2="178" stroke="#4d72a9" stroke-width="1.5" marker-end="url(#team-arrow)"/>
      <text x="300" y="171" font-size="11" fill="#5a6a85">ส่งโค้ดให้ตรวจ</text>

      <!-- qa -> dev feedback (dashed loop back) -->
      <path d="M500 200 C 380 236, 260 236, 220 200" fill="none" stroke="#b23b3b" stroke-width="1.5" stroke-dasharray="4 4" marker-end="url(#team-arrow-red)"/>
      <text x="245" y="232" font-size="11" fill="#b23b3b">reject พร้อมเหตุผล → แก้ใหม่</text>

      <!-- qa -> boss approved -->
      <line x1="595" y1="150" x2="440" y2="70" stroke="#2f9e5c" stroke-width="1.5" marker-end="url(#team-arrow-green)"/>
      <text x="490" y="105" font-size="11" fill="#1f7a45">approved</text>

      <!-- boss -> you, routed around the right margin so it never crosses the other four lines -->
      <path d="M445 50 L700 50 L700 274 L445 274" fill="none" stroke="#2f9e5c" stroke-width="1.5" stroke-dasharray="2 3" marker-end="url(#team-arrow-green)"/>
      <text x="620" y="42" font-size="11" fill="#1f7a45">สรุปแล้วส่งมอบ</text>
    </svg>
    <figcaption>QA ไม่ได้ตรวจแล้วจบ — reject ต้องวนกลับไปหา dev พร้อมเหตุผลเสมอ นี่คือหัวใจของลูป feedback ที่ทำให้ทีมต่างจาก AI ตัวเดียวตรวจงานตัวเอง</figcaption>
  </figure>

  <h2 class="step">3 วิธีจัดทีมที่มีจริงวันนี้</h2>
  <p>
    Claude Code ไม่ได้มีปุ่มเดียวชื่อ "สร้างทีม" แต่มี 3 วิธีที่ทำเรื่องนี้ได้ ต่างกันที่ agent แต่ละตัวคุยกันเองได้แค่ไหน
    และเราคุมความแน่นอนของผลลัพธ์ได้มากน้อยแค่ไหน
  </p>
  <div class="card">
    <ol>
      <li>
        <strong>Agent Teams</strong> — agent หลายตัวนั่ง "ห้องเดียวกัน" สื่อสารกันเองได้ตรง ๆ ผ่านกล่องข้อความกลาง (mailbox)
        และดูงานที่เหลือร่วมกันจาก task list เดียวกัน หนึ่งตัวเป็น team lead คอยแบ่งงานและสรุปผล
        ยังเป็นฟีเจอร์ <strong>experimental</strong> อยู่ ต้องเปิดใช้งานด้วยตัวแปรระบบ <code>CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1</code> ก่อน
        ไม่มีเพดานจำนวนตัวตายตัว แต่เอกสารทางการแนะนำว่าเริ่มที่ 3–5 ตัวก่อน เพราะยิ่งทีมใหญ่ ภาระในการประสานงานกันเองก็ยิ่งกินผลประโยชน์ที่ควรได้จากการขนานงาน
      </li>
      <li>
        <strong>Workflows</strong> — เขียนเป็นสคริปต์ JavaScript สั่งลำดับงานตายตัว ผ่านฟังก์ชัน <code>agent()</code> (เรียก agent หนึ่งตัว รอผลกลับ),
        <code>parallel()</code> (รันหลายงานพร้อมกันแล้วรอครบทุกตัว) และ <code>pipeline()</code> (ส่งต่องานเป็นทอด ๆ ไม่ต้องรอครบ)
        ควบคุมได้เป๊ะที่สุดเพราะเราเป็นคนเขียนลำดับเอง แต่มีเพดาน agent รันพร้อมกันสูงสุด 16 ตัว และรวมทั้ง workflow ไม่เกิน 1,000 ตัวต่อการรันหนึ่งครั้ง
      </li>
      <li>
        <strong>Sub-agents</strong> — วิธีที่เบาที่สุด สั่งทีละงานแล้วรอผลสรุปกลับมาที่ตัวหลัก (ตามที่แกะไว้ในหัวข้อก่อนหน้า)
        ไม่มีแนวคิดเรื่อง "ทีมคุยกันเอง" เลย เหมาะกับงานที่ต้องการแค่ผลสรุปสั้น ๆ ไม่ต้องมีการต่อรองกันไปมาระหว่าง agent
      </li>
    </ol>
  </div>
  <div class="card">
    <ul>
      <li><strong>Agent Teams</strong> — คุยกันเอง: <strong>ได้ตรง ๆ ผ่าน mailbox</strong> · ควบคุมได้: <strong>ต่ำ</strong> (ปล่อยให้ทีมตัดสินใจกันเอง) · เหมาะกับงานที่ต้องถกเถียง/ท้าทายกันเอง</li>
      <li><strong>Workflows</strong> — คุยกันเอง: <strong>ไม่ได้</strong> (คุยผ่าน lead เท่านั้น) · ควบคุมได้: <strong>สูงสุด</strong> (เราเขียนลำดับเอง) · เหมาะกับลูปที่ต้องการผลลัพธ์แน่นอน ทำซ้ำได้</li>
      <li><strong>Sub-agents</strong> — คุยกันเอง: <strong>ไม่ได้เลย</strong> · ควบคุมได้: <strong>ปานกลาง</strong> · เหมาะกับงานเดี่ยว ๆ ที่ต้องการแค่สรุปกลับ</li>
    </ul>
  </div>
  <p>ตัวอย่าง "Lead–dev–QA" ในบทความนี้ใช้ <strong>Workflows</strong> เพราะอยากได้ลูป feedback ที่ทำซ้ำได้แน่นอน ไม่อยากให้ผลลัพธ์เปลี่ยนไปมาแบบสุ่มทุกครั้งที่รัน</p>

  <h2>ออกแบบ "บทบาท" ให้แต่ละ agent</h2>
  <p>
    ไม่ว่าจะเลือกวิธีไหนใน 3 ข้อบน สิ่งที่ต้องทำเหมือนกันคือ<strong>เขียน "บทบาท"</strong> ให้แต่ละ agent รู้ว่าตัวเองเป็นใคร
    ทำหน้าที่อะไร ใช้เครื่องมืออะไรได้บ้าง — เหมือน<strong>ใบกำหนดตำแหน่งงาน (job description)</strong> ที่เขียนครั้งเดียว
    แล้วหยิบมาใช้ซ้ำได้ทุกครั้งที่เรียก agent ตัวนั้น ไม่ต้องอธิบายบทบาทใหม่ทุกรอบ
  </p>
  <p>
    เก็บเป็นไฟล์ Markdown ในโฟลเดอร์ <code>.claude/agents/</code> ระบุ <code>name</code> กับ <code>description</code> เป็นอย่างน้อย
    (สองช่องนี้จำเป็น ที่เหลือใส่เพิ่มได้) ส่วน <code>tools</code> จำกัดว่าใช้เครื่องมืออะไรได้บ้าง ไม่ใส่ก็ได้ (จะสืบทอดเครื่องมือทั้งหมดจาก session หลัก)
    และ <code>model</code> เลือกได้ว่าจะรันด้วยโมเดลไหน ตัวอย่างไฟล์บทบาทของ QA ในบทความนี้หน้าตาแบบนี้
  </p>
  <CodeBlock lang="yaml" title=".claude/agents/qa.md" code={`---
name: qa
description: ตรวจโค้ดเทียบเกณฑ์รับงานที่ Lead ตั้งไว้ ไล่ลอจิกด้วยมือ อนุมัติหรือตีกลับพร้อมเหตุผล
model: sonnet
tools: Read, Grep, Bash
---
คุณคือ QA reviewer เข้มงวด ไล่ execute โค้ดในหัวทีละ input ที่ Lead ระบุไว้
approve เฉพาะเมื่อทุกเกณฑ์ผ่านจริงเท่านั้น ถ้าตีกลับ ต้องระบุ input ที่พังและเหตุผลให้ชัด`} />
  <div class="callout callout-note">
    <p class="callout-label">โน้ต</p>
    <p>ช่อง <code>tools</code> ในตัวอย่างจำกัดให้ QA อ่านโค้ดกับรันคำสั่งตรวจได้อย่างเดียว แก้ไฟล์เองไม่ได้ — บังคับให้บทบาทนี้ทำหน้าที่แค่ "ตรวจ" ไม่เผลอไปช่วยแก้โค้ดเอง ซึ่งจะไปเบลอเส้นแบ่งบทบาทกับ dev</p>
  </div>

  <h2 class="step">ลงมือจริง — ทีมสร้างฟังก์ชันตัวหนึ่ง</h2>
  <p>
    เพื่อไม่ให้เป็นแค่ทฤษฎีลอย ๆ ผมเขียน workflow จริงให้ทีม "Lead–dev–QA" ทำงานกันเป็น phase ตามลำดับ:
    <strong>Plan (Lead ตั้งเกณฑ์) → Build+QA (dev เขียน แล้ว QA ตรวจ วนจนผ่าน) → Handoff (Lead สรุปส่งมอบ)</strong>
    โจทย์ที่ให้คือฟังก์ชัน <code>formatThousands(n)</code> — ใส่ comma คั่นหลักพันให้ตัวเลข รองรับทั้งจำนวนลบและทศนิยม
  </p>
  <CodeBlock lang="js" title="team-demo.workflow.js (ย่อ)" code={`phase('Plan')
const spec = await agent(
  \`You are the TEAM LEAD. Restate the goal, list 3-5 acceptance criteria
   your QA will verify, write a short brief for your dev. Do not write the code yourself.\`,
  { label: 'boss:plan', schema: SPEC_SCHEMA, effort: 'low' })

phase('Build+QA')
let code = '', lastQa = null; const rounds = []; const MAX_ROUNDS = 3
for (let round = 1; round <= MAX_ROUNDS; round++) {
  const feedback = lastQa ? \`Previous attempt REJECTED. Fix:\\n- \${lastQa.issues.join('\\n- ')}\\n\${code}\` : ''
  code = await agent(\`You are the DEV. Implement: \${spec.devBrief} \${feedback}
                      Return ONLY the module source.\`,
                     { label: \`dev:round\${round}\`, effort: 'low' })
  lastQa = await agent(\`You are a STRICT QA. Mentally EXECUTE the code on 1234567, -1234,
                        1234.5678, 0, -1234567.89. Approve only if every input is exact.\`,
                       { label: \`qa:round\${round}\`, schema: QA_SCHEMA, effort: 'low' })
  rounds.push({ round, approved: lastQa.approved, verdict: lastQa.verdict, issues: lastQa.issues })
  if (lastQa.approved) break
}

phase('Handoff')
const handoff = await agent(\`You are the TEAM LEAD. Write a short Thai handoff note:
                             what was built, passed QA?, how many rounds, any caveat.\`,
                            { label: 'boss:handoff', effort: 'low' })`} />
  <p>
    รอบแรก dev เขียนแบบร่างเร็ว ยังไม่กันเคสทศนิยมไว้ — โค้ดที่ได้ใช้ regex ตัดหลักพันตรง ๆ กับตัวเลขทั้งก้อน
    รวมถึงส่วนทศนิยมด้วย ผลคือพัง
  </p>
  <div class="card">
    <p><strong>QA reject รอบ 1</strong> ระบุ input ที่พังชัดเจน:</p>
    <p><code>formatThousands(1234.5678)</code> คืนค่า <code>"1,234.5,678"</code> ทั้งที่ควรได้ <code>"1,234.5678"</code> — regex ไปหั่นส่วนทศนิยมด้วยทั้งที่ไม่ควรแตะ</p>
  </div>
  <p>พิสูจน์ว่านี่ไม่ใช่ QA มโนไปเอง ลองรันจริงดูก็เจอบั๊กเดียวกันเป๊ะ</p>
  <CodeBlock lang="bash" code={`node -e 'console.log(String(1234.5678).replace(/\\B(?=(\\d{3})+(?!\\d))/g, ","))'
# → 1,234.5,678   (ตรงกับที่ QA รายงาน)`} />
  <p>รอบ 2 dev แก้โดยแยกส่วนจำนวนเต็มกับทศนิยมออกจากกันก่อนใส่ comma แล้ว QA อนุมัติผ่าน</p>
  <CodeBlock lang="js" title="โค้ดที่ผ่าน QA รอบ 2" code={`export function formatThousands(n) {
  const negative = n < 0;
  const [intPart, fracPart] = Math.abs(n).toString().split(".");
  const grouped = intPart.replace(/\\B(?=(\\d{3})+(?!\\d))/g, ",");
  const body = fracPart === undefined ? grouped : \`\${grouped}.\${fracPart}\`;
  return negative ? \`-\${body}\` : body;
}`} />

  <h2>ลูป feedback มี 2 ทิศทาง</h2>
  <p>
    เคสข้างบนคือลูป <strong>แนวนอน</strong> — dev กับ QA แก้กันเองจนผ่าน โดยที่ผมไม่ต้องเข้าไปยุ่งเลยสักครั้ง
    แต่มีอีกทิศหนึ่งที่สำคัญไม่แพ้กัน คือลูป <strong>แนวตั้ง</strong> — ตอนที่ทีมเด้งกลับมาถาม<strong>มนุษย์</strong>โดยตรง
  </p>
  <p>
    ตอนแรกผมลองให้โจทย์กำกวมกว่านี้ แค่ "ใส่ comma หน่อย" ไม่บอกละเอียดว่าต้องรองรับติดลบหรือทศนิยมไหม
    QA เอะใจว่าตัวเองไม่รู้จะตั้งเกณฑ์ตรวจตรงไหน เพราะความกำกวมไม่ได้อยู่ที่โค้ด แต่อยู่ที่ requirement ตั้งแต่ต้น
    เลยส่งเรื่องกลับไปหา Lead และ Lead ก็ถามผม 3 คำถามตรง ๆ ก่อนจะล็อกสเปกแล้วค่อยส่งงานต่อ
  </p>
  <p>
    ประเด็นสำคัญคือ requirement ที่กำกวมจะถูกตีความเพี้ยนไปเรื่อย ๆ เป็นทอด ๆ ถ้าปล่อยให้ไหลจาก Lead → dev → QA
    โดยไม่มีจุดตัดวงจร แต่ละ agent จะเดาเอาเองคนละแบบ แล้วสุดท้ายผลลัพธ์ที่ได้ก็ไม่มีใครรู้ว่าตรงกับที่ผมต้องการจริง ๆ หรือเปล่า
  </p>
  <p class="pull">agent ที่ดีคือ agent ที่ปฏิเสธจะเดา แล้วถามกลับ — ดีกว่าเดาผิดแล้วส่งต่อความผิดพลาดนั้นไปทั้งสาย</p>

  <h2>แล้ว "ห้องแชตรวม" ที่นั่งดูมันคุยล่ะ?</h2>
  <p>
    ขอซื่อสัตย์ตรงนี้: <strong>ยังไม่มีเป็นฟีเจอร์สำเร็จรูป</strong> ที่ใกล้เคียงที่สุดตอนนี้คือหน้าติดตามความคืบหน้าของ Workflows,
    หน้าแยกจอ (split-pane) ของ Agent Teams ที่โชว์แต่ละ agent กำลังทำอะไร หรือคำสั่ง <code>claude agents</code>
    ที่เปิด dashboard สถานะ — ทั้งหมดนี้เป็น "หน้าสถานะ" ไม่ใช่ "ห้องแชตแบบ transcript" ที่นั่งไล่อ่านบทสนทนาทั้งเส้นได้
  </p>
  <p>
    ทางออกที่ผมทำคือเอา log จากการรัน workflow มา render เป็นห้องแชตเอง (ยังเป็น prototype ที่ผมสร้างขึ้นมาทดลอง ไม่ใช่ของจริงใน Claude Code)
    ยึดหลักออกแบบห้องแชตหลายคนพูดพร้อมกันตามแนวทางที่ UXPin แนะนำไว้สำหรับ chat UI ที่มีผู้พูดมากกว่า 2 คน
  </p>
  <figure class="screenshot">
    <img src="/knowledge/agent-team-room.png" alt="prototype ห้องแชตทีม Claude แสดง 3 โซน: roster ซ้ายมือระบุบทบาทและสีของ You, Team Lead, Dev, QA · ห้องหลักตรงกลางไล่ตาม phase ตั้งแต่ kickoff จนถึง QA อนุมัติ · thread ย่อยด้านขวาสำหรับบทสนทนาที่ไม่เกี่ยวกับสายหลัก" loading="lazy" />
    <figcaption>ทุกข้อความในห้องหลักชิดซ้ายเป็นคอลัมน์เดียวแม้จะมี 4 ผู้พูด ยกเว้น "You (Chi)" ที่ชิดขวาเป็นข้อยกเว้นเดียว — แยกสายตาได้ทันทีว่าอันไหนคือเรา ส่วนบทสนทนาที่ไม่เกี่ยวกับสายหลัก (QA ขอความชัดเจนจาก Lead) ถูกกันไว้เป็น thread ย่อยด้านขวา ไม่ปนกับห้องหลัก</figcaption>
  </figure>
  <div class="callout callout-tip">
    <p class="callout-label">เคล็ดลับ</p>
    <p>
      ถ้าจะออกแบบห้องแชตแบบนี้เอง หลักที่ยึดได้: <strong>ผู้พูดตั้งแต่ 3 คนขึ้นไปให้ใช้คอลัมน์เดียวชิดซ้ายทั้งหมด</strong>
      (บับเบิลซ้าย-ขวาสองฝั่งใช้ได้ดีแค่ตอนคู่สนทนามีแค่ 2 คน พอเกิน 2 จะเริ่มสับสนว่าใครคุยกับใคร) แล้ว<strong>ใช้สีชื่อแยกคนแทนสีทั้งบับเบิล</strong>
      ให้<strong>มนุษย์เป็นข้อยกเว้นเดียวที่ชิดขวา</strong> เพื่อแยกสายตาได้ทันทีว่าไหนคือเรา และแยก thread ย่อยไว้ต่างหาก
      เมื่อ agent สองตัวคุยกันเองโดยไม่เกี่ยวกับเรา (เช่น QA คุยกับ Lead เรื่องขอความชัดเจน) จะได้ไม่ปนกับสายหลัก
    </p>
  </div>

  <h2>จะ "จำ" setting พวกนี้ได้ยังไง</h2>
  <p>
    บทบาท agent ที่เขียนไว้ใน <code>.claude/agents/</code> คู่มือโปรเจกต์ใน <code>CLAUDE.md</code> ไฟล์ความจำระยะยาว
    และ workflow script ที่เซฟไว้ใน <code>.claude/workflows/</code> — ทั้งหมดนี้เก็บเป็นไฟล์ในโปรเจกต์ ทุก session ถัดไปที่เปิดโปรเจกต์เดียวกันจะอ่านเจอเอง
    ไม่ต้องอธิบายบทบาทหรือลำดับงานซ้ำทุกครั้ง
  </p>
  <div class="callout callout-note">
    <p class="callout-label">โน้ต</p>
    <p>
      ข้อจำกัดที่ควรรู้ไว้: การตั้งค่าพวกนี้ผูกกับเครื่องและโปรเจกต์ที่บันทึกไฟล์ไว้ ไม่ sync ข้ามเครื่องอัตโนมัติ
      และแต่ละ session ไม่ได้ "คุยข้าม session สด ๆ" กันเองได้ — ถ้าอยากกลับไปดูบทสนทนาเก่าต้องใช้ <code>/resume</code> เรียกคืนมา
    </p>
  </div>

  <h2>ข้อควรระวัง</h2>
  <div class="card">
    <ul>
      <li>Agent Teams ยังเป็น experimental feature อยู่ อาจเจอพฤติกรรมแปลก ๆ เรื่องการ resume session หรือการปิดทีมไม่สมบูรณ์</li>
      <li>Workflows มีเพดานตายตัว: agent รันพร้อมกันสูงสุด 16 ตัว รวมทั้งรันไม่เกิน 1,000 ตัว และยิ่งเรียก agent เยอะยิ่งกินโควตา token มากตามไปด้วย</li>
      <li><strong>"ลูปวนจนผ่าน" ไม่ได้แปลว่า "ถูกเสมอ"</strong> — QA ก็เป็น AI เหมือนกัน ยังต้องมีคนตรวจปลายทางอยู่ดี โดยเฉพาะงานที่มีผลกระทบสูง</li>
      <li>การตั้งค่าบทบาทหรือ permission ต่าง ๆ ไม่ใช่กำแพงความปลอดภัยจริง เป็นแค่การจัดระเบียบงาน ไม่ควรเอาไปพึ่งพาเป็นเกราะป้องกันข้อมูลสำคัญ</li>
    </ul>
  </div>

  <h2>สรุป</h2>
  <p>
    ตั้งบริษัทซอฟต์แวร์ที่มี Lead-dev-QA เป็น Claude ล้วน ๆ ทำได้จริงวันนี้ — ผ่าน Agent Teams, Workflows หรือ sub-agents
    แล้วแต่ว่าอยากได้ความยืดหยุ่นหรือความแน่นอนมากกว่ากัน แต่หัวใจที่ทำให้ทีมแบบนี้ต่างจาก AI ตัวเดียวตรวจงานตัวเองจริง ๆ
    ไม่ใช่จำนวน agent ที่มี แต่คือ<strong>ลูป feedback ที่ยอมเด้งกลับไปถามเมื่อไม่แน่ใจ</strong> — ทั้งในแนวนอนระหว่าง agent ด้วยกัน
    และในแนวตั้งกลับมาหาเรา
  </p>

