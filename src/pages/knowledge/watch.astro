      <text x="108" y="49" font-size="13.5" font-weight="700" fill="#294266" text-anchor="middle">วิดีโอ (ขาเข้า)</text>
      <text x="108" y="66" font-size="10.5" fill="#7a869a" text-anchor="middle">ยูทูบ · TikTok · ไฟล์</text>

      <text x="245" y="40" font-size="11" font-weight="700" fill="#3a5680" text-anchor="middle">/watch</text>
      <text x="245" y="54" font-size="9.5" fill="#7a869a" text-anchor="middle">เฟรม + transcript</text>
      <line x1="192" y1="60" x2="286" y2="82" stroke="#4d72a9" stroke-width="2.2" marker-end="url(#vc-arr)"/>

      <!-- bottom row: output (ffmpeg) -->
