---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/articles';
---
<Layout title="หมวดความรู้ | ChimengSoso" description="ความลับจากสายพัฒนาที่แชร์ไว้ตรงนี้ — ถ้าไม่รู้ไว้ก่อนคือพลาด" narrow>
  <a class="back" href="/" data-astro-prefetch="viewport">
    <svg class="back-arrow" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/></svg>
    กลับหน้าโปรไฟล์
  </a>
  <h1>หมวดความรู้</h1>
  <div class="sub">ความลับจากสายพัฒนาที่แชร์ไว้ตรงนี้ — ถ้าไม่รู้ไว้ก่อนคือพลาด</div>

  <div class="list">
    {articles.map((a, i) => (
      <a class={`item ${a.soon ? 'soon' : ''}`} href={a.href} style={`animation-delay:${i * 60}ms`} data-astro-prefetch={a.soon ? undefined : 'viewport'}>
        <span class="tag">{a.tag}</span>
        <h3>{a.title}</h3>
        <p>{a.desc}</p>
      </a>
    ))}
  </div>
</Layout>

<style>
  .back{
    display:inline-flex;
    align-items:center;
    gap:4px;
    margin-bottom:1.25rem;
    text-decoration:none;
    font-size:0.82rem;
    color:#5a6a85;
    transition:color .15s;
  }
  .back:hover{color:#294266;}
  .back-arrow{
    width:16px;
    height:16px;
    flex-shrink:0;
    transition:transform .15s ease, color .15s;
  }
  .back:hover .back-arrow{transform:translateX(-3px);}
  h1{
    font-size:20px;
    color:#131e30;
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  .sub{
    color:#4d72a9;
    font-size:12px;
    margin-top:6px;
    margin-bottom:24px;
  }
  .list{display:flex;flex-direction:column;gap:12px;}
  .item{
    display:block;
    border:1px solid #bcd3f8;
    border-radius:14px;
    padding:15px 18px;
    text-decoration:none;
    color:#131e30;
    opacity:0;
    animation:slideIn .4s cubic-bezier(.16,1,.3,1) both;
    transition:border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  @keyframes slideIn{
    from{opacity:0;transform:translateY(8px);}
    to{opacity:1;transform:translateY(0);}
  }
  .item:hover{
    border-color:#4d72a9;
    background:#ecf3fc;
    transform:translateY(-2px);
    box-shadow:0 8px 16px -6px rgba(22,63,120,0.25);
  }
  .item .tag{
    display:inline-block;
    font-size:10px;
    background:#294266;
    color:#ecf3fc;
    padding:2px 9px;
    border-radius:20px;
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .item h3{font-size:14px;margin-bottom:4px;}
  .item p{font-size:12px;color:#5a6a85;}
  .item.soon{opacity:0.45 !important;pointer-events:none;}
</style>
