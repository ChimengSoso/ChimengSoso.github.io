---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    href: 'claude-intro/',
    tag: 'แนะนำเบื้องต้น',
    title: 'Claude คืออะไร ใช้ยังไง',
    desc: 'ปูพื้นฐาน Claude, ใช้ทำอะไรได้, เข้าถึงจากไหน และเริ่มต้นใช้งานยังไง',
    soon: false,
  },
  {
    href: '#',
    tag: 'เร็วๆ นี้',
    title: 'เทคนิคการเขียน Prompt ให้ได้ผลลัพธ์ดีขึ้น',
    desc: 'กำลังจัดทำเนื้อหา',
    soon: true,
  },
  {
    href: '#',
    tag: 'เร็วๆ นี้',
    title: 'ใช้ Claude ผ่าน API เบื้องต้น',
    desc: 'กำลังจัดทำเนื้อหา',
    soon: true,
  },
];
---
<Layout title="หมวดความรู้ | ChimengSoso" description="รวมเรื่องเล่าจากสายพัฒนา และเกร็ดความรู้อื่น ๆ ที่แวะเวียนผ่านมา" narrow>
  <a class="back" href="../index.html">&larr; กลับหน้าโปรไฟล์</a>
  <h1>หมวดความรู้</h1>
  <div class="sub">รวมเรื่องเล่าจากสายพัฒนา และเกร็ดความรู้อื่น ๆ ที่แวะเวียนผ่านมา</div>

  <div class="list">
    {articles.map((a, i) => (
      <a class={`item ${a.soon ? 'soon' : ''}`} href={a.href} style={`animation-delay:${i * 60}ms`}>
        <span class="tag">{a.tag}</span>
        <h3>{a.title}</h3>
        <p>{a.desc}</p>
      </a>
    ))}
  </div>
</Layout>

<style>
  .back{
    display:inline-block;
    font-size:12px;
    color:#294266;
    text-decoration:none;
    margin-bottom:16px;
    transition:opacity .15s;
  }
  .back:hover{opacity:.65;}
  h1{
    font-size:20px;
    color:#131e30;
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  .sub{
    color:#4d72a9;
    font-size:12px;
    margin-top:6px;
    margin-bottom:24px;
  }
  .list{display:flex;flex-direction:column;gap:12px;}
  .item{
    display:block;
    border:1px solid #bcd3f8;
    border-radius:14px;
    padding:15px 18px;
    text-decoration:none;
    color:#131e30;
    opacity:0;
    animation:slideIn .4s cubic-bezier(.16,1,.3,1) both;
    transition:border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  @keyframes slideIn{
    from{opacity:0;transform:translateY(8px);}
    to{opacity:1;transform:translateY(0);}
  }
  .item:hover{
    border-color:#4d72a9;
    background:#ecf3fc;
    transform:translateY(-2px);
    box-shadow:0 8px 16px -6px rgba(22,63,120,0.25);
  }
  .item .tag{
    display:inline-block;
    font-size:10px;
    background:#294266;
    color:#ecf3fc;
    padding:2px 9px;
    border-radius:20px;
    text-transform:uppercase;
    margin-bottom:8px;
  }
  .item h3{font-size:14px;margin-bottom:4px;}
  .item p{font-size:12px;color:#5a6a85;}
  .item.soon{opacity:0.45 !important;pointer-events:none;}
</style>
