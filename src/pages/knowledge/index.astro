---
import Layout from '../../layouts/Layout.astro';
import { articles, type Article } from '../../data/articles';
import { formatThaiDateShort } from '../../lib/dates';

// Split a title/description into segments so the template can render slash-command tokens
// (e.g. /grill-me, /handoff) as inline-code chips — matching the article page, breadcrumb,
// and OG card. JSX can't live in the frontmatter, so we only split here and wrap in the
// template below. Odd-index segments are the captured tokens.
const splitCommands = (text: string) => text.split(/(\/[a-zA-Z0-9-]+)/g);
const isCommand = (seg: string) => /^\/[a-zA-Z0-9-]+$/.test(seg);

// Group articles by their tag, preserving the array order (which is the intended reading
// sequence). First-seen tag order becomes the section order: intro → core skills → takes.
interface Group { tag: string; items: Article[]; }
const groups: Group[] = [];
for (const a of articles) {
  const g = groups.find((x) => x.tag === a.tag);
  if (g) g.items.push(a);
  else groups.push({ tag: a.tag, items: [a] });
}

const publishedCount = articles.filter((a) => !a.soon).length;
---
<Layout title="หมวดความรู้ | ChimengSoso" description="ความลับจากสายพัฒนาที่แชร์ไว้ตรงนี้ — ถ้าไม่รู้ไว้ก่อนคือพลาด" toc={false}>
  <a class="back" href="/" data-astro-prefetch="viewport">
    <svg class="back-arrow" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/></svg>
    กลับหน้าโปรไฟล์
  </a>
  <h1>หมวดความรู้</h1>
  <div class="sub">ความลับจากสายพัฒนาที่แชร์ไว้ตรงนี้ — ถ้าไม่รู้ไว้ก่อนคือพลาด · {publishedCount} บทความ</div>

  {groups.map((group, gi) => (
    <section class="group">
      <h2 class="group-title">
        {group.tag}
        <span class="group-count" data-toc-ignore>{group.items.length}</span>
      </h2>
      <div class="list">
        {/* soon-placeholders get no href: pointer-events:none already blocks the mouse,
            but an href would keep the dead card keyboard-focusable (Tab + Enter = 404). */}
        {group.items.map((a, i) => (
          <a class={`item ${a.soon ? 'soon' : ''}`} href={a.soon ? undefined : a.href} style={`animation-delay:${(gi * 3 + i) * 55}ms`} data-astro-prefetch={a.soon ? undefined : 'viewport'}>
            <h3>{splitCommands(a.title).map((seg) => isCommand(seg) ? <code>{seg}</code> : seg)}</h3>
            <p>{splitCommands(a.desc).map((seg) => isCommand(seg) ? <code>{seg}</code> : seg)}</p>
            <div class="meta">
              {a.soon ? (
                <span class="badge-soon">เร็วๆ นี้</span>
              ) : (
                <Fragment>
                  {a.readingMinutes && (
                    <span class="rt">
                      <svg class="rt-icon" viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="8" cy="8" r="6.3"/><path stroke-linecap="round" d="M8 4.5V8l2.4 1.6"/></svg>
                      อ่าน {a.readingMinutes} นาที
                    </span>
                  )}
                  {a.dateISO && <span class="date">{formatThaiDateShort(a.dateISO)}</span>}
                </Fragment>
              )}
              <span class="go" aria-hidden="true">อ่านต่อ<svg class="go-arrow" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/></svg></span>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>

<style>
  .back{
    display:inline-flex;
    align-items:center;
    gap:4px;
    margin-bottom:1.25rem;
    text-decoration:none;
    font-size:0.82rem;
    color:var(--muted);
    transition:color .15s;
  }
  .back:hover{color:var(--blue-deep);}
  .back-arrow{
    width:16px;
    height:16px;
    flex-shrink:0;
    transition:transform .15s ease, color .15s;
  }
  .back:hover .back-arrow{transform:translateX(-3px);}
  h1{
    font-size:1.75rem;
    color:var(--ink);
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  .sub{
    color:var(--blue);
    font-size:0.9rem;
    margin-top:0.375rem;
    margin-bottom:1.5rem;
  }

  /* Category section: a small sticky-feeling label groups related articles so the four
     "Claude Code" cards read as one cluster instead of four repeated pills. */
  .group{margin-bottom:1.5rem;}
  .group-title{
    display:flex;
    align-items:center;
    gap:8px;
    font-size:0.8rem;
    font-weight:700;
    color:var(--blue-deep);
    text-transform:uppercase;
    letter-spacing:0.6px;
    margin-bottom:0.7rem;
    padding-bottom:0.5rem;
    border-bottom:1px solid #dbe6f8;
  }
  .group-count{
    font-size:0.68rem;
    font-weight:600;
    color:var(--muted);
    background:#eaf1fc;
    border-radius:20px;
    padding:0.06rem 0.5rem;
    letter-spacing:0;
  }

  .list{display:flex;flex-direction:column;gap:0.6rem;}
  .item{
    display:block;
    border:1px solid #cfdff7;
    border-radius:12px;
    padding:1rem 1.15rem;
    text-decoration:none;
    color:var(--ink);
    opacity:0;
    animation:slideIn .4s cubic-bezier(.16,1,.3,1) both;
    transition:border-color .18s ease, background .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  @keyframes slideIn{
    from{opacity:0;transform:translateY(8px);}
    to{opacity:1;transform:translateY(0);}
  }
  .item:hover{
    border-color:var(--blue);
    background:#f2f7fe;
    transform:translateY(-2px);
    box-shadow:0 8px 16px -6px rgba(22,63,120,0.25);
  }
  .item h3{font-size:1.1rem;margin-bottom:0.3rem;line-height:1.5;}
  .item p{font-size:0.97rem;color:var(--muted);line-height:1.65;margin-bottom:0.6rem;}
  /* Slash-command tokens in a title or description show as inline-code chips (matches the
     article page, breadcrumb, and OG card). */
  .item h3 code,
  .item p code{
    font-family:"Fira Code","Fira Mono",monospace;
    font-variant-ligatures:none;
    font-size:0.9em;
    background:#e3edfb;
    color:var(--blue-deep);
    padding:0.02em 0.3em;
    border-radius:5px;
  }

  /* Meta row: reading time (the primary scan anchor) + publish date, with a "read more"
     affordance that slides in on hover so each card signals it's tappable. */
  .meta{
    display:flex;
    align-items:center;
    gap:0.65rem;
    font-size:0.75rem;
    color:#7183a1;
  }
  .rt{display:inline-flex;align-items:center;gap:0.28em;font-weight:600;color:var(--blue);}
  .rt-icon{width:1.05em;height:1.05em;flex-shrink:0;}
  .date{position:relative;padding-left:0.75em;}
  .date::before{content:'·';position:absolute;left:0.13em;color:#a9b8d0;}
  .badge-soon{
    font-weight:600;
    color:#8a97ad;
    background:#eef1f6;
    border-radius:20px;
    padding:1px 9px;
  }
  .go{
    display:inline-flex;
    align-items:center;
    gap:4px;
    margin-left:auto;
    font-weight:600;
    color:var(--blue);
    opacity:0;
    transform:translateX(-4px);
    transition:opacity .18s ease, transform .18s ease;
  }
  .go-arrow{
    width:1.1em;
    height:1.1em;
    flex-shrink:0;
    transition:transform .15s ease;
  }
  .item:hover .go{opacity:1;transform:translateX(0);}
  /* Mirror of .back-arrow's hover nudge — the chevron slides toward its own direction (right). */
  .item:hover .go-arrow{transform:translateX(3px);}
  .item.soon{opacity:0.5 !important;pointer-events:none;}
  .item.soon .go{display:none;}

  /* Touch devices can't hover, so always show the read-more cue there. */
  @media (hover: none){
    .go{opacity:1;transform:none;}
  }
  @media (prefers-reduced-motion: reduce){
    .item{animation:none;opacity:1;}
    .item:hover{transform:none;}
    .go, .go-arrow{transition:none;}
    .item:hover .go-arrow{transform:none;}
  }
</style>
