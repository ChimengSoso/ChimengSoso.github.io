      <path d="M560 140 q+3 -60 -142 5" fill="none" stroke="#294266" stroke-width="2" marker-end="url(#tax-ar)"/>
      <text x="540" y="105" font-size="12" font-weight="700" fill="#294266" text-anchor="middle">ภาษี Pigouvian ดึงกลับ</text>
      <!-- overlapped point -->
      <circle cx="400" cy="150" r="12" fill="none" stroke="#b23b3b" stroke-width="1.8"/>
      <circle cx="400" cy="150" r="7" fill="#2f9e5c"/>
