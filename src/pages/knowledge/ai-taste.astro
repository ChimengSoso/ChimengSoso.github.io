      <circle cx="560" cy="150" r="7" fill="#ffffff" stroke="#d9a3a3" stroke-width="1.5" stroke-dasharray="3 2"/>
      <text x="560" y="202" font-size="11" fill="#b08a8a" text-anchor="middle">เดิม: จุดที่บริษัทเลือก</text>
