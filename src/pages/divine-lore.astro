---
import Layout from '../layouts/Layout.astro';
---
<Layout title="บันทึกศาสตร์แห่งเทพ" description="เจ้าทำสำเร็จที่เข้าหน้านี้ได้" noindex>
  <p id="divine-lore-checking">กำลังตรวจสิทธิ์...</p>
  <div id="divine-lore-content" hidden>
    <h1>บันทึกศาสตร์แห่งเทพ</h1>
    <p>เจ้าทำสำเร็จที่เข้าหน้านี้ได้</p>
  </div>
</Layout>

<script>
  // This page is only meant to be reached through SecretConsole.astro's login
  // puzzle, which stores a checksum token (see divineLoreToken.ts) right
  // before redirecting here. The real content stays hidden behind the
  // "checking" placeholder until a valid token is confirmed -- swapped in
  // synchronously in the same astro:page-load tick, so it never flashes on
  // screen for someone who hit this URL directly without one -- they see the
  // checking message and then get bounced back to `/` instead.
  import { TOKEN_KEY, isValidToken } from '../lib/divineLoreToken';

  document.addEventListener('astro:page-load', () => {
    const checking = document.getElementById('divine-lore-checking');
    const content = document.getElementById('divine-lore-content');
    if (!checking || !content) return;

    if (isValidToken(sessionStorage.getItem(TOKEN_KEY))) {
      checking.hidden = true;
      content.hidden = false;
    } else {
      window.location.replace('/');
    }
  });
</script>
