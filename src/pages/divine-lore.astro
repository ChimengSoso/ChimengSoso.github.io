          </marker>
        </defs>
        <text x="360" y="24" font-size="15" font-weight="700" fill="#131e30" text-anchor="middle">สปอตไลต์ดวงเดียวกลางเวที = ความคิดที่ "รู้ตัว"</text>
        <ellipse cx="360" cy="78" rx="86" ry="34" fill="#fff6da" stroke="#e0b400" stroke-width="1.5"/>
        <text x="360" y="74" font-size="12.5" font-weight="700" fill="#846400" text-anchor="middle">ช่องกลาง (J-space)</text>
        <text x="360" y="92" font-size="11" fill="#9a7a10" text-anchor="middle">มีแค่ไม่กี่สิบ concept</text>
        <g font-size="11" fill="#5a6a85" text-anchor="middle">
          <rect x="30" y="176" width="120" height="46" rx="9" fill="#eef2f8" stroke="#9aa7bd"/>
