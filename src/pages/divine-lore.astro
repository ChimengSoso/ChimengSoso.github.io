          <text x="230" y="204">ทีมความจำ</text>
          <rect x="310" y="176" width="120" height="46" rx="9" fill="#eef2f8" stroke="#9aa7bd"/>
          <text x="370" y="204">ทีมความรู้ทั่วไป</text>
          <rect x="450" y="176" width="120" height="46" rx="9" fill="#eef2f8" stroke="#9aa7bd"/>
          <text x="510" y="204">ทีมไวยากรณ์</text>
          <rect x="590" y="176" width="100" height="46" rx="9" fill="#eef2f8" stroke="#9aa7bd"/>
          <text x="640" y="204">ทีมอื่น ๆ</text>
