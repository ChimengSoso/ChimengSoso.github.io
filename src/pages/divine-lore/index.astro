---
import DivineLoreLayout from '../../layouts/DivineLoreLayout.astro';
import { divineLoreEntries } from '../../data/divineLore';
import { formatThaiDateShort } from '../../lib/dates';
---
<DivineLoreLayout title="บันทึกศาสตร์แห่งเทพ" description="เจ้าทำสำเร็จที่เข้าหน้านี้ได้">
  <p id="divine-lore-checking">กำลังตรวจสิทธิ์...</p>
  <div id="divine-lore-content" hidden>
    <nav class="dl-nav">
      <a href="/">
        <svg class="dl-nav-arrow" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/></svg>
        กลับหน้าแรก
      </a>
    </nav>
    <p class="tag">บันทึกศาสตร์แห่งเทพ</p>
    <h1>เจ้าทำสำเร็จที่เข้าหน้านี้ได้</h1>
    <p class="subtitle">
      ตามรอยดาวมะรกต ไขปริศนา Konami แกะรหัสผ่านจนถึงหน้านี้ — เป็นรางวัลให้ครับ นี่คือคลังบันทึกที่ผมไม่ได้เอาไปวางไว้ในหมวดความรู้ปกติ เพราะรู้สึกว่ามันควรเป็นของลับที่ต้องหามาเจอเอง ไม่ใช่ของที่ scroll เจอเฉย ๆ — เปิดดูได้เลยครับ
    </p>

    <div class="list">
      {divineLoreEntries.map((e) => (
        <a class="item" href={e.href}>
          <span class="item-tag">{e.tag}</span>
          <h3>{e.title}</h3>
          <p>{e.desc}</p>
          <div class="meta">
            <span class="rt">อ่าน {e.readingMinutes} นาที</span>
            <span class="date">{formatThaiDateShort(e.dateISO)}</span>
            <span class="go" aria-hidden="true">เปิดอ่าน<svg class="go-arrow" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</DivineLoreLayout>

<style>
  .list{display:flex;flex-direction:column;gap:0.75rem;margin-top:1.5rem;}
  .item{
    display:block;
    border:1px solid var(--dl-border);
    border-radius:14px;
    padding:1.1rem 1.25rem;
    text-decoration:none;
    color:var(--dl-ink);
    transition:border-color .18s ease, background .18s ease, transform .18s ease;
  }
  .item:hover{
    border-color:var(--dl-emerald);
    background:rgba(47,158,92,0.08);
    transform:translateY(-2px);
  }
  .item-tag{
    display:inline-block;
    font-family:"JetBrains Mono", monospace;
    font-size:0.62rem;
    color:var(--dl-gold);
    text-transform:uppercase;
    letter-spacing:.5px;
    margin-bottom:0.4rem;
  }
  .item h3{font-size:1.05rem;margin-bottom:0.3rem;line-height:1.5;color:#fff;}
  .item p{font-size:0.92rem;color:var(--dl-muted);line-height:1.6;margin:0 0 0.6rem;}
  .meta{
    display:flex;
    align-items:center;
    gap:0.65rem;
    font-size:0.75rem;
    color:var(--dl-muted);
    font-family:"JetBrains Mono", monospace;
  }
  .rt{color:var(--dl-emerald-bright);font-weight:600;}
  .go{
    margin-left:auto;
    display:inline-flex;
    align-items:center;
    gap:3px;
    color:var(--dl-emerald-bright);
    font-weight:600;
  }
  .go-arrow{
    width:13px;
    height:13px;
    flex-shrink:0;
    transition:transform .15s ease;
  }
  .item:hover .go-arrow{transform:translateX(3px);}
  @media (prefers-reduced-motion: reduce){
    .item:hover .go-arrow{transform:none;}
  }
  @media (prefers-reduced-motion: reduce){
    .item{transition:none;}
    .item:hover{transform:none;}
  }
</style>

<script>
  // Wrapped in astro:page-load (see StarfieldBackground.astro for why) -- this
  // layout now includes <ClientRouter />, so this script's module scope only
  // ever runs once; the handler must re-run its DOM lookup on every navigation
  // into this page.
  import { TOKEN_KEY, isValidToken } from '../../lib/divineLoreToken';

  document.addEventListener('astro:page-load', () => {
    const checking = document.getElementById('divine-lore-checking');
    const content = document.getElementById('divine-lore-content');
    if (!checking || !content) return;

    if (isValidToken(sessionStorage.getItem(TOKEN_KEY))) {
      checking.hidden = true;
      content.hidden = false;
    } else {
      window.location.replace('/');
    }
  });
</script>
