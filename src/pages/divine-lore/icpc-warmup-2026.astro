<script>
  (function () {
    function initOne(fig: HTMLElement): void {
      if (fig.dataset.wired === '1') return;
      const capEl = fig.querySelector<HTMLElement>('.glyph-cap');
      const prev = fig.querySelector<HTMLButtonElement>('.ga-prev');
      const next = fig.querySelector<HTMLButtonElement>('.ga-next');
      const play = fig.querySelector<HTMLButtonElement>('.ga-play');
      const dots = Array.from(fig.querySelectorAll<HTMLButtonElement>('.ga-dots button'));
      if (!capEl || !prev || !next || !play || dots.length === 0) return;

      const parsed: unknown = JSON.parse(fig.dataset.caps || '[]');
      const caps: string[] = Array.isArray(parsed)
        ? (parsed as unknown[]).filter((c): c is string => typeof c === 'string')
        : [];
      const TOTAL = dots.length;
      if (caps.length !== TOTAL) return;
      fig.dataset.wired = '1';

      let step = 1;
      let timer: number | null = null;

      function render(): void {
        fig.dataset.step = String(step);
        capEl!.textContent = caps[step - 1];
        prev!.disabled = step === 1 && timer === null;
        next!.disabled = step === TOTAL && timer === null;
        dots.forEach((d, i) => d.setAttribute('aria-current', i + 1 === step ? 'true' : 'false'));
      }
      function go(s: number): void {
        step = Math.max(1, Math.min(TOTAL, s));
        render();
      }
      function stop(): void {
        if (timer !== null) {
          clearInterval(timer);
          timer = null;
          play!.textContent = '▶ เล่นอัตโนมัติ';
          play!.setAttribute('aria-pressed', 'false');
        }
        render();
      }
      function start(): void {
        timer = window.setInterval(() => {
          step = step >= TOTAL ? 1 : step + 1;
          render();
        }, 1700);
        play!.textContent = '⏸ หยุด';
        play!.setAttribute('aria-pressed', 'true');
        render();
      }

      prev.addEventListener('click', () => { stop(); go(step - 1); });
      next.addEventListener('click', () => { stop(); go(step + 1); });
      dots.forEach((d, i) => d.addEventListener('click', () => { stop(); go(i + 1); }));
      play.addEventListener('click', () => { if (timer === null) { start(); } else { stop(); } });

      render();
    }

    function initAll(): void {
      document.querySelectorAll<HTMLElement>('.glyph-anim').forEach(initOne);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }
  })();
</script>

<script>
  // Playground ข้อ A: ลาก/คลิกเลือกตำแหน่งปักเข็มบนไม้ แล้วจำลองการหมุนเป็นวงกลม
  (function () {
    const CX = 180;      // จุดหมุน (พิกัด svg)
    const CY = 192;
    const X0 = 50;       // ปลายไม้ซ้าย
    const X1 = 310;      // ปลายไม้ขวา
    const TOP = -Math.PI / 2;

    function sector(r: number, a1: number): string {
      const large = a1 - TOP > Math.PI ? 1 : 0;
      const sx = CX + r * Math.cos(TOP);
      const sy = CY + r * Math.sin(TOP);
      const ex = CX + r * Math.cos(a1);
      const ey = CY + r * Math.sin(a1);
      return `M ${CX} ${CY} L ${sx.toFixed(2)} ${sy.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${ex.toFixed(2)} ${ey.toFixed(2)} Z`;
    }

    function initOne(fig: HTMLElement): void {
      if (fig.dataset.wired === '1') return;
      const L = Number(fig.dataset.len || '10');
      const PPU = Number(fig.dataset.ppu || '8.5');
      // เช็คว่ามีครบก่อน แล้วค่อยประกาศแบบ non-null (เลี่ยง null-narrowing ข้าม closure)
      const sel = ['.ns-stage', '.ns-stickzone', '.ns-needle', '.ns-arm-l', '.ns-arm-r', '.ns-inner', '.ns-target', '.ns-disk-full', '.ns-sweep', '.ns-stickspin', '.ns-tip-long', '.ns-tip-short', '.ns-area', '.ns-center', '.ns-end'];
      if (sel.some((s) => !fig.querySelector(s))) return;
      const svg = fig.querySelector<SVGSVGElement>('.ns-stage')!;
      const zone = fig.querySelector<SVGGElement>('.ns-stickzone')!;
      const needle = fig.querySelector<SVGGElement>('.ns-needle')!;
      const armL = fig.querySelector<SVGTextElement>('.ns-arm-l')!;
      const armR = fig.querySelector<SVGTextElement>('.ns-arm-r')!;
      const inner = fig.querySelector<SVGCircleElement>('.ns-inner')!;
      const target = fig.querySelector<SVGCircleElement>('.ns-target')!;
      const full = fig.querySelector<SVGCircleElement>('.ns-disk-full')!;
      const sweep = fig.querySelector<SVGPathElement>('.ns-sweep')!;
      const stick = fig.querySelector<SVGLineElement>('.ns-stickspin')!;
      const tipLong = fig.querySelector<SVGCircleElement>('.ns-tip-long')!;
      const tipShort = fig.querySelector<SVGCircleElement>('.ns-tip-short')!;
      const areaEl = fig.querySelector<SVGTextElement>('.ns-area')!;
      const btnCenter = fig.querySelector<HTMLButtonElement>('.ns-center')!;
      const btnEnd = fig.querySelector<HTMLButtonElement>('.ns-end')!;
      fig.dataset.wired = '1';

      const areaHead = areaEl.querySelector<SVGTSpanElement>('tspan');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const pxPerUnit = (X1 - X0) / L;
      // เริ่มที่ตำแหน่งเยื้อง (ไม่ใช่กลาง) เพื่อให้ผู้เล่นลากเองแล้วค้นพบว่ากลางไม้ให้วงเล็กสุด
      let pos = Math.max(1, Math.round(L * 0.2));
      let anim: number | null = null;

      function longUnits(p: number): number { return Math.max(p, L - p); }
      function shortUnits(p: number): number { return Math.min(p, L - p); }

      function xAt(p: number): number {
        return X0 + p * pxPerUnit;
      }

      function stopAnim(): void {
        if (anim !== null) {
          cancelAnimationFrame(anim);
          anim = null;
        }
      }

      // วางไม้ที่มุม a: ปลายยาว (เขียว) ด้านหนึ่ง ปลายสั้น (จาง) ตรงข้าม
      function placeStick(a: number, longP: number, shortP: number): void {
        const lx = CX + longP * Math.cos(a);
        const ly = CY + longP * Math.sin(a);
        const sx = CX - shortP * Math.cos(a);
        const sy = CY - shortP * Math.sin(a);
        stick.setAttribute('x1', sx.toFixed(2));
        stick.setAttribute('y1', sy.toFixed(2));
        stick.setAttribute('x2', lx.toFixed(2));
        stick.setAttribute('y2', ly.toFixed(2));
        tipLong.setAttribute('cx', lx.toFixed(2));
        tipLong.setAttribute('cy', ly.toFixed(2));
        tipShort.setAttribute('cx', sx.toFixed(2));
        tipShort.setAttribute('cy', sy.toFixed(2));
      }

      function showStick(on: boolean): void {
        const v = on ? '1' : '0';
        stick.setAttribute('opacity', v);
        tipLong.setAttribute('opacity', v);
        tipShort.setAttribute('opacity', shortUnits(pos) === 0 ? '0' : v);
      }

      function paintResult(): void {
        // สถานะพัก: โชว์วงนอก(max)+วงใน(min) เส้นประ ยังไม่หมุน
        sweep.setAttribute('opacity', '0');
        full.setAttribute('opacity', '0');
        showStick(false);
      }

      function render(): void {
        const longR = longUnits(pos);
        const shortR = shortUnits(pos);
        const longP = longR * PPU;
        const shortP = shortR * PPU;
        needle.setAttribute('transform', `translate(${xAt(pos)},0)`);
        armL.textContent = `แขนซ้าย a = ${pos}`;
        armR.textContent = `แขนขวา b = ${L - pos}`;
        target.setAttribute('r', String(longP));
        full.setAttribute('r', String(longP));
        inner.setAttribute('r', String(shortP));
        if (areaHead) areaHead.textContent = `พื้นที่ = ${longR * longR}`;
        // ให้ป้ายพื้นที่ห่างจากขอบวงนอกเสมอ (วงใหญ่ก็ยังไม่ทับ)
        areaEl.setAttribute('y', String(Math.round(CY + longP + 34)));
        const isMin = pos === L / 2;
        fig.classList.toggle('is-min', isMin);
        zone.setAttribute('aria-valuenow', String(pos));
        zone.setAttribute('aria-valuetext', isMin ? 'ปักกลางไม้ พื้นที่น้อยที่สุด' : `แขนยาวสุด ${longR} หน่วย แขนสั้น ${shortR} หน่วย`);
        paintResult();
      }

      function setPos(p: number, live: boolean): void {
        const np = Math.max(0, Math.min(L, Math.round(p)));
        const same = np === pos && fig.dataset.init === '1';
        pos = np;
        fig.dataset.init = '1';
        stopAnim();
        render();
        // live = ระหว่างลาก แสดงแค่วง ยังไม่หมุน; ปล่อยแล้วค่อยหมุนอัตโนมัติ
        if (!live && !same) run();
      }

      function run(): void {
        stopAnim();
        const longP = longUnits(pos) * PPU;
        const shortP = shortUnits(pos) * PPU;
        sweep.setAttribute('opacity', '1');
        full.setAttribute('opacity', '0');
        showStick(true);

        function finish(): void {
          sweep.setAttribute('opacity', '0');
          full.setAttribute('opacity', '1');
          placeStick(TOP, longP, shortP); // ไม้พักตั้งตรง โชว์ทั้งสองปลายทับวงที่ได้
          showStick(true);
          anim = null;
        }

        if (reduce) { finish(); return; }

        const dur = 1500;
        let start = -1;
        function frame(ts: number): void {
          if (start < 0) start = ts;
          const t = Math.min(1, (ts - start) / dur);
          const a = TOP + t * Math.PI * 2 * 0.9999;
          sweep.setAttribute('d', sector(longP, a));
          placeStick(a, longP, shortP);
          if (t < 1) { anim = requestAnimationFrame(frame); } else { finish(); }
        }
        anim = requestAnimationFrame(frame);
      }

      function posFromEvent(e: PointerEvent, live: boolean): void {
        const rect = svg.getBoundingClientRect();
        const sx = ((e.clientX - rect.left) / rect.width) * 360; // 360 = viewBox width
        setPos((sx - X0) / pxPerUnit, live);
      }

      let dragging = false;
      zone.addEventListener('pointerdown', (e) => {
        dragging = true;
        fig.classList.add('is-dragging'); // โชว์คำใบ้ "ปล่อยได้"
        zone.setPointerCapture(e.pointerId);
        posFromEvent(e, true);
      });
      zone.addEventListener('pointermove', (e) => { if (dragging) posFromEvent(e, true); });
      zone.addEventListener('pointerup', (e) => {
        dragging = false;
        fig.classList.remove('is-dragging');
        zone.releasePointerCapture(e.pointerId);
        run(); // ปล่อยเมื่อไหร่ หมุนให้ดูทันที
      });
      zone.addEventListener('pointercancel', () => {
        dragging = false;
        fig.classList.remove('is-dragging');
      });
      zone.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { setPos(pos - 1, false); e.preventDefault(); }
        else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { setPos(pos + 1, false); e.preventDefault(); }
        else if (e.key === 'Home') { setPos(0, false); e.preventDefault(); }
        else if (e.key === 'End') { setPos(L, false); e.preventDefault(); }
        else if (e.key === 'Enter' || e.key === ' ') { run(); e.preventDefault(); }
      });

      btnCenter.addEventListener('click', () => { setPos(L / 2, true); run(); });
      btnEnd.addEventListener('click', () => { setPos(0, true); run(); });

      render();
      run(); // หมุนโชว์ทันทีจากไม้ที่แสดงอยู่ตอนแรก
    }

    function initAll(): void {
      document.querySelectorAll<HTMLElement>('.needle-sim').forEach(initOne);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }
  })();
</script>

<script>
  // เฉลยเบลอ: กดปุ่มแล้วเปิดให้เห็น
  (function () {
    function wire(): void {
      document.querySelectorAll<HTMLElement>('[data-spoiler]').forEach((box) => {
        if (box.dataset.wired === '1') return;
        const btn = box.querySelector<HTMLButtonElement>('.spoiler-reveal');
        if (!btn) return;
        box.dataset.wired = '1';
        btn.addEventListener('click', () => {
          box.classList.remove('locked');
          btn.setAttribute('aria-expanded', 'true');
          // ปลดล็อกส่วนเบลออื่น ๆ ในข้อเดียวกันด้วย (เช่น io-note ใต้ตารางที่แอบเฉลย)
          // ไล่ sibling ถัดไปจนกว่าจะเจอเส้นคั่น (hr) หรือหัวข้อถัดไป (h2)
          let el = box.nextElementSibling;
          while (el && el.tagName !== 'HR' && el.tagName !== 'H2') {
            if (el.classList.contains('spoiler')) el.classList.remove('locked');
            el = el.nextElementSibling;
          }
        });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wire);
    } else {
      wire();
    }
  })();
</script>

<script>
  // เกมปั๊มแสตมป์ (ข้อ B): ปั๊มให้ครบ 1 ภาพ (3 วงกลม, 1 สามเหลี่ยม, 2 สี่เหลี่ยม, 4 เส้น)
  (function () {
    const SHAPES: { key: string; name: string; need: number; unit: string }[] = [
      { key: 'circle', name: 'วงกลม', need: 3, unit: 'รูป' },
      { key: 'triangle', name: 'สามเหลี่ยม', need: 1, unit: 'รูป' },
      { key: 'square', name: 'สี่เหลี่ยม', need: 2, unit: 'รูป' },
      { key: 'line', name: 'เส้น', need: 4, unit: 'เส้น' },
    ];
    function initOne(fig: HTMLElement): void {
      if (fig.dataset.wired === '1') return;
      // เช็คว่ามีครบก่อน แล้วค่อยประกาศแบบ non-null (เลี่ยง null-narrowing ข้าม closure render)
      if (!fig.querySelector('.sg-rows') || !fig.querySelector('.sg-status')) return;
      const rowsEl = fig.querySelector<HTMLElement>('.sg-rows')!;
      const statusEl = fig.querySelector<HTMLElement>('.sg-status')!;
      fig.dataset.wired = '1';
      const counts: Record<string, number> = {};
      const trackEls: Record<string, HTMLElement> = {};
      const countEls: Record<string, HTMLElement> = {};
      SHAPES.forEach((sh) => {
        counts[sh.key] = 0;
        const row = document.createElement('div');
        row.className = 'sg-row';
        const label = document.createElement('div');
        label.className = 'sg-label';
        const swatch = document.createElement('span');
        swatch.className = 'pip pip-' + sh.key + ' is-filled';
        const nameEl = document.createElement('span');
        nameEl.textContent = sh.name + ' ' + String(sh.need) + ' ' + sh.unit;
        label.appendChild(swatch);
        label.appendChild(nameEl);
        const track = document.createElement('div');
        track.className = 'sg-track';
        const cnt = document.createElement('span');
        cnt.className = 'sg-count';
        row.appendChild(label);
        row.appendChild(track);
        row.appendChild(cnt);
        rowsEl.appendChild(row);
        trackEls[sh.key] = track;
        countEls[sh.key] = cnt;
      });
      function render(): void {
        let allExact = true;
        const overs: string[] = [];
        const shorts: string[] = [];
        SHAPES.forEach((sh) => {
          const c = counts[sh.key];
          const track = trackEls[sh.key];
          while (track.firstChild) track.removeChild(track.firstChild);
          const total = Math.max(sh.need, c);
          for (let i = 1; i <= total; i++) {
            const pip = document.createElement('span');
            let state = 'is-empty';
            if (i <= c && i <= sh.need) state = 'is-filled';
            else if (i <= c) state = 'is-extra';
            pip.className = 'pip pip-' + sh.key + ' ' + state;
            track.appendChild(pip);
          }
          countEls[sh.key].textContent = 'มี ' + String(c) + ' / ต้องการ ' + String(sh.need) + ' ' + sh.unit;
          if (c !== sh.need) allExact = false;
          if (c > sh.need) overs.push(sh.name + 'เกิน ' + String(c - sh.need) + ' ' + sh.unit);
          if (c < sh.need) shorts.push(sh.name + 'ขาด ' + String(sh.need - c) + ' ' + sh.unit);
        });
        statusEl.classList.remove('sg-ok', 'sg-over', 'sg-short');
        if (allExact) {
          statusEl.textContent = 'ครบเป๊ะทุกอย่าง! ภาพนี้ครูรับ นับเป็น 1 ภาพ';
          statusEl.classList.add('sg-ok');
        } else if (overs.length > 0) {
          statusEl.textContent = 'ปั๊มเกิน ครูไม่รับ เพราะ 1 ภาพต้องเป๊ะ ห้ามเกิน (' + overs.concat(shorts).join(', ') + ')';
          statusEl.classList.add('sg-over');
        } else {
          statusEl.textContent = 'ยังไม่ครบ ครูยังไม่รับ ปั๊มต่ออีก (' + shorts.join(', ') + ')';
          statusEl.classList.add('sg-short');
        }
      }
      fig.querySelectorAll<HTMLButtonElement>('[data-stamp]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const k = btn.dataset.stamp;
          if (k && k in counts) {
            counts[k] += 1;
            render();
          }
        });
      });
      const resetBtn = fig.querySelector<HTMLButtonElement>('[data-reset]');
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          SHAPES.forEach((sh) => {
            counts[sh.key] = 0;
          });
          render();
        });
      }
      render();
    }
    function initAll(): void {
      document.querySelectorAll<HTMLElement>('[data-stamp-game]').forEach(initOne);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }
  })();
</script>
