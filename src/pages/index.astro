---
import { ClientRouter } from 'astro:transitions';
import StarfieldBackground from '../components/StarfieldBackground.astro';
import SelfXssWarning from '../components/SelfXssWarning.astro';
import SecretConsole from '../components/SecretConsole.astro';
import { socialLinks } from '../data/socialLinks.js';
import '../styles/profile.css';

// Single source of truth for the hover-scramble word cycles -- rendered into
// data-words (consumed by the scramble script below) and into the aria-labels,
// so the accessible name can never drift out of sync with the animation again.
const handleAliases = ['Chi', 'Chimeng', 'ChimengSoso', 'Chigurumeng', 'Meng', 'CodeMeng'];
const roleTitles = [
  'Catalytic Compounder',
  'Software Engineer',
  'Functional Programmer',
  'Full Stack Developer',
  'Legendary Olympiad TA',
  'Value Investor',
  'CMU Gold Medalist',
  'Computer Olympiad Alumnus',
  'TOI12 Bear Medalist',
  'Trader in the Zone',
  'Financial Confidant',
  'Property Matchmaker',
  'Quiet Investor',
  'Selective Mentor',
  'Perpetual Student',
];
const otherRoles = roleTitles.slice(1);
const handleAriaLabel = `Also known as ${handleAliases.join(', ')}`;
const roleAriaLabel = `Also professionally known as ${otherRoles.slice(0, -1).join(', ')}, and ${otherRoles[otherRoles.length - 1]}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Worakun Ata',
  alternateName: 'ChimengSoso',
  jobTitle: 'Catalytic Compounder',
  image: 'https://chimengsoso.github.io/img.jpg',
  url: 'https://chimengsoso.github.io/',
  sameAs: socialLinks.map((s) => s.url),
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Worakun Ata (ChimengSoso) — Catalytic Compounder</title>
  <meta name="description" content="โปรไฟล์ Worakun Ata (ChimengSoso) — Catalytic Compounder ลิงก์ช่องทางโซเชียลและบทความความรู้ทั้งหมด">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <meta property="og:type" content="profile">
  <meta property="og:site_name" content="ChimengSoso">
  <meta property="og:locale" content="th_TH">
  <meta property="og:title" content="Worakun Ata (ChimengSoso)">
  <meta property="og:description" content="Catalytic Compounder — ลิงก์ช่องทางโซเชียลและบทความความรู้ทั้งหมด">
  <meta property="og:url" content="https://chimengsoso.github.io/">
  <meta property="og:image" content="https://chimengsoso.github.io/img.jpg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Worakun Ata (ChimengSoso)">
  <meta name="twitter:description" content="Catalytic Compounder — ลิงก์ช่องทางโซเชียลและบทความความรู้ทั้งหมด">
  <meta name="twitter:image" content="https://chimengsoso.github.io/img.jpg">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Same font stylesheet URL as Layout.astro on purpose: ClientRouter blocks the
       page swap on any stylesheet the next page adds, so sharing one (cached) URL
       makes / <-> /knowledge/ navigation skip the font-CSS fetch entirely. Font
       *files* still load per-page only for the families actually used. -->
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=JetBrains+Mono:wght@400;500;700&family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet">
  <ClientRouter />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body data-bg="interactive">
  <StarfieldBackground />
  <SelfXssWarning />
  <SecretConsole />
  <div class="container">
    <div class="orb orb-1" aria-hidden="true"></div>
    <div class="orb orb-2" aria-hidden="true"></div>
    <div class="orb orb-3" aria-hidden="true"></div>
    <div class="profile">
      <div class="round">
        <div class="dp">
          <img src="/img.jpg" alt="Worakun Ata" width="320" height="320" fetchpriority="high">
        </div>
      </div>

      <div class="details">
        <h1 class="name">Worakun Ata</h1>
        <div class="id" tabindex="0" aria-label={handleAriaLabel} data-scramble-words={JSON.stringify(handleAliases)} data-scramble-prefix="@">@{handleAliases[0]}</div>
        <div class="role" tabindex="0" aria-label={roleAriaLabel} data-scramble-words={JSON.stringify(roleTitles)}>{roleTitles[0]}</div>
      </div>

      <div class="social-icons">
        {socialLinks.map((s) => (
          <a class={`social-icon ${s.id}`} href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d={s.iconPath} /></svg>
          </a>
        ))}
      </div>

      <p class="reveal-hint" aria-hidden="true">กดตรงนี้สิ มีของดีซ่อนอยู่ 👇</p>

      <a class="featured-link" href="knowledge/" data-astro-prefetch="viewport">
        <div class="featured-link-icon">
          <svg viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783"/></svg>
        </div>
        <div class="featured-link-text">
          <span class="featured-link-title">หมวดความรู้</span>
          <span class="featured-link-sub">บทความและความรู้ต่าง ๆ</span>
        </div>
        <svg class="featured-link-arrow" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708"/></svg>
      </a>
    </div>
  </div>
  <script>
    function initTilt(card) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // Set once on enter rather than every mousemove -- .profile already carries this
      // as its resting transition in profile.css, so this only needs to reassert the
      // fast tilt-follow easing after mouseleave swaps in the slower snap-back one.
      card.addEventListener('mouseenter', function () {
        card.style.transition = 'transform 0.12s ease, box-shadow 0.2s ease';
      });
      card.addEventListener('mousemove', function (e) {
        var r = card.getBoundingClientRect();
        var dx = (e.clientX - (r.left + r.width / 2)) / (r.width / 2);
        var dy = (e.clientY - (r.top + r.height / 2)) / (r.height / 2);
        card.style.transform = 'perspective(700px) rotateY(' + (dx * 7) + 'deg) rotateX(' + (-dy * 7) + 'deg)';
        card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
        card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100).toFixed(1) + '%');
      });
      card.addEventListener('mouseleave', function () {
        card.style.transition = 'transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.2s ease';
        card.style.transform = '';
      });
    }

    function initReveal(card) {
      var link = card.querySelector('.featured-link');
      if (!link) return;
      card.addEventListener('click', function (e) {
        // Click reveals on every input type now (mouse hover only shows the teaser
        // hint via CSS -- see .reveal-hint in profile.css), so the first click
        // anywhere on the card (that isn't the link or a social icon) expands it.
        var tappedLink = link.contains(e.target);
        var tappedSocialIcon = e.target.closest && e.target.closest('.social-icons');
        if (!card.classList.contains('revealed') && !tappedLink && !tappedSocialIcon) {
          e.preventDefault();
          card.classList.add('revealed');
        }
      });
    }

    function initScrambleCycle(el, words, prefix) {
      prefix = prefix || '';
      var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var CHARS = '!<>-_\\/[]{}=+*^?#01';

      function randomChar() {
        return CHARS[(Math.random() * CHARS.length) | 0];
      }

      var queue = [];
      var frame = 0;
      var frameRequest = null;
      var resolveFn = null;

      function currentDisplayed() {
        return el.textContent.slice(prefix.length);
      }

      function update() {
        var output = '';
        var complete = 0;
        for (var i = 0; i < queue.length; i++) {
          var q = queue[i];
          if (frame >= q.end) {
            complete++;
            output += q.to;
          } else if (frame >= q.start) {
            if (!q.char || Math.random() < 0.28) q.char = randomChar();
            output += q.char;
          } else {
            output += q.from;
          }
        }
        el.textContent = prefix + output;
        if (complete === queue.length) {
          if (resolveFn) resolveFn();
        } else {
          frame++;
          frameRequest = requestAnimationFrame(update);
        }
      }

      function scrambleTo(newText) {
        var oldText = currentDisplayed();
        var length = Math.max(oldText.length, newText.length);
        queue = [];
        for (var i = 0; i < length; i++) {
          var start = Math.floor(Math.random() * 20);
          queue.push({
            from: oldText[i] || '',
            to: newText[i] || '',
            start: start,
            end: start + Math.floor(Math.random() * 20) + 10,
            char: null
          });
        }
        cancelAnimationFrame(frameRequest);
        frame = 0;
        return new Promise(function (resolve) {
          resolveFn = resolve;
          update();
        });
      }

      var cycling = false;
      var randomOrder = false;
      var cycleIndex = 0;
      var cycleTimer = null;

      function nextIndex() {
        if (!randomOrder) return (cycleIndex + 1) % words.length;
        // random word, but never the one currently showing
        var next = (Math.random() * words.length) | 0;
        return next === cycleIndex ? (next + 1) % words.length : next;
      }

      function step() {
        cycleIndex = nextIndex();
        scrambleTo(words[cycleIndex]).then(function () {
          if (cycling) cycleTimer = setTimeout(step, 900);
        });
      }

      function startCycle(random) {
        if (cycling || reduceMotion) return;
        cycling = true;
        randomOrder = !!random;
        cycleIndex = 0;
        step();
      }

      function stopCycle() {
        if (!cycling) return;
        cycling = false;
        clearTimeout(cycleTimer);
        cancelAnimationFrame(frameRequest);
        scrambleTo(words[0]);
      }

      // Wrapped so the event object never leaks into startCycle's `random` param.
      el.addEventListener('mouseenter', function () { startCycle(false); });
      el.addEventListener('mouseleave', stopCycle);
      el.addEventListener('focus', function () { startCycle(false); });
      el.addEventListener('blur', stopCycle);

      // Handles for triggering this element's scramble from elsewhere
      // (the name-hover easter egg below drives both elements at once).
      return { startCycle: startCycle, stopCycle: stopCycle };
    }

    // index.astro is not transition:persist'ed, so ClientRouter swaps in a fresh
    // .profile every time the user navigates back to `/` -- astro:page-load (fires on
    // the first load too) re-runs this for whichever .profile is currently in the DOM,
    // instead of a plain top-level script binding once to the very first one ever seen.
    document.addEventListener('astro:page-load', function () {
      var card = document.querySelector('.profile');
      if (card) {
        initTilt(card);
        initReveal(card);
      }
      // Word lists live in the frontmatter (rendered into data-scramble-words),
      // so markup, aria-labels, and this animation all share one definition.
      var scramblers = [];
      document.querySelectorAll('[data-scramble-words]').forEach(function (el) {
        var words;
        try {
          words = JSON.parse(el.getAttribute('data-scramble-words'));
        } catch (err) {
          return;
        }
        if (Array.isArray(words) && words.length) {
          scramblers.push(initScrambleCycle(el, words, el.getAttribute('data-scramble-prefix') || ''));
        }
      });

      // Hovering the name itself scrambles BOTH the handle and the role at
      // once, in random word order (hovering each element directly still
      // cycles its own list sequentially).
      var nameEl = document.querySelector('.details .name');
      if (nameEl) {
        nameEl.addEventListener('mouseenter', function () {
          scramblers.forEach(function (s) { s.startCycle(true); });
        });
        nameEl.addEventListener('mouseleave', function () {
          scramblers.forEach(function (s) { s.stopCycle(); });
        });
      }
    });

    // Registered once ever (document itself survives navigations, unlike .profile) --
    // looks up .profile fresh on every click rather than closing over a stale reference.
    document.addEventListener('click', function (e) {
      var card = document.querySelector('.profile');
      if (card && !card.contains(e.target)) card.classList.remove('revealed');
    });
  </script>
</body>
</html>
