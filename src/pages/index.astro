  <script>
    function initTilt(card) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // Set once on enter rather than every mousemove -- .profile already carries this
      // as its resting transition in profile.css, so this only needs to reassert the
      // fast tilt-follow easing after mouseleave swaps in the slower snap-back one.
      card.addEventListener('mouseenter', function () {
        card.style.transition = 'transform 0.12s ease, box-shadow 0.2s ease';
      });
      card.addEventListener('mousemove', function (e) {
        var r = card.getBoundingClientRect();
        var dx = (e.clientX - (r.left + r.width / 2)) / (r.width / 2);
        var dy = (e.clientY - (r.top + r.height / 2)) / (r.height / 2);
        card.style.transform = 'perspective(700px) rotateY(' + (dx * 7) + 'deg) rotateX(' + (-dy * 7) + 'deg)';
        card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
        card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100).toFixed(1) + '%');
      });
      card.addEventListener('mouseleave', function () {
        card.style.transition = 'transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.2s ease';
        card.style.transform = '';
      });
    }

    function initReveal(card) {
      var link = card.querySelector('.featured-link');
      if (!link) return;
      card.addEventListener('click', function (e) {
        // Click reveals on every input type now (mouse hover only shows the teaser
        // hint via CSS -- see .reveal-hint in profile.css), so the first click
        // anywhere on the card (that isn't the link or a social icon) expands it.
        var tappedLink = link.contains(e.target);
        var tappedSocialIcon = e.target.closest && e.target.closest('.social-icons');
        if (!card.classList.contains('revealed') && !tappedLink && !tappedSocialIcon) {
          e.preventDefault();
          card.classList.add('revealed');
        }
      });
    }

    function initScrambleCycle(el, words, prefix) {
      prefix = prefix || '';
      var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var CHARS = '!<>-_\\/[]{}=+*^?#01';

      function randomChar() {
        return CHARS[(Math.random() * CHARS.length) | 0];
      }

      var queue = [];
      var frame = 0;
      var frameRequest = null;
      var resolveFn = null;

      function currentDisplayed() {
        return el.textContent.slice(prefix.length);
      }

      function update() {
        var output = '';
        var complete = 0;
        for (var i = 0; i < queue.length; i++) {
          var q = queue[i];
          if (frame >= q.end) {
            complete++;
            output += q.to;
          } else if (frame >= q.start) {
            if (!q.char || Math.random() < 0.28) q.char = randomChar();
            output += q.char;
          } else {
            output += q.from;
          }
        }
        el.textContent = prefix + output;
        if (complete === queue.length) {
          if (resolveFn) resolveFn();
        } else {
          frame++;
          frameRequest = requestAnimationFrame(update);
        }
      }

      function scrambleTo(newText) {
        var oldText = currentDisplayed();
        var length = Math.max(oldText.length, newText.length);
        queue = [];
        for (var i = 0; i < length; i++) {
          var start = Math.floor(Math.random() * 20);
          queue.push({
            from: oldText[i] || '',
            to: newText[i] || '',
            start: start,
            end: start + Math.floor(Math.random() * 20) + 10,
            char: null
          });
        }
        cancelAnimationFrame(frameRequest);
        frame = 0;
        return new Promise(function (resolve) {
          resolveFn = resolve;
          update();
        });
      }

      var cycling = false;
      var cycleIndex = 0;
      var cycleTimer = null;

      function step() {
        cycleIndex = (cycleIndex + 1) % words.length;
        scrambleTo(words[cycleIndex]).then(function () {
          if (cycling) cycleTimer = setTimeout(step, 900);
        });
      }

      function startCycle() {
        if (cycling || reduceMotion) return;
        cycling = true;
        cycleIndex = 0;
        step();
      }

      function stopCycle() {
        if (!cycling) return;
        cycling = false;
        clearTimeout(cycleTimer);
        cancelAnimationFrame(frameRequest);
        scrambleTo(words[0]);
      }

      el.addEventListener('mouseenter', startCycle);
      el.addEventListener('mouseleave', stopCycle);
      el.addEventListener('focus', startCycle);
      el.addEventListener('blur', stopCycle);
    }

    // index.astro is not transition:persist'ed, so ClientRouter swaps in a fresh
    // .profile every time the user navigates back to `/` -- astro:page-load (fires on
    // the first load too) re-runs this for whichever .profile is currently in the DOM,
    // instead of a plain top-level script binding once to the very first one ever seen.
    document.addEventListener('astro:page-load', function () {
      var card = document.querySelector('.profile');
      if (card) {
        initTilt(card);
        initReveal(card);
      }
      var handle = document.getElementById('handle-scramble');
      if (handle) {
        initScrambleCycle(handle, ['Chi', 'Chimeng', 'ChimengSoso', 'Chigurumeng', 'Meng', 'CodeMeng'], '@');
      }
      var role = document.getElementById('role-scramble');
      if (role) {
        initScrambleCycle(role, [
          'Catalytic Compounder',
          'Software Engineer',
          'Functional Programmer',
          'Full Stack Developer',
          'Legendary Olympiad TA',
          'Value Investor',
          'CMU Gold Medalist',
          'Computer Olympiad Alumnus',
          'TOI12 Bear Medalist',
          'Trader in the Zone',
          'Financial Confidant',
          'Property Matchmaker',
          'Quiet Investor',
          'Selective Mentor',
          'Perpetual Student'
        ]);
      }
    });

    // Registered once ever (document itself survives navigations, unlike .profile) --
    // looks up .profile fresh on every click rather than closing over a stale reference.
    document.addEventListener('click', function (e) {
      var card = document.querySelector('.profile');
      if (card && !card.contains(e.target)) card.classList.remove('revealed');
    });
  </script>
</body>
</html>
