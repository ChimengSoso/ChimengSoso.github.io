---
import Layout from '../layouts/Layout.astro';
// GitHub Pages serves dist/404.html (which Astro emits from this file) for any
// unknown URL, so visitors land on a branded page instead of GitHub's default.
---
<Layout title="ไม่พบหน้านี้ | ChimengSoso" description="หน้าที่ตามหาไม่มีอยู่ หรืออาจถูกย้ายไปแล้ว" narrow toc={false} noindex>
  <p class="code-404" aria-hidden="true">404</p>
  <h1>ไม่พบหน้าที่ตามหา</h1>
  <p>
    ลิงก์ที่เปิดมาอาจพิมพ์ผิด หน้าอาจถูกย้าย หรือไม่เคยมีอยู่ตั้งแต่แรก
    ถ้ามาจากลิงก์ในเว็บนี้เองแล้วเจอหน้านี้ ทักมาบอกได้ตามช่องทางในหน้าแรกเลยครับ
  </p>
  <nav class="lost-nav">
    <a href="/">
      <svg class="lost-nav-arrow" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"/></svg>
      กลับหน้าแรก
    </a>
    <a href="/knowledge/">ดูบทความทั้งหมดในหมวดความรู้</a>
  </nav>
</Layout>

<style>
  .code-404{
    font-family:"Fira Code","Fira Mono",monospace;
    font-size:3.5rem;
    font-weight:700;
    color:var(--blue-soft);
    line-height:1;
    margin:0 0 0.75rem;
  }
  .lost-nav{
    display:flex;
    flex-wrap:wrap;
    gap:0.75rem;
    margin-top:1.75rem;
  }
  .lost-nav a{
    display:inline-flex;
    align-items:center;
    gap:4px;
    padding:0.5rem 1rem;
    border:1px solid var(--blue-soft);
    border-radius:10px;
    text-decoration:none;
    font-size:0.9rem;
    font-weight:600;
    color:var(--blue-shadow);
    transition:background .15s, border-color .15s;
  }
  .lost-nav a:hover{
    background:var(--blue-tint);
    border-color:var(--blue);
  }
  .lost-nav-arrow{
    width:16px;
    height:16px;
    flex-shrink:0;
    transition:transform .15s ease;
  }
  .lost-nav a:hover .lost-nav-arrow{transform:translateX(-3px);}
  @media (prefers-reduced-motion: reduce){
    .lost-nav a:hover .lost-nav-arrow{transform:none;}
  }
</style>
