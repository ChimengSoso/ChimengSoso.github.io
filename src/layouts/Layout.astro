---
import { ClientRouter } from 'astro:transitions';
import ShareButtons from '../components/ShareButtons.astro';
import DonateButton from '../components/DonateButton.astro';
import StarfieldBackground from '../components/StarfieldBackground.astro';
import ScrollScrubber from '../components/ScrollScrubber.astro';
import SelfXssWarning from '../components/SelfXssWarning.astro';
import { footerSocialLinks } from '../data/socialLinks';
import '../styles/fonts.css';

interface ArticleLink {
  href: string;
  title: string;
}
interface Props {
  title: string;
  description?: string;
  narrow?: boolean;
  toc?: boolean;
  prev?: ArticleLink | null;
  next?: ArticleLink | null;
  updated?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  dateISO?: string;
  updatedISO?: string;
  headline?: string;
}
const {
  title,
  description = "หมวดความรู้ของ ChimengSoso",
  narrow = false,
  toc = true,
  prev = null,
  next = null,
  image,
  type = "website",
  noindex = false,
  dateISO,
  updatedISO,
  headline,
} = Astro.props;

const year = new Date().getFullYear();
const canonicalUrl = Astro.url.href;

// Auto-generated branded share card per knowledge page (see src/pages/og/[slug].png.ts).
// An explicit `image` prop still wins; anything outside /knowledge falls back to the profile photo.
const segments = Astro.url.pathname.split("/").filter(Boolean);
const derivedOgImage =
  segments[0] === "knowledge" ? `/og/${segments[1] ?? "knowledge"}.png` : null;
const ogImageUrl = new URL(image ?? derivedOgImage ?? "/img.jpg", Astro.site ?? Astro.url).href;

const isArticle = type === "article" && !!dateISO;
const blogPostingJsonLd = isArticle ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: headline ?? title,
  datePublished: dateISO,
  dateModified: updatedISO ?? dateISO,
  inLanguage: 'th',
  image: ogImageUrl,
  author: {
    '@type': 'Person',
    name: 'Worakun Ata',
    url: 'https://chimengsoso.github.io/',
  },
} : null;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#4d72a9" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{title}</title>
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
  <link rel="icon" type="image/jpeg" href="/img.jpg" />
  <link rel="alternate" type="application/rss+xml" title="ChimengSoso — ความรู้" href="/rss.xml" />

  <meta property="fb:app_id" content="999748286011681" />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="ChimengSoso" />
  <meta property="og:locale" content="th_TH" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  {isArticle && <meta property="article:published_time" content={dateISO} />}
  {isArticle && <meta property="article:modified_time" content={updatedISO ?? dateISO} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  {blogPostingJsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />}
  <ClientRouter />
  <script is:inline type="module" src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "1b7bedfae8d54d1ab0a92a97650df507", "spa": true}'></script>

  <style is:global>
    :root{
      /* Single knob for overall scale on wide screens, as a multiple of the
         16px mobile base — e.g. 1.5 means desktop tops out ~150% of mobile
         size. Everything else below derives from this automatically. */
      --scale: 1.5;
      --fs-min: 16;
      --fs-max: calc(var(--fs-min) * var(--scale));
      --vw-min: 400;
      --vw-max: 1600;
      --fs-slope: calc((var(--fs-max) - var(--fs-min)) / (var(--vw-max) - var(--vw-min)) * 100);
      --fs-intercept: calc(var(--fs-min) - (var(--vw-min) * (var(--fs-max) - var(--fs-min)) / (var(--vw-max) - var(--vw-min))));

      --blue: #4d72a9;
      --blue-deep: #294266;
      --blue-shadow: #163f78;
      --blue-soft: #bcd3f8;
      --blue-tint: #ecf3fc;
      --ink: #131e30;
      --muted: #5a6a85;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{
      /* fluid base size: scales the whole rem-based layout with viewport width,
         so large screens don't need manual zoom to look proportionate.
         Bounds and slope computed from --scale above. */
      font-size:clamp(
        calc(var(--fs-min) * 1px),
        calc(var(--fs-intercept) * 1px + var(--fs-slope) * 1vw),
        calc(var(--fs-max) * 1px)
      );
      scroll-behavior:smooth;
    }
    @media (prefers-reduced-motion: reduce){
      html{scroll-behavior:auto;}
    }
    html,body{
      font-family:"Sarabun", system-ui, sans-serif;
      background:var(--blue);
      color:var(--ink);
    }
    body{
      min-height:100vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:2.5rem 1rem 3rem;
    }
    a{color:inherit;}
    a:visited{color:inherit;}
    code, pre, kbd{font-family:"Fira Code","Fira Mono",monospace;font-variant-ligatures:none;}
    .page{width:100%;display:flex;justify-content:center;}
    .layout{
      width:100%;
      max-width:100rem;
      display:flex;
      gap:3.5rem;
      align-items:flex-start;
      justify-content:center;
    }
    .panel{
      width:100%;
      min-width:0;
      max-width:50rem;
      background:#ffffff;
      border-radius:22px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.45);
      padding:2.75rem 3rem 3.25rem;
      line-height:1.8;
      counter-reset:figure step;
      animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
    }
    .panel.panel-narrow{
      max-width:34rem;
    }
    @keyframes fadeUp{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    .toc{
      display:none;
      width:15rem;
      flex-shrink:0;
      position:sticky;
      top:2.5rem;
    }
    @media (min-width:1180px){
      .toc.has-headings{display:block;}
    }
    .toc-label{
      font-size:0.66rem;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.6px;
      color:rgba(255,255,255,0.6);
      margin-bottom:0.75rem;
    }
    .toc nav{display:flex;flex-direction:column;gap:0.125rem;}
    .toc nav a{
      display:block;
      font-size:0.81rem;
      line-height:1.5;
      color:rgba(255,255,255,0.8);
      text-decoration:none;
      padding:0.3rem 0 0.3rem 0.75rem;
      border-left:2px solid rgba(255,255,255,0.25);
      transition:color .15s, border-color .15s;
    }
    .toc nav a:hover{color:#fff;border-left-color:rgba(255,255,255,0.55);}
    .toc nav a.active{color:#fff;border-left-color:#fff;font-weight:600;}
    .breadcrumb{
      font-size:0.69rem;
      color:var(--muted);
      margin-bottom:1.25rem;
      letter-spacing:.3px;
      text-transform:uppercase;
    }
    .breadcrumb a{
      color:var(--muted);
      text-decoration:none;
      border-bottom:1px solid transparent;
      transition:color .15s, border-color .15s;
    }
    .breadcrumb a:hover{color:var(--blue-deep);border-bottom-color:var(--blue-soft);}
    /* Slash-command tokens in an article title (e.g. /grill-me) render as inline-code chips
       inside the breadcrumb so they don't read as the " / " breadcrumb separator. Opt out of
       the breadcrumb's uppercase + letter-spacing so the command reads literally. */
    .breadcrumb code{
      text-transform:none;
      letter-spacing:0;
      font-size:0.92em;
      padding:0.05rem 0.3rem;
      border-radius:5px;
    }
    /* Breadcrumb + date share the top row via CSS Grid (not flex): far more predictable
       than juggling flex-shrink ratios (which kept wrapping the breadcrumb instead of the
       date — see the byline saga). Mobile: single column, they stack. */
    .article-head{
      display:grid;
      grid-template-columns:1fr;
      align-items:baseline;
      gap:0.15rem 1.5rem;
      margin-bottom:1.25rem;
    }
    .article-head .breadcrumb{margin-bottom:0;}
    /* >=480px: two columns.
       - breadcrumb column minmax(0, max-content): normally its one-line width (so "จริง"
         stays on line 1), but it can shrink/wrap as a last resort so it never pushes the
         date off the right edge at extreme zoom.
       - date column 1fr: takes ALL the remaining width, so text-align:right in ArticleByline
         pins the date to the right edge. When 1fr gets narrower than the date's one-line
         width, the date wraps to two lines inside its column (each date part is nowrap, so
         only the " · " separator breaks). */
    @media (min-width:480px){
      .article-head{grid-template-columns:minmax(0, max-content) 1fr;}
    }
    .tag{
      display:inline-block;
      font-size:0.69rem;
      background:var(--blue-deep);
      color:var(--blue-tint);
      padding:0.25rem 0.75rem;
      border-radius:1.25rem;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.875rem;
    }
    h1{font-size:1.75rem;color:var(--ink);margin-bottom:0.5rem;letter-spacing:-.2px;}
    /* Slash-command tokens in the title render as code chips too (matches the breadcrumb and
       the OG card). Slightly smaller than the heading text with tighter padding so the chip
       doesn't tower over the surrounding Thai glyphs. */
    h1 code{font-size:0.82em;padding:0.05em 0.35rem;border-radius:8px;}
    .subtitle{color:var(--muted);font-size:0.91rem;margin-bottom:2.375rem;}
    h2{
      font-size:1rem;
      color:var(--blue-deep);
      margin-top:2.375rem;
      margin-bottom:0.875rem;
      border-left:3px solid var(--blue);
      padding-left:0.75rem;
      text-transform:uppercase;
      letter-spacing:.5px;
      /* Keep TOC anchor jumps clear of the top edge; must match TOC_OFFSET in the script. */
      scroll-margin-top:96px;
    }
    h2.step{counter-increment:step;}
    h2.step::before{content:"[" counter(step) "] ";}
    p{font-size:0.97rem;color:#2b2a28;margin:0.75rem 0;}
    ul{padding-left:1.375rem;font-size:0.97rem;color:#2b2a28;}
    li{margin:0.5rem 0;}
    strong{color:var(--blue-shadow);font-weight:700;}
    p a, li a, .callout a{
      color:var(--blue-shadow);
      text-decoration:underline;
      text-decoration-color:var(--blue-soft);
      text-underline-offset:2px;
    }
    p a:hover, li a:hover, .callout a:hover{color:var(--blue-deep);}
    .references{
      list-style:none;
      padding-left:0;
      counter-reset:ref;
    }
    .references li{
      counter-increment:ref;
      position:relative;
      padding-left:2rem;
    }
    .references li::before{
      content:"[" counter(ref) "]";
      position:absolute;
      left:0;
      color:var(--blue-shadow);
      font-weight:600;
    }
    /* section dividers: use sparingly, only where the topic genuinely
       shifts — not between every heading */
    .divider{
      border:none;
      border-top:1px dashed var(--blue-soft);
      margin:2.25rem 0;
    }
    .divider-solid{
      border:none;
      border-top:2px solid var(--blue-soft);
      margin:2.75rem 0;
    }
    .card{
      background:var(--blue-tint);
      border-radius:14px;
      padding:1.125rem 1.5rem;
      margin:1rem 0;
    }
    .card ul{padding-left:1.125rem;}
    figure.screenshot{
      margin:1.125rem 0;
    }
    figure.screenshot img{
      display:block;
      width:100%;
      height:auto;
      border-radius:10px;
    }
    figure.screenshot figcaption{
      margin-top:0.6rem;
      font-size:0.8rem;
      color:var(--muted);
      text-align:center;
    }
    figure.screenshot figcaption::before{
      counter-increment:figure;
      content:"Figure " counter(figure) ": ";
      font-weight:700;
      color:var(--ink);
    }
    .expander{
      border:1px solid var(--blue-soft);
      border-radius:14px;
      padding:1rem 1.25rem;
      margin:1rem 0;
      background:#fff;
    }
    .expander summary{
      cursor:pointer;
      font-weight:700;
      color:var(--blue-deep);
      list-style:none;
      display:flex;
      align-items:center;
      gap:0.6rem;
      user-select:none;
    }
    .expander summary::-webkit-details-marker{display:none;}
    .expander summary::before{
      content:"▸";
      color:var(--blue);
      display:inline-block;
      transition:transform .15s ease;
      flex-shrink:0;
    }
    .expander[open] summary::before{transform:rotate(90deg);}
    .expander .expander-body{
      margin-top:0.9rem;
      padding-top:0.9rem;
      border-top:1px dashed var(--blue-soft);
    }
    .expander .expander-body > :first-child{margin-top:0;}
    .expander .expander-body > :last-child{margin-bottom:0;}
    code{
      background:var(--blue-tint);
      color:var(--blue-shadow);
      padding:0.125rem 0.375rem;
      border-radius:6px;
      font-size:0.9em;
    }
    pre{
      background:#1c2536;
      color:#e7ecf6;
      border-radius:14px;
      padding:1.125rem 1.25rem;
      margin:1.125rem 0;
      overflow-x:auto;
      font-size:0.84rem;
      line-height:1.7;
    }
    pre code{background:none;color:inherit;padding:0;font-size:1em;}
    /* Shiki (astro:components Code) sets its own background/color inline via the theme;
       override those two so the box still matches the site's navy code style, while leaving
       each token's own inline color alone so syntax highlighting still shows through. */
    pre.astro-code{background-color:#1c2536 !important;color:#e7ecf6 !important;}
    .callout{
      border-radius:12px;
      padding:1rem 1.25rem;
      margin:1.125rem 0;
      border-left:3px solid;
    }
    .callout p{margin:0;font-size:0.875rem;}
    .callout-label{
      font-size:0.69rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.25rem;
    }
    .callout-tip{background:#eafaf0;border-color:#2f9e5c;}
    .callout-tip .callout-label{color:#1f7a45;}
    .callout-warn{background:#fdecec;border-color:#d64545;}
    .callout-warn .callout-label{color:#b23b3b;}
    .callout-note{background:var(--blue-tint);border-color:var(--blue);}
    .callout-note .callout-label{color:var(--blue-deep);}
    footer{
      margin-top:2.5rem;
      font-size:0.69rem;
      color:#9aa7bd;
      text-align:center;
    }
    .wiki-tip{position:relative;display:inline-block;}
    .wiki-tip-card{
      position:absolute;
      bottom:calc(100% + 10px);
      left:50%;
      transform:translateX(-50%) translateY(4px);
      width:11rem;
      background:#ffffff;
      border-radius:12px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.4);
      padding:0.625rem;
      opacity:0;
      visibility:hidden;
      pointer-events:none;
      transition:opacity .15s ease, transform .15s ease;
      z-index:30;
    }
    .wiki-tip-card::after{
      content:"";
      position:absolute;
      top:100%;
      left:50%;
      transform:translateX(-50%);
      border:6px solid transparent;
      border-top-color:#ffffff;
    }
    .wiki-tip-card img{
      width:100%;
      display:block;
      border-radius:8px;
      margin-bottom:0.5rem;
    }
    .wiki-tip-caption{
      display:block;
      font-size:0.66rem;
      line-height:1.45;
      color:var(--muted);
    }
    .wiki-tip:hover .wiki-tip-card,
    .wiki-tip:focus-within .wiki-tip-card{
      opacity:1;
      visibility:visible;
      transform:translateX(-50%) translateY(0);
      pointer-events:auto;
    }
    .article-nav{
      display:flex;
      gap:1rem;
      margin-top:2.75rem;
      padding-top:1.5rem;
      border-top:1px dashed var(--blue-soft);
    }
    .article-nav > a{
      flex:1 1 0;
      display:flex;
      flex-direction:column;
      gap:0.25rem;
      padding:0.875rem 1rem;
      border-radius:12px;
      text-decoration:none;
      color:var(--ink);
      transition:background .15s, border-color .15s;
      border:1px solid transparent;
    }
    .article-nav > a:hover{background:var(--blue-tint);border-color:var(--blue-soft);}
    .article-nav-next{text-align:right;margin-left:auto;}
    .article-nav-label{
      font-size:0.69rem;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.4px;
    }
    .article-nav-title{font-size:0.9rem;font-weight:600;color:var(--blue-shadow);}
    .site-footer{
      width:100%;
      max-width:34rem;
      margin-top:3rem;
      padding-top:1.75rem;
      border-top:1px solid rgba(255,255,255,0.15);
      text-align:center;
    }
    .site-footer-social{
      display:flex;
      justify-content:center;
      gap:1.2rem;
      margin-bottom:0.875rem;
    }
    .site-footer-social a{
      color:rgba(255,255,255,0.65);
      line-height:1;
      transition:color .15s, transform .15s;
      display:inline-block;
    }
    .site-footer-social svg{
      width:1.1rem;
      height:1.1rem;
      display:block;
    }
    .site-footer-social a:hover{color:#fff;transform:translateY(-1px);}
    .site-footer-copyright{
      font-size:0.72rem;
      color:rgba(255,255,255,0.55);
      letter-spacing:.2px;
    }
    .site-footer-copyright a{
      color:rgba(255,255,255,0.8);
      text-decoration:underline;
      text-decoration-color:rgba(255,255,255,0.35);
      text-underline-offset:2px;
    }
    .site-footer-copyright a:hover{color:#fff;}
  </style>
</head>
<body data-bg="plain">
  <StarfieldBackground />
  <SelfXssWarning />
  <div class="page">
    <div class="layout">
      <div class:list={["panel", { "panel-narrow": narrow }]}>
        <slot />
        {isArticle && <ShareButtons />}
        {(prev || next) && (
          <nav class="article-nav">
            {prev ? (
              <a class="article-nav-prev" href={`../${prev.href}`} data-astro-prefetch="viewport">
                <span class="article-nav-label">{"< "} บทความก่อนหน้า</span>
                <span class="article-nav-title">{prev.title}</span>
              </a>
            ) : <span />}
            {next ? (
              <a class="article-nav-next" href={`../${next.href}`} data-astro-prefetch="viewport">
                <span class="article-nav-label">บทความถัดไป {" >"}</span>
                <span class="article-nav-title">{next.title}</span>
              </a>
            ) : <span />}
          </nav>
        )}
      </div>
      {toc && (
        <aside class="toc" id="page-toc">
          <p class="toc-label">ในบทความนี้</p>
          <nav id="toc-nav"></nav>
        </aside>
      )}
    </div>
  </div>
  <footer class="site-footer">
    <div class="site-footer-social">
      {footerSocialLinks.map((s) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d={s.iconPath} /></svg>
        </a>
      ))}
    </div>
    <p class="site-footer-copyright">&copy; {year} <a href="/">ChimengSoso</a> — สร้างด้วย <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> · <a href="/privacy/">นโยบายความเป็นส่วนตัว</a></p>
  </footer>
  <DonateButton />
  <ScrollScrubber />
  <script>
    // Astro's ClientRouter re-inserts this <script> tag's markup on every navigation,
    // but the module itself only ever evaluates once (same module URL), so top-level
    // code here would only ever run for the very first page. astro:page-load fires on
    // every navigation (including the first), so build the TOC there instead.
    // Kept outside buildToc so each call can disconnect the previous navigation's
    // observer before creating a new one -- otherwise every article visit leaks an
    // observer still watching that page's now-detached headings, and now that
    // ClientRouter keeps the document alive across navigations, those leaks
    // accumulate for the whole browsing session instead of being cleared by a reload.
    let cleanupToc: (() => void) | null = null;
    // Distance from the viewport top where a heading is considered "current". Must match the
    // headings' scroll-margin-top so a clicked heading lands exactly on this line.
    const TOC_OFFSET = 96;

    function buildToc() {
      cleanupToc?.();
      cleanupToc = null;

      const headings = Array.from(document.querySelectorAll('.panel h2'));
      const toc = document.getElementById('page-toc');
      const nav = document.getElementById('toc-nav');
      if (!toc || !nav) return;
      nav.innerHTML = '';
      toc.classList.remove('has-headings');

      if (headings.length < 2) return;
      const used = new Set();
      // The TOC label is the heading's text minus any element marked data-toc-ignore
      // (e.g. the article-count badge on the /knowledge listing's group headings).
      const tocLabel = (h: Element) => {
        const clone = h.cloneNode(true) as Element;
        clone.querySelectorAll('[data-toc-ignore]').forEach((n) => n.remove());
        return (clone.textContent ?? '').trim();
      };
      headings.forEach((h, i) => {
        const label = tocLabel(h);
        if (!h.id) {
          let slug = label.toLowerCase()
            .replace(/[^a-z0-9ก-๙\s-]/g, '')
            .replace(/\s+/g, '-') || `section-${i}`;
          while (used.has(slug)) slug = `${slug}-${i}`;
          used.add(slug);
          h.id = slug;
        }
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = label;
        nav.appendChild(a);
      });
      toc.classList.add('has-headings');

      const links = Array.from(nav.querySelectorAll('a'));
      const setActive = (id: string) => {
        links.forEach((l) => l.classList.toggle('active', l.getAttribute('href') === `#${id}`));
      };
      // Highlight the last heading whose top has scrolled at/above the offset line. This
      // (unlike a narrow detection band) can highlight the very first heading, works when
      // the content is too short to scroll a lower heading into a band, and doesn't skip
      // headings. At the bottom of the page the last heading always wins so tail sections
      // that can't reach the line still activate.
      const syncActive = () => {
        const scrollBottom = window.scrollY + window.innerHeight;
        const atBottom = scrollBottom >= document.documentElement.scrollHeight - 2;
        let current = headings[0];
        if (atBottom) {
          current = headings[headings.length - 1];
        } else {
          for (const h of headings) {
            if (h.getBoundingClientRect().top - TOC_OFFSET <= 1) current = h;
            else break;
          }
        }
        if (current?.id) setActive(current.id);
      };
      // Clicking a link highlights it right away — the smooth scroll settles a moment later
      // and syncActive confirms the same heading (its scroll-margin-top lands it on the line).
      links.forEach((l) => l.addEventListener('click', () => {
        const id = (l.getAttribute('href') ?? '').slice(1);
        if (id) setActive(id);
      }));
      window.addEventListener('scroll', syncActive, { passive: true });
      window.addEventListener('resize', syncActive, { passive: true });
      syncActive();
      cleanupToc = () => {
        window.removeEventListener('scroll', syncActive);
        window.removeEventListener('resize', syncActive);
      };
    }
    document.addEventListener('astro:page-load', buildToc);
  </script>
</body>
</html>
