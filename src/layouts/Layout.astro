---
import { ClientRouter } from 'astro:transitions';
import ShareButtons from '../components/ShareButtons.astro';
import DonateButton from '../components/DonateButton.astro';
import StarfieldBackground from '../components/StarfieldBackground.astro';
import SelfXssWarning from '../components/SelfXssWarning.astro';
import { footerSocialLinks } from '../data/socialLinks.js';

interface ArticleLink {
  href: string;
  title: string;
}
interface Props {
  title: string;
  description?: string;
  narrow?: boolean;
  prev?: ArticleLink | null;
  next?: ArticleLink | null;
  updated?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
}
const {
  title,
  description = "หมวดความรู้ของ ChimengSoso",
  narrow = false,
  prev = null,
  next = null,
  updated,
  image,
  type = "website",
  noindex = false,
} = Astro.props;
const year = new Date().getFullYear();
const canonicalUrl = Astro.url.href;

// Auto-generated branded share card per knowledge page (see src/pages/og/[slug].png.ts).
// An explicit `image` prop still wins; anything outside /knowledge falls back to the profile photo.
const segments = Astro.url.pathname.split("/").filter(Boolean);
const derivedOgImage =
  segments[0] === "knowledge" ? `/og/${segments[1] ?? "knowledge"}.png` : null;
const ogImageUrl = new URL(image ?? derivedOgImage ?? "/img.jpg", Astro.site ?? Astro.url).href;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <title>{title}</title>
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
  <link rel="icon" type="image/jpeg" href="/img.jpg" />

  <meta property="fb:app_id" content="999748286011681" />
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="ChimengSoso" />
  <meta property="og:locale" content="th_TH" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <ClientRouter />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Same font stylesheet URL as index.astro on purpose -- see the comment there. -->
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Fira+Code:wght@400;500&family=JetBrains+Mono:wght@400;500;700&family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root{
      /* Single knob for overall scale on wide screens, as a multiple of the
         16px mobile base — e.g. 1.5 means desktop tops out ~150% of mobile
         size. Everything else below derives from this automatically. */
      --scale: 1.5;
      --fs-min: 16;
      --fs-max: calc(var(--fs-min) * var(--scale));
      --vw-min: 400;
      --vw-max: 1600;
      --fs-slope: calc((var(--fs-max) - var(--fs-min)) / (var(--vw-max) - var(--vw-min)) * 100);
      --fs-intercept: calc(var(--fs-min) - (var(--vw-min) * (var(--fs-max) - var(--fs-min)) / (var(--vw-max) - var(--vw-min))));

      --blue: #4d72a9;
      --blue-deep: #294266;
      --blue-shadow: #163f78;
      --blue-soft: #bcd3f8;
      --blue-tint: #ecf3fc;
      --ink: #131e30;
      --muted: #5a6a85;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{
      /* fluid base size: scales the whole rem-based layout with viewport width,
         so large screens don't need manual zoom to look proportionate.
         Bounds and slope computed from --scale above. */
      font-size:clamp(
        calc(var(--fs-min) * 1px),
        calc(var(--fs-intercept) * 1px + var(--fs-slope) * 1vw),
        calc(var(--fs-max) * 1px)
      );
      scroll-behavior:smooth;
    }
    @media (prefers-reduced-motion: reduce){
      html{scroll-behavior:auto;}
    }
    html,body{
      font-family:"Sarabun", system-ui, sans-serif;
      background:var(--blue);
      color:var(--ink);
    }
    body{
      min-height:100vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:2.5rem 1rem 3rem;
    }
    a{color:inherit;}
    a:visited{color:inherit;}
    code, pre, kbd{font-family:"Fira Code","Fira Mono",monospace;font-variant-ligatures:none;}
    .page{width:100%;display:flex;justify-content:center;}
    .layout{
      width:100%;
      max-width:100rem;
      display:flex;
      gap:3.5rem;
      align-items:flex-start;
      justify-content:center;
    }
    .panel{
      width:100%;
      min-width:0;
      max-width:50rem;
      background:#ffffff;
      border-radius:22px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.45);
      padding:2.75rem 3rem 3.25rem;
      line-height:1.8;
      counter-reset:figure step;
      animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
    }
    .panel.panel-narrow{
      max-width:34rem;
    }
    @keyframes fadeUp{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    .toc{
      display:none;
      width:15rem;
      flex-shrink:0;
      position:sticky;
      top:2.5rem;
    }
    @media (min-width:1180px){
      .toc.has-headings{display:block;}
    }
    .toc-label{
      font-size:0.66rem;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.6px;
      color:rgba(255,255,255,0.6);
      margin-bottom:0.75rem;
    }
    .toc nav{display:flex;flex-direction:column;gap:0.125rem;}
    .toc nav a{
      display:block;
      font-size:0.81rem;
      line-height:1.5;
      color:rgba(255,255,255,0.8);
      text-decoration:none;
      padding:0.3rem 0 0.3rem 0.75rem;
      border-left:2px solid rgba(255,255,255,0.25);
      transition:color .15s, border-color .15s;
    }
    .toc nav a:hover{color:#fff;border-left-color:rgba(255,255,255,0.55);}
    .toc nav a.active{color:#fff;border-left-color:#fff;font-weight:600;}
    .breadcrumb{
      font-size:0.69rem;
      color:var(--muted);
      margin-bottom:1.25rem;
      letter-spacing:.3px;
      text-transform:uppercase;
    }
    .breadcrumb a{
      color:var(--muted);
      text-decoration:none;
      border-bottom:1px solid transparent;
      transition:color .15s, border-color .15s;
    }
    .breadcrumb a:hover{color:var(--blue-deep);border-bottom-color:var(--blue-soft);}
    .tag{
      display:inline-block;
      font-size:0.69rem;
      background:var(--blue-deep);
      color:var(--blue-tint);
      padding:0.25rem 0.75rem;
      border-radius:1.25rem;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.875rem;
    }
    h1{font-size:1.75rem;color:var(--ink);margin-bottom:0.5rem;letter-spacing:-.2px;}
    .subtitle{color:var(--muted);font-size:0.91rem;margin-bottom:2.375rem;}
    h2{
      font-size:1rem;
      color:var(--blue-deep);
      margin-top:2.375rem;
      margin-bottom:0.875rem;
      border-left:3px solid var(--blue);
      padding-left:0.75rem;
      text-transform:uppercase;
      letter-spacing:.5px;
    }
    h2.step{counter-increment:step;}
    h2.step::before{content:"[" counter(step) "] ";}
    p{font-size:0.97rem;color:#2b2a28;margin:0.75rem 0;}
    ul{padding-left:1.375rem;font-size:0.97rem;color:#2b2a28;}
    li{margin:0.5rem 0;}
    strong{color:var(--blue-shadow);font-weight:700;}
    p a, li a, .callout a{
      color:var(--blue-shadow);
      text-decoration:underline;
      text-decoration-color:var(--blue-soft);
      text-underline-offset:2px;
    }
    p a:hover, li a:hover, .callout a:hover{color:var(--blue-deep);}
    .references{
      list-style:none;
      padding-left:0;
      counter-reset:ref;
    }
    .references li{
      counter-increment:ref;
      position:relative;
      padding-left:2rem;
    }
    .references li::before{
      content:"[" counter(ref) "]";
      position:absolute;
      left:0;
      color:var(--blue-shadow);
      font-weight:600;
    }
    /* section dividers: use sparingly, only where the topic genuinely
       shifts — not between every heading */
    .divider{
      border:none;
      border-top:1px dashed var(--blue-soft);
      margin:2.25rem 0;
    }
    .divider-solid{
      border:none;
      border-top:2px solid var(--blue-soft);
      margin:2.75rem 0;
    }
    .card{
      background:var(--blue-tint);
      border-radius:14px;
      padding:1.125rem 1.5rem;
      margin:1rem 0;
    }
    .card ul{padding-left:1.125rem;}
    figure.screenshot{
      margin:1.125rem 0;
    }
    figure.screenshot img{
      display:block;
      width:100%;
      height:auto;
      border-radius:10px;
    }
    figure.screenshot figcaption{
      margin-top:0.6rem;
      font-size:0.8rem;
      color:var(--muted);
      text-align:center;
    }
    figure.screenshot figcaption::before{
      counter-increment:figure;
      content:"Figure " counter(figure) ": ";
      font-weight:700;
      color:var(--ink);
    }
    .expander{
      border:1px solid var(--blue-soft);
      border-radius:14px;
      padding:1rem 1.25rem;
      margin:1rem 0;
      background:#fff;
    }
    .expander summary{
      cursor:pointer;
      font-weight:700;
      color:var(--blue-deep);
      list-style:none;
      display:flex;
      align-items:center;
      gap:0.6rem;
      user-select:none;
    }
    .expander summary::-webkit-details-marker{display:none;}
    .expander summary::before{
      content:"▸";
      color:var(--blue);
      display:inline-block;
      transition:transform .15s ease;
      flex-shrink:0;
    }
    .expander[open] summary::before{transform:rotate(90deg);}
    .expander .expander-body{
      margin-top:0.9rem;
      padding-top:0.9rem;
      border-top:1px dashed var(--blue-soft);
    }
    .expander .expander-body > :first-child{margin-top:0;}
    .expander .expander-body > :last-child{margin-bottom:0;}
    code{
      background:var(--blue-tint);
      color:var(--blue-shadow);
      padding:0.125rem 0.375rem;
      border-radius:6px;
      font-size:0.9em;
    }
    pre{
      background:#1c2536;
      color:#e7ecf6;
      border-radius:14px;
      padding:1.125rem 1.25rem;
      margin:1.125rem 0;
      overflow-x:auto;
      font-size:0.84rem;
      line-height:1.7;
    }
    pre code{background:none;color:inherit;padding:0;font-size:1em;}
    /* Shiki (astro:components Code) sets its own background/color inline via the theme;
       override those two so the box still matches the site's navy code style, while leaving
       each token's own inline color alone so syntax highlighting still shows through. */
    pre.astro-code{background-color:#1c2536 !important;color:#e7ecf6 !important;}
    .callout{
      border-radius:12px;
      padding:1rem 1.25rem;
      margin:1.125rem 0;
      border-left:3px solid;
    }
    .callout p{margin:0;font-size:0.875rem;}
    .callout-label{
      font-size:0.69rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.25rem;
    }
    .callout-tip{background:#eafaf0;border-color:#2f9e5c;}
    .callout-tip .callout-label{color:#1f7a45;}
    .callout-warn{background:#fdecec;border-color:#d64545;}
    .callout-warn .callout-label{color:#b23b3b;}
    .callout-note{background:var(--blue-tint);border-color:var(--blue);}
    .callout-note .callout-label{color:var(--blue-deep);}
    footer{
      margin-top:2.5rem;
      font-size:0.69rem;
      color:#9aa7bd;
      text-align:center;
    }
    .wiki-tip{position:relative;display:inline-block;}
    .wiki-tip-card{
      position:absolute;
      bottom:calc(100% + 10px);
      left:50%;
      transform:translateX(-50%) translateY(4px);
      width:11rem;
      background:#ffffff;
      border-radius:12px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.4);
      padding:0.625rem;
      opacity:0;
      visibility:hidden;
      pointer-events:none;
      transition:opacity .15s ease, transform .15s ease;
      z-index:30;
    }
    .wiki-tip-card::after{
      content:"";
      position:absolute;
      top:100%;
      left:50%;
      transform:translateX(-50%);
      border:6px solid transparent;
      border-top-color:#ffffff;
    }
    .wiki-tip-card img{
      width:100%;
      display:block;
      border-radius:8px;
      margin-bottom:0.5rem;
    }
    .wiki-tip-caption{
      display:block;
      font-size:0.66rem;
      line-height:1.45;
      color:var(--muted);
    }
    .wiki-tip:hover .wiki-tip-card,
    .wiki-tip:focus-within .wiki-tip-card{
      opacity:1;
      visibility:visible;
      transform:translateX(-50%) translateY(0);
      pointer-events:auto;
    }
    .article-nav{
      display:flex;
      gap:1rem;
      margin-top:2.75rem;
      padding-top:1.5rem;
      border-top:1px dashed var(--blue-soft);
    }
    .article-nav > a{
      flex:1 1 0;
      display:flex;
      flex-direction:column;
      gap:0.25rem;
      padding:0.875rem 1rem;
      border-radius:12px;
      text-decoration:none;
      color:var(--ink);
      transition:background .15s, border-color .15s;
      border:1px solid transparent;
    }
    .article-nav > a:hover{background:var(--blue-tint);border-color:var(--blue-soft);}
    .article-nav-next{text-align:right;margin-left:auto;}
    .article-nav-label{
      font-size:0.69rem;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.4px;
    }
    .article-nav-title{font-size:0.9rem;font-weight:600;color:var(--blue-shadow);}
    .site-footer{
      width:100%;
      max-width:34rem;
      margin-top:3rem;
      padding-top:1.75rem;
      border-top:1px solid rgba(255,255,255,0.15);
      text-align:center;
    }
    .site-footer-social{
      display:flex;
      justify-content:center;
      gap:1.2rem;
      margin-bottom:0.875rem;
    }
    .site-footer-social a{
      color:rgba(255,255,255,0.65);
      line-height:1;
      transition:color .15s, transform .15s;
      display:inline-block;
    }
    .site-footer-social svg{
      width:1.1rem;
      height:1.1rem;
      display:block;
    }
    .site-footer-social a:hover{color:#fff;transform:translateY(-1px);}
    .site-footer-copyright{
      font-size:0.72rem;
      color:rgba(255,255,255,0.55);
      letter-spacing:.2px;
    }
    .site-footer-copyright a{
      color:rgba(255,255,255,0.8);
      text-decoration:underline;
      text-decoration-color:rgba(255,255,255,0.35);
      text-underline-offset:2px;
    }
    .site-footer-copyright a:hover{color:#fff;}
  </style>
</head>
<body data-bg="plain">
  <StarfieldBackground />
  <SelfXssWarning />
  <div class="page">
    <div class="layout">
      <div class:list={["panel", { "panel-narrow": narrow }]}>
        <slot />
        {updated && <ShareButtons />}
        {(prev || next) && (
          <nav class="article-nav">
            {prev ? (
              <a class="article-nav-prev" href={`../${prev.href}`} data-astro-prefetch="viewport">
                <span class="article-nav-label">&larr; บทความก่อนหน้า</span>
                <span class="article-nav-title">{prev.title}</span>
              </a>
            ) : <span />}
            {next ? (
              <a class="article-nav-next" href={`../${next.href}`} data-astro-prefetch="viewport">
                <span class="article-nav-label">บทความถัดไป &rarr;</span>
                <span class="article-nav-title">{next.title}</span>
              </a>
            ) : <span />}
          </nav>
        )}
        {updated && <footer>หมวดความรู้ — อัปเดตล่าสุด {updated}</footer>}
      </div>
      <aside class="toc" id="page-toc">
        <p class="toc-label">ในบทความนี้</p>
        <nav id="toc-nav"></nav>
      </aside>
    </div>
  </div>
  <footer class="site-footer">
    <div class="site-footer-social">
      {footerSocialLinks.map((s) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d={s.iconPath} /></svg>
        </a>
      ))}
    </div>
    <p class="site-footer-copyright">&copy; {year} <a href="/">ChimengSoso</a> — สร้างด้วย <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a></p>
  </footer>
  <DonateButton />
  <script>
    // Astro's ClientRouter re-inserts this <script> tag's markup on every navigation,
    // but the module itself only ever evaluates once (same module URL), so top-level
    // code here would only ever run for the very first page. astro:page-load fires on
    // every navigation (including the first), so build the TOC there instead.
    // Kept outside buildToc so each call can disconnect the previous navigation's
    // observer before creating a new one -- otherwise every article visit leaks an
    // observer still watching that page's now-detached headings, and now that
    // ClientRouter keeps the document alive across navigations, those leaks
    // accumulate for the whole browsing session instead of being cleared by a reload.
    let currentObserver: IntersectionObserver | null = null;

    function buildToc() {
      currentObserver?.disconnect();
      currentObserver = null;

      const headings = Array.from(document.querySelectorAll('.panel h2'));
      const toc = document.getElementById('page-toc');
      const nav = document.getElementById('toc-nav');
      if (!toc || !nav) return;
      nav.innerHTML = '';
      toc.classList.remove('has-headings');

      if (headings.length < 2) return;
      const used = new Set();
      headings.forEach((h, i) => {
        if (!h.id) {
          let slug = h.textContent.trim().toLowerCase()
            .replace(/[^a-z0-9ก-๙\s-]/g, '')
            .replace(/\s+/g, '-') || `section-${i}`;
          while (used.has(slug)) slug = `${slug}-${i}`;
          used.add(slug);
          h.id = slug;
        }
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent;
        nav.appendChild(a);
      });
      toc.classList.add('has-headings');

      const links = Array.from(nav.querySelectorAll('a'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          links.forEach((l) => l.classList.remove('active'));
          const active = nav.querySelector(`a[href="#${entry.target.id}"]`);
          if (active) active.classList.add('active');
        });
      }, { rootMargin: '-15% 0px -70% 0px' });
      headings.forEach((h) => observer.observe(h));
      currentObserver = observer;
    }
    document.addEventListener('astro:page-load', buildToc);
  </script>
</body>
</html>
