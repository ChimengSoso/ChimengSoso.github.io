---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "หมวดความรู้ของ ChimengSoso" } = Astro.props;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root{
      --blue: #4d72a9;
      --blue-deep: #294266;
      --blue-shadow: #163f78;
      --blue-soft: #bcd3f8;
      --blue-tint: #ecf3fc;
      --ink: #131e30;
      --muted: #5a6a85;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{
      font-family:"Fira Mono", monospace;
      background:var(--blue);
      color:var(--ink);
    }
    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      padding:40px 16px 72px;
    }
    a{color:inherit;}
    .page{width:100%;display:flex;justify-content:center;}
    .panel{
      width:100%;
      max-width:38rem;
      background:#ffffff;
      border-radius:22px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.45);
      padding:32px 30px 40px;
      line-height:1.75;
      animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
    }
    @keyframes fadeUp{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    .breadcrumb{font-size:11px;color:var(--blue);margin-bottom:20px;letter-spacing:.2px;}
    .breadcrumb a{text-decoration:none;color:var(--blue-deep);transition:opacity .15s;}
    .breadcrumb a:hover{opacity:.65;}
    .tag{
      display:inline-block;
      font-size:10px;
      background:var(--blue-deep);
      color:var(--blue-tint);
      padding:3px 10px;
      border-radius:20px;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:12px;
    }
    h1{font-size:23px;color:var(--ink);margin-bottom:6px;letter-spacing:-.2px;}
    .subtitle{color:var(--muted);font-size:12.5px;margin-bottom:34px;}
    h2{
      font-size:14.5px;
      color:var(--blue-deep);
      margin-top:34px;
      margin-bottom:12px;
      border-left:3px solid var(--blue);
      padding-left:11px;
      text-transform:uppercase;
      letter-spacing:.5px;
    }
    p{font-size:13.5px;color:#2b2a28;margin:10px 0;}
    ul{padding-left:20px;font-size:13.5px;color:#2b2a28;}
    li{margin:7px 0;}
    .card{
      background:var(--blue-tint);
      border-radius:14px;
      padding:16px 20px;
      margin:14px 0;
    }
    footer{
      margin-top:40px;
      font-size:11px;
      color:#9aa7bd;
      text-align:center;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="panel">
      <slot />
    </div>
  </div>
</body>
</html>
