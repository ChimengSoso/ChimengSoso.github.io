---
interface Props {
  title: string;
  description?: string;
  narrow?: boolean;
}
const { title, description = "หมวดความรู้ของ ChimengSoso", narrow = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    :root{
      --blue: #4d72a9;
      --blue-deep: #294266;
      --blue-shadow: #163f78;
      --blue-soft: #bcd3f8;
      --blue-tint: #ecf3fc;
      --ink: #131e30;
      --muted: #5a6a85;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{
      /* fluid base size: scales the whole rem-based layout with viewport width,
         so large screens don't need manual zoom to look proportionate */
      font-size:clamp(16px, 12px + 0.95vw, 27px);
    }
    html,body{
      font-family:"Sarabun", system-ui, sans-serif;
      background:var(--blue);
      color:var(--ink);
    }
    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      padding:2.5rem 1rem 4.5rem;
    }
    a{color:inherit;}
    a:visited{color:inherit;}
    code, pre, kbd{font-family:"Fira Code","Fira Mono",monospace;}
    .page{width:100%;display:flex;justify-content:center;}
    .layout{
      width:100%;
      max-width:100rem;
      display:flex;
      gap:3.5rem;
      align-items:flex-start;
      justify-content:center;
    }
    .panel{
      width:100%;
      min-width:0;
      max-width:50rem;
      background:#ffffff;
      border-radius:22px;
      box-shadow:0 14px 28px -6px rgba(22,63,120,0.45);
      padding:2.75rem 3rem 3.25rem;
      line-height:1.8;
      animation:fadeUp .5s cubic-bezier(.16,1,.3,1) both;
    }
    .panel.panel-narrow{
      max-width:34rem;
    }
    @keyframes fadeUp{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    .toc{
      display:none;
      width:15rem;
      flex-shrink:0;
      position:sticky;
      top:2.5rem;
    }
    @media (min-width:1180px){
      .toc.has-headings{display:block;}
    }
    .toc-label{
      font-size:0.66rem;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:.6px;
      color:rgba(255,255,255,0.6);
      margin-bottom:0.75rem;
    }
    .toc nav{display:flex;flex-direction:column;gap:0.125rem;}
    .toc nav a{
      display:block;
      font-size:0.81rem;
      line-height:1.5;
      color:rgba(255,255,255,0.8);
      text-decoration:none;
      padding:0.3rem 0 0.3rem 0.75rem;
      border-left:2px solid rgba(255,255,255,0.25);
      transition:color .15s, border-color .15s;
    }
    .toc nav a:hover{color:#fff;border-left-color:rgba(255,255,255,0.55);}
    .toc nav a.active{color:#fff;border-left-color:#fff;font-weight:600;}
    .breadcrumb{
      font-size:0.69rem;
      color:var(--muted);
      margin-bottom:1.25rem;
      letter-spacing:.3px;
      text-transform:uppercase;
    }
    .breadcrumb a{
      color:var(--muted);
      text-decoration:none;
      border-bottom:1px solid transparent;
      transition:color .15s, border-color .15s;
    }
    .breadcrumb a:hover{color:var(--blue-deep);border-bottom-color:var(--blue-soft);}
    .tag{
      display:inline-block;
      font-size:0.69rem;
      background:var(--blue-deep);
      color:var(--blue-tint);
      padding:0.25rem 0.75rem;
      border-radius:1.25rem;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.875rem;
    }
    h1{font-size:1.75rem;color:var(--ink);margin-bottom:0.5rem;letter-spacing:-.2px;}
    .subtitle{color:var(--muted);font-size:0.91rem;margin-bottom:2.375rem;}
    h2{
      font-size:1rem;
      color:var(--blue-deep);
      margin-top:2.375rem;
      margin-bottom:0.875rem;
      border-left:3px solid var(--blue);
      padding-left:0.75rem;
      text-transform:uppercase;
      letter-spacing:.5px;
    }
    p{font-size:0.97rem;color:#2b2a28;margin:0.75rem 0;}
    ul{padding-left:1.375rem;font-size:0.97rem;color:#2b2a28;}
    li{margin:0.5rem 0;}
    strong{color:var(--blue-shadow);font-weight:700;}
    .card{
      background:var(--blue-tint);
      border-radius:14px;
      padding:1.125rem 1.5rem;
      margin:1rem 0;
    }
    .card ul{padding-left:1.125rem;}
    code{
      background:var(--blue-tint);
      color:var(--blue-shadow);
      padding:0.125rem 0.375rem;
      border-radius:6px;
      font-size:0.9em;
    }
    pre{
      background:#1c2536;
      color:#e7ecf6;
      border-radius:14px;
      padding:1.125rem 1.25rem;
      margin:1.125rem 0;
      overflow-x:auto;
      font-size:0.84rem;
      line-height:1.7;
    }
    pre code{background:none;color:inherit;padding:0;font-size:1em;}
    .callout{
      border-radius:12px;
      padding:1rem 1.25rem;
      margin:1.125rem 0;
      border-left:3px solid;
    }
    .callout p{margin:0;font-size:0.875rem;}
    .callout-label{
      font-size:0.69rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.25rem;
    }
    .callout-tip{background:#eafaf0;border-color:#2f9e5c;}
    .callout-tip .callout-label{color:#1f7a45;}
    .callout-warn{background:#fdecec;border-color:#d64545;}
    .callout-warn .callout-label{color:#b23b3b;}
    .callout-note{background:var(--blue-tint);border-color:var(--blue);}
    .callout-note .callout-label{color:var(--blue-deep);}
    footer{
      margin-top:2.5rem;
      font-size:0.69rem;
      color:#9aa7bd;
      text-align:center;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="layout">
      <div class:list={["panel", { "panel-narrow": narrow }]}>
        <slot />
      </div>
      <aside class="toc" id="page-toc">
        <p class="toc-label">ในบทความนี้</p>
        <nav id="toc-nav"></nav>
      </aside>
    </div>
  </div>
  <script>
    const headings = Array.from(document.querySelectorAll('.panel h2'));
    const toc = document.getElementById('page-toc');
    const nav = document.getElementById('toc-nav');

    if (toc && nav && headings.length >= 2) {
      const used = new Set();
      headings.forEach((h, i) => {
        if (!h.id) {
          let slug = h.textContent.trim().toLowerCase()
            .replace(/[^a-z0-9ก-๙\s-]/g, '')
            .replace(/\s+/g, '-') || `section-${i}`;
          while (used.has(slug)) slug = `${slug}-${i}`;
          used.add(slug);
          h.id = slug;
        }
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent;
        nav.appendChild(a);
      });
      toc.classList.add('has-headings');

      const links = Array.from(nav.querySelectorAll('a'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          links.forEach((l) => l.classList.remove('active'));
          const active = nav.querySelector(`a[href="#${entry.target.id}"]`);
          if (active) active.classList.add('active');
        });
      }, { rootMargin: '-15% 0px -70% 0px' });
      headings.forEach((h) => observer.observe(h));
    } else if (toc) {
      toc.remove();
    }
  </script>
</body>
</html>
