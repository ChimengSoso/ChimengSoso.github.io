---
import { ClientRouter } from 'astro:transitions';
import DonateButton from '../components/DonateButton.astro';
import { footerSocialLinks } from '../data/socialLinks';
import '../styles/fonts.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "บันทึกลับของ ChimengSoso" } = Astro.props;
const year = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0d1220" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title}</title>
  <link rel="canonical" href={Astro.url.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
  <link rel="icon" type="image/jpeg" href="/img.jpg" />
  <ClientRouter />

  <style is:global>
    /* DonateButton is a shared component styled against the main site's blue
       palette (Layout.astro's :root) -- defined here too so its popup dialog
       renders correctly on this otherwise dark/emerald "vault" theme. */
    :root{
      --blue: #4d72a9;
      --blue-deep: #294266;
      --blue-shadow: #163f78;
      --blue-soft: #bcd3f8;
      --blue-tint: #ecf3fc;
      --ink: #131e30;
      --muted: #5a6a85;

      --dl-bg: #0d1220;
      --dl-panel: #1c2536;
      --dl-border: #2a3350;
      --dl-ink: #e7ecf6;
      --dl-muted: #9aa7bd;
      --dl-emerald: #2f9e5c;
      --dl-emerald-bright: #4ade80;
      --dl-gold: #e0b400;
      --dl-red: #d64545;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{font-size:clamp(16px, 1rem + 0.3vw, 22px);}
    html,body{
      font-family:"Sarabun", system-ui, sans-serif;
      background:var(--dl-bg);
      color:var(--dl-ink);
    }
    body{
      min-height:100vh;
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:2.5rem 1rem 3rem;
    }
    a{color:inherit;}
    a:visited{color:inherit;}
    code, pre{font-family:"Fira Code","Fira Mono",monospace;font-variant-ligatures:none;}
    .panel{
      width:100%;
      max-width:42rem;
      background:var(--dl-panel);
      border:1px solid var(--dl-border);
      border-radius:22px;
      box-shadow:0 20px 60px -12px rgba(0,0,0,0.6);
      padding:2.25rem 2.25rem 2.75rem;
      line-height:1.8;
      animation:dl-fade-up .5s cubic-bezier(.16,1,.3,1) both;
    }
    @keyframes dl-fade-up{
      from{opacity:0;transform:translateY(10px);}
      to{opacity:1;transform:translateY(0);}
    }
    .dl-nav{
      display:flex;
      flex-wrap:wrap;
      gap:1.25rem;
      margin-bottom:1.25rem;
    }
    .dl-nav a{
      display:inline-flex;
      align-items:center;
      gap:4px;
      font-size:0.82rem;
      color:var(--dl-muted);
      text-decoration:none;
      transition:color .15s;
    }
    .dl-nav a:hover{color:var(--dl-emerald-bright);}
    .dl-nav-arrow{
      width:16px;
      height:16px;
      flex-shrink:0;
      transition:transform .15s ease;
    }
    .dl-nav a:hover .dl-nav-arrow{transform:translateX(-3px);}
    @media (prefers-reduced-motion: reduce){
      .dl-nav a:hover .dl-nav-arrow{transform:none;}
    }
    .tag{
      display:inline-block;
      font-family:"JetBrains Mono", monospace;
      font-size:0.66rem;
      background:var(--dl-emerald);
      color:#eafaf0;
      padding:0.25rem 0.75rem;
      border-radius:1.25rem;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.875rem;
    }
    h1{font-size:1.6rem;color:#fff;margin-bottom:0.5rem;letter-spacing:-.2px;}
    .subtitle{color:var(--dl-muted);font-size:0.91rem;margin-bottom:2rem;}
    h2{
      font-size:1rem;
      color:var(--dl-emerald-bright);
      margin-top:2.25rem;
      margin-bottom:0.875rem;
      border-left:3px solid var(--dl-emerald);
      padding-left:0.75rem;
      text-transform:uppercase;
      letter-spacing:.5px;
    }
    p{font-size:0.97rem;color:var(--dl-ink);margin:0.75rem 0;}
    ul{padding-left:1.375rem;font-size:0.97rem;color:var(--dl-ink);}
    li{margin:0.5rem 0;}
    strong{color:var(--dl-emerald-bright);font-weight:700;}
    .arw{
      color:var(--dl-emerald-bright);
      font-size:1.05em;
      margin:0 0.14em;
      vertical-align:-0.03em;
    }
    p a, li a, .callout a{
      color:var(--dl-emerald-bright);
      text-decoration:underline;
      text-decoration-color:rgba(74,222,128,0.4);
      text-underline-offset:2px;
    }
    p a:hover, li a:hover, .callout a:hover{color:#fff;}
    .references{
      list-style:none;
      padding-left:0;
      counter-reset:ref;
    }
    .references li{
      counter-increment:ref;
      position:relative;
      padding-left:2rem;
    }
    .references li::before{
      content:"[" counter(ref) "]";
      position:absolute;
      left:0;
      color:var(--dl-emerald-bright);
      font-weight:600;
    }
    .divider{
      border:none;
      border-top:1px dashed var(--dl-border);
      margin:2.25rem 0;
    }
    .divider-solid{
      border:none;
      border-top:2px solid var(--dl-border);
      margin:2.75rem 0;
    }
    .card{
      background:#141a29;
      border:1px solid var(--dl-border);
      border-radius:14px;
      padding:1.125rem 1.5rem;
      margin:1rem 0;
    }
    .card ul{padding-left:1.125rem;}
    .pull{
      font-size:1.05rem;
      font-weight:600;
      color:#fff;
      border-left:3px solid var(--dl-gold);
      padding-left:1rem;
      margin:1.5rem 0;
      line-height:1.6;
    }
    .callout{
      border-radius:12px;
      padding:1rem 1.25rem;
      margin:1.125rem 0;
      border-left:3px solid;
    }
    .callout p{margin:0;font-size:0.875rem;}
    .callout-label{
      font-family:"JetBrains Mono", monospace;
      font-size:0.69rem;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
      margin-bottom:0.25rem;
    }
    .callout-tip{background:rgba(47,158,92,0.12);border-color:var(--dl-emerald);}
    .callout-tip .callout-label{color:var(--dl-emerald-bright);}
    .callout-warn{background:rgba(214,69,69,0.12);border-color:var(--dl-red);}
    .callout-warn .callout-label{color:#f08b8b;}
    .callout-note{background:rgba(224,180,0,0.08);border-color:var(--dl-gold);}
    .callout-note .callout-label{color:var(--dl-gold);}
    code{
      background:#141a29;
      color:var(--dl-emerald-bright);
      padding:0.125rem 0.375rem;
      border-radius:6px;
      font-size:0.9em;
    }
    figure.diagram{margin:1.125rem 0;}
    figure.diagram figcaption{
      margin-top:0.6rem;
      font-size:0.8rem;
      color:var(--dl-muted);
      text-align:center;
    }
    figure.photo{margin:1.125rem 0;}
    figure.photo img{
      display:block;
      width:100%;
      height:auto;
      background:#f4f1e9;
      padding:0.75rem;
      border-radius:12px;
      border:1px solid var(--dl-border);
    }
    figure.photo figcaption{
      margin-top:0.6rem;
      font-size:0.8rem;
      color:var(--dl-muted);
      text-align:center;
    }
    figure.photo figcaption .photo-credit{
      display:block;
      margin-top:0.2rem;
      font-size:0.72rem;
      color:#6b7690;
    }
    .site-footer{
      width:100%;
      max-width:34rem;
      margin-top:2.5rem;
      padding-top:1.75rem;
      border-top:1px solid var(--dl-border);
      text-align:center;
    }
    .site-footer-social{
      display:flex;
      justify-content:center;
      gap:1.2rem;
      margin-bottom:0.875rem;
    }
    .site-footer-social a{
      color:var(--dl-muted);
      line-height:1;
      transition:color .15s, transform .15s;
      display:inline-block;
    }
    .site-footer-social svg{
      width:1.1rem;
      height:1.1rem;
      display:block;
    }
    .site-footer-social a:hover{color:var(--dl-emerald-bright);transform:translateY(-1px);}
    .site-footer-copyright{
      font-size:0.72rem;
      color:var(--dl-muted);
      letter-spacing:.2px;
    }
    .site-footer-copyright a{
      color:var(--dl-emerald-bright);
      text-decoration:underline;
      text-decoration-color:rgba(74,222,128,0.4);
      text-underline-offset:2px;
    }
    .site-footer-copyright a:hover{color:#fff;}
  </style>
</head>
<body>
  <div class="panel">
    <slot />
  </div>
  <footer class="site-footer">
    <div class="site-footer-social">
      {footerSocialLinks.map((s) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label}>
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d={s.iconPath} /></svg>
        </a>
      ))}
    </div>
    <p class="site-footer-copyright">&copy; {year} <a href="/">ChimengSoso</a> — สร้างด้วย <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> · <a href="/privacy/">นโยบายความเป็นส่วนตัว</a></p>
  </footer>
  <DonateButton />
</body>
</html>
