---
const shareUrl = Astro.url.href;
const fbShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
---
<div class="share-row">
  <span class="share-label">แชร์บทความนี้</span>
  <a
    class="share-fb"
    href={fbShareUrl}
    data-share-url={shareUrl}
    target="_blank"
    rel="noopener noreferrer"
    title="แชร์ไปยัง Facebook"
    aria-label="แชร์บทความนี้ไปยัง Facebook"
  >
    <svg class="icon-fb" viewBox="0 0 320 512" aria-hidden="true" fill="currentColor"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
    <svg class="icon-check" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </a>
  <button
    class="share-copy"
    type="button"
    data-copy-link
    data-url={shareUrl}
    title="คัดลอกลิงก์"
    aria-label="คัดลอกลิงก์บทความนี้"
  >
    <svg class="icon-link" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <svg class="icon-check" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </button>
</div>

<style>
  .share-row{
    display:flex;
    align-items:center;
    gap:0.625rem;
    margin-top:2.5rem;
    padding-top:1.5rem;
    border-top:1px dashed var(--blue-soft);
  }
  .share-label{
    font-size:0.78rem;
    color:var(--muted);
  }
  .share-fb, .share-copy{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:2.1rem;
    height:2.1rem;
    flex-shrink:0;
    border-radius:50%;
    text-decoration:none;
    font-size:1rem;
    transition:background .15s, transform .15s;
  }
  .share-fb{
    background:#1877f2;
    color:#fff;
  }
  .share-fb:hover{background:#0d5fc7;transform:translateY(-1px);}
  .share-copy{
    background:var(--blue);
    color:#fff;
    border:none;
    cursor:pointer;
    padding:0;
    font-family:inherit;
  }
  .share-copy:hover{background:var(--blue-deep);transform:translateY(-1px);}
  .icon-fb{width:0.625rem;height:1rem;}
  .icon-link, .icon-check{width:1rem;height:1rem;}
  .share-copy .icon-check{display:none;}
  .share-copy.copied{background:#2f9e5c;}
  .share-copy.copied .icon-link{display:none;}
  .share-copy.copied .icon-check{display:block;}
  .share-fb .icon-check{display:none;}
  .share-fb.shared{background:#2f9e5c;}
  .share-fb.shared .icon-fb{display:none;}
  .share-fb.shared .icon-check{display:block;}
</style>

<script>
  // Facebook share uses the JS SDK's FB.ui share dialog (not a raw sharer.php
  // popup) because that dialog closes itself after the user posts and fires a
  // callback — the sharer.php popup no longer auto-closes, it redirects to the
  // feed and lingers. The SDK is loaded lazily on the first share click so it
  // never blocks initial page load (the site deliberately avoids external CDN
  // scripts on load). If the SDK is blocked or fails, we fall back to the old
  // sharer.php popup so sharing still works.
  const FB_APP_ID = '999748286011681';
  const FB_SDK_SRC = 'https://connect.facebook.net/th_TH/sdk.js';
  const FB_VERSION = 'v21.0';

  type FbShareParams = { method: 'share'; href: string };
  type FacebookSdk = {
    init(options: { appId: string; xfbml: boolean; version: string }): void;
    ui(params: FbShareParams, callback: (response?: unknown) => void): void;
  };
  type WindowWithFb = Window & { FB?: FacebookSdk };

  let sdkPromise: Promise<FacebookSdk> | null = null;

  function loadFbSdk(): Promise<FacebookSdk> {
    const existing = (window as WindowWithFb).FB;
    if (existing) return Promise.resolve(existing);
    if (sdkPromise) return sdkPromise;
    sdkPromise = new Promise<FacebookSdk>((resolve, reject) => {
      if (!document.getElementById('fb-root')) {
        const root = document.createElement('div');
        root.id = 'fb-root';
        document.body.appendChild(root);
      }
      const script = document.createElement('script');
      script.src = FB_SDK_SRC;
      script.async = true;
      script.defer = true;
      script.crossOrigin = 'anonymous';
      script.addEventListener('load', () => {
        const fb = (window as WindowWithFb).FB;
        if (!fb) {
          reject(new Error('FB SDK loaded but window.FB is missing'));
          return;
        }
        fb.init({ appId: FB_APP_ID, xfbml: false, version: FB_VERSION });
        resolve(fb);
      });
      script.addEventListener('error', () => reject(new Error('FB SDK failed to load')));
      document.head.appendChild(script);
    });
    return sdkPromise;
  }

  function sharerFallback(sharerUrl: string) {
    window.open(sharerUrl, 'facebook-share', 'width=580,height=520,menubar=no,toolbar=no,location=no,status=no');
  }

  // Registered once via astro:page-load (see StarfieldBackground.astro for why) so
  // the share row on every article still works after a client-side navigation.
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLAnchorElement>('.share-fb').forEach((btn) => {
      // Warm the SDK up on hover/focus/press so it's ready by click time. The
      // click handler must then call FB.ui *synchronously* (no await) — awaiting
      // first loses the user-gesture activation and the browser blocks FB's popup
      // (POPUP_MAYBE_BLOCKED). If it isn't ready yet, we open the classic sharer
      // popup synchronously instead (also in-gesture, so not blocked).
      const warm = () => { loadFbSdk().catch(() => {}); };
      btn.addEventListener('pointerenter', warm);
      btn.addEventListener('focus', warm);
      btn.addEventListener('pointerdown', warm);

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const shareUrl = btn.dataset.shareUrl ?? btn.href;
        const fb = (window as WindowWithFb).FB;
        if (fb) {
          // FB's own share dialog is cross-origin and closes itself (or lingers
          // on a confirmation screen) beyond our control — so give the user
          // clear feedback on *our* page instead. A truthy response with no
          // error_code means the post went through; undefined / error_code
          // (e.g. 4201 user-cancelled) means they backed out, so stay silent.
          fb.ui({ method: 'share', href: shareUrl }, (response) => {
            const res = response as { error_code?: number } | undefined;
            if (!res || res.error_code) return;
            btn.classList.add('shared');
            window.setTimeout(() => btn.classList.remove('shared'), 1600);
          });
        } else {
          warm();
          sharerFallback(btn.href);
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url ?? '';
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          return;
        }
        btn.classList.add('copied');
        window.setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });
  });
</script>
