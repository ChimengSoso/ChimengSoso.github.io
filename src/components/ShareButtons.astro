---
const shareUrl = Astro.url.href;
const fbShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
---
<div class="share-row">
  <span class="share-label">แชร์บทความนี้</span>
  <a
    class="share-fb"
    href={fbShareUrl}
    target="_blank"
    rel="noopener noreferrer"
    title="แชร์ไปยัง Facebook"
    aria-label="แชร์บทความนี้ไปยัง Facebook"
  >
    <svg class="icon-fb" viewBox="0 0 320 512" aria-hidden="true" fill="currentColor"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
  </a>
  <button
    class="share-copy"
    type="button"
    data-copy-link
    data-url={shareUrl}
    title="คัดลอกลิงก์"
    aria-label="คัดลอกลิงก์บทความนี้"
  >
    <svg class="icon-link" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <svg class="icon-check" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
  </button>
</div>

<style>
  .share-row{
    display:flex;
    align-items:center;
    gap:0.625rem;
    margin-top:2.5rem;
    padding-top:1.5rem;
    border-top:1px dashed var(--blue-soft);
  }
  .share-label{
    font-size:0.78rem;
    color:var(--muted);
  }
  .share-fb, .share-copy{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:2.1rem;
    height:2.1rem;
    flex-shrink:0;
    border-radius:50%;
    text-decoration:none;
    font-size:1rem;
    transition:background .15s, transform .15s;
  }
  .share-fb{
    background:#1877f2;
    color:#fff;
  }
  .share-fb:hover{background:#0d5fc7;transform:translateY(-1px);}
  .share-copy{
    background:var(--blue);
    color:#fff;
    border:none;
    cursor:pointer;
    padding:0;
    font-family:inherit;
  }
  .share-copy:hover{background:var(--blue-deep);transform:translateY(-1px);}
  .icon-fb{width:0.625rem;height:1rem;}
  .icon-link, .icon-check{width:1rem;height:1rem;}
  .share-copy .icon-check{display:none;}
  .share-copy.copied{background:#2f9e5c;}
  .share-copy.copied .icon-link{display:none;}
  .share-copy.copied .icon-check{display:block;}
</style>

<script>
  // ---------------------------------------------------------------------------
  // Facebook share = plain sharer.php popup. Deliberately NO JS SDK.
  //
  // WHY (revert history — read before "improving" this):
  //   We previously used the FB JS SDK (`FB.ui({method:'share'})`) so the share
  //   dialog could fire a success callback (green ✓ feedback) and — the original
  //   ask — close itself after posting. It turned out (a) FB.ui v21 does NOT
  //   auto-close its dialog and we can't close cross-origin facebook.com chrome
  //   ourselves, and (b) the SDK share dialog requires the FB App to be a fully
  //   registered/verified business app; that verification lapsed, so the SDK
  //   path broke and sharing stopped working entirely. sharer.php needs none of
  //   that — no App ID, no SDK, no business verification — so anyone can share.
  //   We accept losing the green ✓ success feedback (sharer.php gives no
  //   callback) in exchange for sharing that Just Works today.
  //
  // TO BRING THE SDK BACK (only once the FB business/App verification is
  // approved — the owner wants it for share analytics): see the "Reviving the
  // Facebook share SDK" plan in CLAUDE.md. In short: restore the loadFbSdk()/
  // FB.ui() click path + the `.share-fb.shared` green-✓ CSS + the removed
  // <svg class="icon-check"> inside the .share-fb anchor, keeping this popup as
  // the fallback. Git history for this file holds the full prior implementation.
  // ---------------------------------------------------------------------------
  function openSharePopup(sharerUrl: string): Window | null {
    const popup = window.open(sharerUrl, 'facebook-share', 'width=580,height=520,menubar=no,toolbar=no,location=no,status=no');
    // Sever the reverse handle so the opened page can never navigate this tab
    // (window.open's feature string has no rel="noopener" equivalent that still
    // returns the handle we need for the blocked-popup fallback below).
    if (popup) popup.opener = null;
    return popup;
  }

  // Registered once via astro:page-load (see StarfieldBackground.astro for why) so
  // the share row on every article still works after a client-side navigation.
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLAnchorElement>('.share-fb').forEach((btn) => {
      // Open the sharer.php URL as a small popup instead of a full new tab. The
      // window.open must run synchronously inside the click (in-gesture) or the
      // browser blocks the popup. preventDefault only on success, so a blocked
      // popup falls back to the anchor's own target="_blank" navigation instead
      // of the click silently doing nothing.
      btn.addEventListener('click', (e) => {
        if (openSharePopup(btn.href)) e.preventDefault();
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url ?? '';
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          return;
        }
        btn.classList.add('copied');
        window.setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });
  });
</script>
