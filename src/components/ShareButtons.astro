---
const shareUrl = Astro.url.href;
const fbShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;
---
<div class="share-row">
  <span class="share-label">แชร์บทความนี้</span>
  <a
    class="share-fb"
    href={fbShareUrl}
    target="_blank"
    rel="noopener noreferrer"
    title="แชร์ไปยัง Facebook"
    aria-label="แชร์บทความนี้ไปยัง Facebook"
  >
    <i class="fa fa-facebook"></i>
  </a>
  <button
    class="share-copy"
    type="button"
    data-copy-link
    data-url={shareUrl}
    title="คัดลอกลิงก์"
    aria-label="คัดลอกลิงก์บทความนี้"
  >
    <i class="fa fa-link icon-link"></i>
    <i class="fa fa-check icon-check"></i>
  </button>
</div>

<style>
  .share-row{
    display:flex;
    align-items:center;
    gap:0.625rem;
    margin-top:2.5rem;
    padding-top:1.5rem;
    border-top:1px dashed var(--blue-soft);
  }
  .share-label{
    font-size:0.78rem;
    color:var(--muted);
  }
  .share-fb, .share-copy{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:2.1rem;
    height:2.1rem;
    flex-shrink:0;
    border-radius:50%;
    text-decoration:none;
    font-size:1rem;
    transition:background .15s, transform .15s;
  }
  .share-fb{
    background:#1877f2;
    color:#fff;
  }
  .share-fb:hover{background:#0d5fc7;transform:translateY(-1px);}
  .share-copy{
    background:var(--blue);
    color:#fff;
    border:none;
    cursor:pointer;
    padding:0;
    font-family:inherit;
  }
  .share-copy:hover{background:var(--blue-deep);transform:translateY(-1px);}
  .share-copy .icon-check{display:none;}
  .share-copy.copied{background:#2f9e5c;}
  .share-copy.copied .icon-link{display:none;}
  .share-copy.copied .icon-check{display:inline-flex;}
</style>

<script>
  // Registered once via astro:page-load (see StarfieldBackground.astro for why) so
  // the share row on every article still works after a client-side navigation.
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLAnchorElement>('.share-fb').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        window.open(btn.href, 'facebook-share', 'width=580,height=520,menubar=no,toolbar=no,location=no,status=no');
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-copy-link]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url ?? '';
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          return;
        }
        btn.classList.add('copied');
        window.setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });
  });
</script>
