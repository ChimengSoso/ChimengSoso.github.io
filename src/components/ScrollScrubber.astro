---
// Mobile-only section-index scrubber ("water-ripple" mini-map) for /knowledge articles.
// Desktop already has the sticky sidebar TOC (Layout.astro, shown >=1180px); this is its
// touch-screen counterpart, shown only where that TOC is hidden AND the primary input can't
// hover (i.e. real touch devices) -- so exactly one of the two navs is ever visible.
//
// Idle: hidden except a faint hint bar on the right edge. Press the right rail -> a compact,
// vertically-centred cluster of dots (one per <h2>) fades in; the dot nearest the finger swells
// (fisheye) and a bubble names that section. Dragging live-scrolls the page to the selected
// heading (snap-to-section); releasing keeps you there and fades everything out.
//
// No id/hash coupling with the TOC builder: we scroll by each heading's live document offset,
// so the two scripts stay independent. The starfield black-hole pointerdown handler returns
// early on knowledge pages (phase !== 'interactive'), so there's no conflict to exclude here.
---
<div class="scrubber" id="scrubber" aria-hidden="true">
  <span class="scrubber-hint"></span>
  <div class="scrubber-dots" id="scrubber-dots">
    <span class="scrubber-label" id="scrubber-label"></span>
  </div>
</div>

<style>
  .scrubber{
    display:none;
    position:fixed;
    top:0;
    right:0;
    /* >=44px touch target (WCAG 2.5.5 / Apple HIG) even though the dots are small */
    width:44px;
    height:100dvh;
    z-index:30;
    touch-action:none;
    cursor:ns-resize;
  }
  /* Show only on touch devices where the desktop TOC is hidden (<1180px), so the two
     never appear together. hover:none keeps it off narrow desktop/mouse windows. */
  @media (hover:none) and (max-width:1179.98px){
    .scrubber.has-headings{display:block;}
  }
  .scrubber-hint{
    position:absolute;
    left:50%;
    top:50%;
    width:3px;
    height:2.125rem;
    transform:translate(-50%,-50%);
    /* Blue, not white: the rail is anchored to the card's right edge (see layout()),
       so it sits over the white article surface, not the blue page background. */
    background:rgba(41,66,102,0.28);
    border-radius:3px;
    transition:opacity .3s;
  }
  .scrubber-dots{
    position:absolute;
    inset:0;
    opacity:0;
    transition:opacity .22s;
  }
  .scrubber.active .scrubber-dots{opacity:1;}
  .scrubber.active .scrubber-hint{opacity:0;}
  .scrubber-dot{
    position:absolute;
    border-radius:50%;
    background:var(--blue);
    transform:translate(-50%,-50%);
  }
  .scrubber-label{
    position:absolute;
    right:30px;
    max-width:11rem;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
    background:var(--blue-deep);
    color:#fff;
    font-weight:500;
    font-size:0.8rem;
    padding:0.35rem 0.7rem;
    border-radius:10px;
    opacity:0;
    transform:translateY(-50%);
    pointer-events:none;
    box-shadow:0 4px 14px rgba(19,30,48,0.35);
    transition:opacity .12s;
  }
  @media (prefers-reduced-motion: reduce){
    .scrubber-dots,.scrubber-hint,.scrubber-label{transition:none;}
  }
</style>

<script>
  const DOT_MIN = 5;
  const DOT_MAX = 15;
  const RIPPLE_R = 72;   // falloff radius of the fisheye "wave"
  const BULGE = 8;       // how far the swelling dots lean toward the content
  const GAP_MAX = 24;    // vertical spacing between dots (shrinks if too many to fit)
  const CX = 26;         // dot centre x within the 44px rail
  const HEAD_OFFSET = 16; // land a little below the very top when snapping to a heading

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initScrubber() {
    const railNode = document.getElementById('scrubber');
    const wrapNode = document.getElementById('scrubber-dots');
    const labelNode = document.getElementById('scrubber-label');
    if (!(railNode instanceof HTMLElement) || !(wrapNode instanceof HTMLElement) || !(labelNode instanceof HTMLElement)) return;
    // Re-bind to consts whose *declared* type is non-null HTMLElement, so the narrowing
    // holds inside the pointer-handler closures below (flow narrowing on the original
    // `| null` bindings doesn't propagate into nested functions on this TS version).
    const rail = railNode;
    const wrap = wrapNode;
    const label = labelNode;

    const headings = Array.from(document.querySelectorAll<HTMLElement>('.panel h2'));

    // Clear any dots from a previous page-load, then bail (and stay hidden) on thin articles.
    wrap.querySelectorAll('.scrubber-dot').forEach((d) => d.remove());
    rail.classList.remove('has-headings', 'active');
    if (headings.length < 2) return;
    rail.classList.add('has-headings');

    const dots = headings.map(() => {
      const d = document.createElement('span');
      d.className = 'scrubber-dot';
      wrap.appendChild(d);
      return d;
    });

    let dotY: number[] = [];
    let active = false;
    let lastSel = -1;

    const railH = () => rail.clientHeight;
    const headingTop = (h: HTMLElement) => h.getBoundingClientRect().top + window.scrollY;

    function layout() {
      // Anchor the rail's right edge to the article card's right edge, so it always sits
      // over the white surface (never the blue page gutter, whose width grows with the
      // viewport once the card hits its max-width) -- that's what keeps the blue dots legible.
      const panel = document.querySelector('.panel');
      const right = panel ? Math.max(0, window.innerWidth - panel.getBoundingClientRect().right) : 0;
      rail.style.right = `${right}px`;

      const n = headings.length;
      const gap = Math.min(GAP_MAX, (railH() - 40) / Math.max(1, n - 1));
      const clusterH = (n - 1) * gap;
      const top = (railH() - clusterH) / 2;
      dotY = headings.map((_, i) => top + i * gap);
      dots.forEach((d, i) => { d.style.top = `${dotY[i]}px`; });
    }

    function draw(cy: number): number {
      const lo = dotY[0];
      const hi = dotY[dotY.length - 1];
      const c = Math.min(hi, Math.max(lo, cy));
      let sel = Math.round((c - lo) / ((hi - lo) / Math.max(1, dotY.length - 1)));
      sel = Math.min(dotY.length - 1, Math.max(0, sel));
      dotY.forEach((y, i) => {
        const t = Math.max(0, 1 - Math.abs(y - c) / RIPPLE_R);
        const s = t * t * (3 - 2 * t);
        const size = DOT_MIN + (DOT_MAX - DOT_MIN) * s;
        const d = dots[i];
        d.style.width = `${size}px`;
        d.style.height = `${size}px`;
        d.style.left = `${CX - s * BULGE}px`;
        d.style.opacity = (0.4 + 0.6 * s).toFixed(2);
        d.style.background = i === sel ? '#294266' : '#4d72a9';
      });
      label.textContent = headings[sel].textContent;
      label.style.top = `${dotY[sel]}px`;
      label.style.opacity = '1';
      return sel;
    }

    function pick(clientY: number, dragging: boolean) {
      const rect = rail.getBoundingClientRect();
      const sel = draw(clientY - rect.top);
      if (sel === lastSel) return;
      lastSel = sel;
      if (navigator.vibrate) navigator.vibrate(6);
      const top = Math.max(0, headingTop(headings[sel]) - HEAD_OFFSET);
      if (dragging || reduce) {
        // Instant while scrubbing (keeps up with the finger) and for reduced-motion.
        // Can't rely on ScrollToOptions behavior:'auto' -- per spec that follows CSS, and
        // html{scroll-behavior:smooth} would make every jump a laggy animation. Force the
        // root to 'auto' for this one call, then restore.
        const root = document.documentElement;
        const prev = root.style.scrollBehavior;
        root.style.scrollBehavior = 'auto';
        window.scrollTo(0, top);
        root.style.scrollBehavior = prev;
      } else {
        window.scrollTo({ top, behavior: 'smooth' });
      }
    }

    function onDown(e: PointerEvent) {
      active = true;
      lastSel = -1;
      rail.classList.add('active');
      rail.setPointerCapture(e.pointerId);
      layout();
      pick(e.clientY, false);
      e.preventDefault();
    }
    function onMove(e: PointerEvent) {
      if (active) pick(e.clientY, true);
    }
    function onUp() {
      if (!active) return;
      active = false;
      rail.classList.remove('active');
      label.style.opacity = '0';
    }

    rail.addEventListener('pointerdown', onDown);
    rail.addEventListener('pointermove', onMove);
    rail.addEventListener('pointerup', onUp);
    rail.addEventListener('pointercancel', onUp);
    layout();
  }

  document.addEventListener('astro:page-load', initScrubber);
</script>
