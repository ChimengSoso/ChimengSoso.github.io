---
---
<canvas id="bg-canvas" aria-hidden="true" transition:persist transition:name="starfield-canvas"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    display: block;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.6s ease;
  }
  #bg-canvas.starfield-hidden {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    #bg-canvas {
      transition: none;
    }
  }
</style>

<script>
  const SPACING = 32;
  const JITTER = 24;
  const SKIP_PROBABILITY = 0.22;
  const SPRING = 0.02;
  const FRICTION = 0.90;
  const REPEL_RADIUS = 100;
  const REPEL_STRENGTH = 4.2;
  const PULL_RADIUS = 170;
  const BASE_PULL_STRENGTH = 2;
  const MAX_PULL_STRENGTH = 9;
  const PULL_RAMP_RATE = 0.004;
  const DRIFT_JITTER = 0.01;
  const DRIFT_DAMPING = 0.98;
  const SCATTER_FADE_MS = 750;
  const COLORS = ['#ffffff', '#eaf1fb', '#bcd3f8', '#8fb3e8'];

  interface Particle {
    homeX: number;
    homeY: number;
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    color: string;
    baseAlpha: number;
    twinkleSpeed: number;
    twinklePhase: number;
    twinkleAmt: number;
    // Once true, the particle permanently skips spring-to-home in favor of gentle
    // idle drift, until the next buildParticles() regenerates it fresh.
    floating: boolean;
    driftVx: number;
    driftVy: number;
    // Transient per-frame marker: true while inside an active black-hole pull,
    // consumed (and promoted to `floating`) on release.
    pulled: boolean;
  }

  interface ShootingStar {
    x: number;
    y: number;
    vx: number;
    vy: number;
    len: number;
    r: number;
    alpha: number;
    duration: number;
    startTime: number;
  }

  function createInitialState(canvas: HTMLCanvasElement) {
    const state = {
      canvas,
      ctx: canvas.getContext('2d')!,
      width: 0,
      height: 0,
      dpr: 1,
      particles: [] as Particle[],
      pointer: { x: -9999, y: -9999, active: false },
      blackhole: { active: false, x: -9999, y: -9999, startTime: 0 },
      shootingStars: [] as ShootingStar[],
      nextShootTime: performance.now() + 1500 + Math.random() * 3000,
      rafId: null as number | null,
      phase: 'hidden' as 'hidden' | 'interactive' | 'scattering',
      transitionGen: 0,
      reduceMotion: window.matchMedia('(prefers-reduced-motion: reduce)').matches,
    };
    // Bound once per canvas lifetime instead of allocating a new closure on every
    // requestAnimationFrame call (60/sec).
    return Object.assign(state, { tickFrame: (t: number) => tick(state, t) });
  }
  type StarfieldState = ReturnType<typeof createInitialState>;
  // `__starfield` is how state survives `transition:persist` across navigations --
  // the canvas DOM node is kept alive by Astro's router, but script-level closures
  // are not guaranteed to be, so everything mutable lives as a property on the node.
  type StarfieldCanvas = HTMLCanvasElement & { __starfield?: StarfieldState };

  // Force from a radial source acting on a particle at (px,py): positive `strength`
  // pushes the particle away from the source (repel), negative pulls it toward the
  // source (attract). Returns the velocity impulse to add, or null if the particle
  // is outside `radius` or within `minDist` of the source (avoids a jittery/undefined
  // direction when a particle sits almost exactly on top of the source).
  function radialForce(
    px: number, py: number,
    sourceX: number, sourceY: number,
    radius: number, strength: number,
    minDist = 0
  ): { vx: number; vy: number } | null {
    const dx = px - sourceX;
    const dy = py - sourceY;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist >= radius || dist <= minDist) return null;
    const force = (1 - dist / radius) * strength;
    return { vx: (dx / dist) * force, vy: (dy / dist) * force };
  }

  function buildParticles(state: StarfieldState) {
    const particles: Particle[] = [];
    const cols = Math.ceil(state.width / SPACING) + 1;
    const rows = Math.ceil(state.height / SPACING) + 1;
    for (let i = 0; i < cols; i++) {
      for (let j = 0; j < rows; j++) {
        if (Math.random() < SKIP_PROBABILITY) continue;
        const stagger = (j % 2) * (SPACING / 2);
        const homeX = i * SPACING + stagger + (Math.random() - 0.5) * JITTER;
        const homeY = j * SPACING + (Math.random() - 0.5) * JITTER;
        particles.push({
          homeX, homeY, x: homeX, y: homeY, vx: 0, vy: 0,
          r: 0.6 + Math.random() * 1.4,
          color: COLORS[(Math.random() * COLORS.length) | 0],
          baseAlpha: 0.18 + Math.random() * 0.3,
          twinkleSpeed: 0.6 + Math.random() * 1.4,
          twinklePhase: Math.random() * Math.PI * 2,
          twinkleAmt: 0.25 + Math.random() * 0.35,
          floating: false, driftVx: 0, driftVy: 0, pulled: false,
        });
      }
    }
    state.particles = particles;
  }

  function resize(state: StarfieldState) {
    state.width = window.innerWidth;
    state.height = window.innerHeight;
    state.dpr = window.devicePixelRatio || 1;
    state.canvas.width = state.width * state.dpr;
    state.canvas.height = state.height * state.dpr;
    state.canvas.style.width = state.width + 'px';
    state.canvas.style.height = state.height + 'px';
    state.ctx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
    buildParticles(state);
  }

  // Cached per hex color (only 4 ever exist) rather than building a fresh "rgba(...)"
  // string for every particle on every frame -- alpha is applied via ctx.globalAlpha
  // instead, so drawing a particle never allocates a string in the hot path.
  const colorStyleCache: Record<string, string> = {};
  function colorStyle(hex: string) {
    if (!colorStyleCache[hex]) {
      const n = parseInt(hex.slice(1), 16);
      colorStyleCache[hex] = `rgb(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255})`;
    }
    return colorStyleCache[hex];
  }

  function drawStatic(state: StarfieldState) {
    const { ctx, width, height, particles } = state;
    ctx.clearRect(0, 0, width, height);
    for (const p of particles) {
      ctx.globalAlpha = p.baseAlpha;
      ctx.fillStyle = colorStyle(p.color);
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }

  function spawnOneShootingStar(state: StarfieldState, spawnAt: number) {
    const angle = (20 + Math.random() * 30) * Math.PI / 180;
    const speed = 9 + Math.random() * 6;
    state.shootingStars.push({
      x: state.width * (0.45 + Math.random() * 0.55),
      y: state.height * (0.05 + Math.random() * 0.6),
      vx: -Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      len: 60 + Math.random() * 70,
      r: 1.3 + Math.random() * 1.1,
      alpha: 0,
      duration: 1100 + Math.random() * 900,
      startTime: spawnAt,
    });
  }

  function maybeSpawnShootingStars(state: StarfieldState, now: number) {
    if (now < state.nextShootTime) return;
    const r = Math.random();
    const count = r < 0.55 ? 1 : r < 0.8 ? 2 : r < 0.93 ? 3 : 4;
    for (let i = 0; i < count; i++) spawnOneShootingStar(state, now + Math.random() * 350);
    state.nextShootTime = now + 3000 + Math.random() * 7000;
  }

  function drawShootingStar(state: StarfieldState, star: ShootingStar) {
    const { ctx } = state;
    const mag = Math.sqrt(star.vx * star.vx + star.vy * star.vy);
    const tailX = star.x - (star.vx / mag) * star.len;
    const tailY = star.y - (star.vy / mag) * star.len;
    const grad = ctx.createLinearGradient(star.x, star.y, tailX, tailY);
    grad.addColorStop(0, `rgba(255,255,255,${star.alpha})`);
    grad.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.strokeStyle = grad;
    ctx.lineWidth = star.r;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(star.x, star.y);
    ctx.lineTo(tailX, tailY);
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(star.x, star.y, star.r * 1.3, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(255,255,255,${star.alpha})`;
    ctx.fill();
  }

  function updateShootingStars(state: StarfieldState, time: number) {
    maybeSpawnShootingStars(state, time);
    for (let s = state.shootingStars.length - 1; s >= 0; s--) {
      const star = state.shootingStars[s];
      if (time < star.startTime) continue;
      const progress = (time - star.startTime) / star.duration;
      if (progress >= 1) {
        state.shootingStars.splice(s, 1);
        continue;
      }
      star.x += star.vx;
      star.y += star.vy;
      star.alpha = Math.sin(progress * Math.PI);
      drawShootingStar(state, star);
    }
  }

  // Radial outward burst used when leaving `/` for a plain reading page -- overwrites
  // velocity directly (rather than nudging it) so every particle visibly blows away from
  // center regardless of whatever spring/drift state it was previously in.
  function scatterParticlesOutward(state: StarfieldState) {
    const cx = state.width / 2;
    const cy = state.height / 2;
    for (const p of state.particles) {
      let dx = p.x - cx;
      let dy = p.y - cy;
      const dist = Math.hypot(dx, dy);
      if (dist < 0.01) {
        const angle = Math.random() * Math.PI * 2;
        dx = Math.cos(angle);
        dy = Math.sin(angle);
      } else {
        dx /= dist;
        dy /= dist;
      }
      const speed = 3 + Math.random() * 4;
      p.vx = dx * speed;
      p.vy = dy * speed;
    }
  }

  function tick(state: StarfieldState, time: number) {
    const { ctx, width, height, particles } = state;
    ctx.clearRect(0, 0, width, height);
    for (const p of particles) {
      if (state.blackhole.active) {
        const holdMs = performance.now() - state.blackhole.startTime;
        const strength = Math.min(MAX_PULL_STRENGTH, BASE_PULL_STRENGTH + holdMs * PULL_RAMP_RATE);
        // Negative strength: radialForce's sign convention is positive = repel, so
        // pulling toward the black hole is the negated (attracting) case.
        const pull = radialForce(p.x, p.y, state.blackhole.x, state.blackhole.y, PULL_RADIUS, -strength);
        if (pull) {
          p.vx += pull.vx;
          p.vy += pull.vy;
          p.pulled = true;
        }
      }

      if (state.pointer.active) {
        const repel = radialForce(p.x, p.y, state.pointer.x, state.pointer.y, REPEL_RADIUS, REPEL_STRENGTH, 0.01);
        if (repel) {
          p.vx += repel.vx;
          p.vy += repel.vy;
        }
      }

      // While scattering out, every particle blows outward uniformly -- skip both the
      // spring-home and floating-drift branches so a mid-flight black-hole release
      // can't leave stragglers behind during the page transition.
      if (state.phase !== 'scattering') {
        if (p.floating) {
          p.driftVx += (Math.random() - 0.5) * DRIFT_JITTER;
          p.driftVy += (Math.random() - 0.5) * DRIFT_JITTER;
          p.driftVx *= DRIFT_DAMPING;
          p.driftVy *= DRIFT_DAMPING;
          p.vx += p.driftVx;
          p.vy += p.driftVy;
        } else {
          p.vx += (p.homeX - p.x) * SPRING;
          p.vy += (p.homeY - p.y) * SPRING;
        }
      }

      p.vx *= FRICTION;
      p.vy *= FRICTION;
      p.x += p.vx;
      p.y += p.vy;

      const twinkle = Math.sin(time * 0.001 * p.twinkleSpeed + p.twinklePhase) * p.twinkleAmt;
      const alpha = Math.max(0, Math.min(1, p.baseAlpha + twinkle));
      ctx.globalAlpha = alpha;
      ctx.fillStyle = colorStyle(p.color);
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;

    updateShootingStars(state, time);
    state.rafId = requestAnimationFrame(state.tickFrame);
  }

  function pauseLoop(state: StarfieldState) {
    if (state.rafId !== null) {
      cancelAnimationFrame(state.rafId);
      state.rafId = null;
    }
  }

  function resumeLoop(state: StarfieldState) {
    if (state.rafId === null && !state.reduceMotion) {
      state.rafId = requestAnimationFrame(state.tickFrame);
    }
  }

  function setCanvasVisible(state: StarfieldState, visible: boolean) {
    state.canvas.classList.toggle('starfield-hidden', !visible);
  }

  function releaseBlackhole(state: StarfieldState) {
    if (!state.blackhole.active) return;
    state.blackhole.active = false;
    for (const p of state.particles) {
      if (p.pulled) {
        p.floating = true;
        p.driftVx = (Math.random() - 0.5) * 0.15;
        p.driftVy = (Math.random() - 0.5) * 0.15;
        p.pulled = false;
      }
    }
  }

  function attachGlobalPointerListeners(state: StarfieldState) {
    window.addEventListener('mousemove', (e) => {
      state.pointer.x = e.clientX;
      state.pointer.y = e.clientY;
      state.pointer.active = true;
    });
    document.addEventListener('mouseout', (e) => {
      if (!e.relatedTarget) state.pointer.active = false;
    });
    window.addEventListener('touchmove', (e) => {
      if (e.touches && e.touches[0]) {
        state.pointer.x = e.touches[0].clientX;
        state.pointer.y = e.touches[0].clientY;
        state.pointer.active = true;
      }
    }, { passive: true });
    window.addEventListener('touchend', () => { state.pointer.active = false; });
    window.addEventListener('touchcancel', () => { state.pointer.active = false; });

    // Black hole only engages on the home page (phase 'interactive'); on knowledge
    // pages the canvas is paused/invisible so there'd be nothing to pull anyway, and
    // ignoring pointerdown inside .profile keeps it from fighting the tilt-card.
    window.addEventListener('pointerdown', (e) => {
      if (state.phase !== 'interactive') return;
      if ((e.target as HTMLElement).closest?.('.profile')) return;
      // Dragging the black hole across the page would otherwise start the browser's
      // native text/image selection drag -- suppress it since this is a click-and-hold
      // gesture, not a selection.
      e.preventDefault();
      state.blackhole.active = true;
      state.blackhole.x = e.clientX;
      state.blackhole.y = e.clientY;
      state.blackhole.startTime = performance.now();
    });
    window.addEventListener('pointermove', (e) => {
      if (state.blackhole.active) {
        state.blackhole.x = e.clientX;
        state.blackhole.y = e.clientY;
      }
    });
    window.addEventListener('pointerup', () => releaseBlackhole(state));
    window.addEventListener('pointercancel', () => releaseBlackhole(state));

    let resizeTimer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener('resize', () => {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        resize(state);
        if (state.phase === 'interactive') {
          if (state.reduceMotion) drawStatic(state); else resumeLoop(state);
        }
      }, 150);
    });
  }

  // Fires after every client-side navigation (Astro's View Transitions router), and
  // once on the very first load -- covers both cases with a single listener.
  function initOrResume() {
    const canvas = document.getElementById('bg-canvas') as StarfieldCanvas | null;
    if (!canvas || !canvas.getContext) return;
    const mode = document.body.dataset.bg === 'plain' ? 'plain' : 'interactive';

    const existing = canvas.__starfield;
    if (!existing) {
      const state = createInitialState(canvas);
      canvas.__starfield = state;
      attachGlobalPointerListeners(state);
      resize(state);
      if (mode === 'plain') {
        state.phase = 'hidden';
        setCanvasVisible(state, false);
      } else {
        state.phase = 'interactive';
        setCanvasVisible(state, true);
        if (state.reduceMotion) drawStatic(state); else resumeLoop(state);
      }
      return;
    }

    applyPageMode(existing, mode);
  }

  function applyPageMode(state: StarfieldState, mode: 'interactive' | 'plain') {
    const myGen = ++state.transitionGen;
    if (mode === 'interactive') {
      if (state.phase === 'interactive') return;
      buildParticles(state);
      state.phase = 'interactive';
      setCanvasVisible(state, true);
      if (state.reduceMotion) drawStatic(state); else resumeLoop(state);
    } else {
      if (state.phase !== 'interactive') return;
      state.phase = 'scattering';
      scatterParticlesOutward(state);
      setCanvasVisible(state, false);
      const finish = () => {
        if (state.transitionGen !== myGen) return;
        state.phase = 'hidden';
        pauseLoop(state);
      };
      if (state.reduceMotion) finish(); else setTimeout(finish, SCATTER_FADE_MS);
    }
  }

  document.addEventListener('astro:page-load', initOrResume);
</script>
