---
---
<button type="button" class="donate-fab" id="donate-fab" aria-haspopup="dialog" aria-controls="donate-dialog">
  <span class="donate-fab-emoji" aria-hidden="true">🍲</span>
  <span class="donate-fab-text">เลี้ยงชาบูผมหน่อย</span>
</button>

<dialog id="donate-dialog" class="donate-dialog" aria-labelledby="donate-title">
  <form method="dialog" class="donate-form">
    <button type="submit" class="donate-close" aria-label="ปิดหน้าต่างนี้">&times;</button>
    <h2 id="donate-title" class="donate-title">เลี้ยงชาบูผมสักมื้อ 🍲</h2>
    <p class="donate-desc">
      เดิมทีปุ่มนี้ควรจะเป็น "เลี้ยงกาแฟ" ตามธรรมเนียม แต่ผมไม่ค่อยกินกาแฟ
      ถ้าเนื้อหาในเว็บนี้มีประโยชน์กับใครบ้าง อยากเลี้ยงชาบูแทนก็โอนผ่าน PromptPay ได้เลยครับ
    </p>
    <img
      src="/promptpay.jpg"
      alt="PromptPay QR code สำหรับโอนเงินให้ ChimengSoso เบอร์ 061-068-8064"
      class="donate-qr"
      loading="lazy"
    />
    <div class="donate-detail">
      <div class="donate-detail-row">
        <span class="donate-detail-label">พร้อมเพย์</span>
        <span class="donate-detail-value">061-068-8064</span>
        <button type="button" class="donate-copy" data-copy-value="0610688064" title="คัดลอกเบอร์พร้อมเพย์" aria-label="คัดลอกเบอร์พร้อมเพย์">
          <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </button>
      </div>
      <div class="donate-detail-row">
        <span class="donate-detail-label">ชื่อบัญชี</span>
        <span class="donate-detail-value">วรกันต์ อะทะ</span>
      </div>
      <div class="donate-detail-row">
        <span class="donate-detail-label">ธนาคาร</span>
        <span class="donate-detail-value">ไทยพาณิชย์ (SCB)</span>
      </div>
    </div>
    <p class="donate-thanks">ขอบคุณที่แวะมาอ่านนะครับ 🙏</p>
  </form>
</dialog>

<style>
  .donate-fab{
    position:fixed;
    right:1.25rem;
    bottom:1.25rem;
    z-index:40;
    display:inline-flex;
    align-items:center;
    width:3.1rem;
    height:3.1rem;
    justify-content:center;
    background:var(--blue-deep);
    color:#fff;
    border:none;
    border-radius:999px;
    padding:0;
    overflow:hidden;
    font-family:"Sarabun",system-ui,sans-serif;
    font-size:0.85rem;
    font-weight:600;
    cursor:pointer;
    box-shadow:0 10px 24px -6px rgba(22,63,120,0.55);
    animation:donate-nudge 9s ease-in-out infinite;
    transition:width .3s cubic-bezier(.16,1,.3,1), background .15s ease, box-shadow .15s ease, transform .15s ease;
  }
  .donate-fab:hover,
  .donate-fab:focus-visible{
    /* Deliberately generous and fixed (not measured) -- an exact pixel-fit computed
       from the rendered text risked subpixel rounding clipping the trailing glyph
       (dropped ู / ย). A little empty space on the right costs nothing visually. */
    width:13.5rem;
    justify-content:flex-start;
    padding:0 1rem 0 0.95rem;
    background:var(--blue-shadow);
    transform:translateY(-2px);
    box-shadow:0 14px 28px -6px rgba(22,63,120,0.65);
    animation-play-state:paused;
  }
  .donate-fab-emoji{
    font-size:1.85rem;
    line-height:1;
    flex-shrink:0;
    font-family:"Apple Color Emoji","Segoe UI Emoji","Noto Color Emoji",system-ui,sans-serif;
  }
  .donate-fab-text{
    max-width:0;
    overflow:hidden;
    opacity:0;
    white-space:nowrap;
    margin-left:0;
    transition:max-width .3s cubic-bezier(.16,1,.3,1), opacity .2s ease, margin-left .3s cubic-bezier(.16,1,.3,1);
  }
  .donate-fab:hover .donate-fab-text,
  .donate-fab:focus-visible .donate-fab-text{
    max-width:none;
    margin-left:0.5rem;
    opacity:1;
  }
  @keyframes donate-nudge{
    0%, 82%, 100%{transform:scale(1) rotate(0deg);}
    85%{transform:scale(1.1) rotate(-6deg);}
    88%{transform:scale(1.1) rotate(6deg);}
    91%{transform:scale(1.04) rotate(-3deg);}
    94%{transform:scale(1) rotate(0deg);}
  }
  @media (prefers-reduced-motion: reduce){
    .donate-fab{animation:none;}
  }
  @media (hover:none){
    .donate-fab:hover{
      width:3.1rem;
      justify-content:center;
      padding:0;
      transform:none;
    }
    .donate-fab:hover .donate-fab-text{max-width:0;margin-left:0;opacity:0;}
  }

  .donate-dialog{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    margin:0;
    border:none;
    border-radius:20px;
    padding:0;
    width:min(22rem, 90vw);
    max-height:85vh;
    overflow-y:auto;
    box-shadow:0 24px 48px -12px rgba(19,30,48,0.45);
  }
  .donate-dialog::backdrop{
    background:rgba(19,30,48,0.55);
    backdrop-filter:blur(2px);
  }
  .donate-form{
    position:relative;
    padding:1.75rem 1.5rem 1.5rem;
    font-family:"Sarabun",system-ui,sans-serif;
  }
  .donate-close{
    position:absolute;
    top:0.75rem;
    right:0.85rem;
    background:none;
    border:none;
    font-size:1.5rem;
    line-height:1;
    color:var(--muted);
    cursor:pointer;
    padding:0.25rem;
  }
  .donate-close:hover{color:var(--ink);}
  .donate-title{
    font-size:1.15rem;
    font-weight:700;
    color:var(--ink);
    margin:0 1.5rem 0.6rem 0;
  }
  .donate-desc{
    font-size:0.85rem;
    color:var(--muted);
    line-height:1.65;
    margin:0 0 1.1rem;
  }
  .donate-qr{
    display:block;
    width:100%;
    max-width:14rem;
    margin:0 auto 1.1rem;
    border-radius:14px;
    border:1px solid var(--blue-soft);
  }
  .donate-detail{
    background:var(--blue-tint);
    border-radius:12px;
    padding:0.9rem 1rem;
    margin-bottom:1rem;
  }
  .donate-detail-row{
    display:flex;
    align-items:center;
    gap:0.5rem;
    font-size:0.85rem;
    padding:0.3rem 0;
  }
  .donate-detail-row + .donate-detail-row{border-top:1px dashed var(--blue-soft);}
  .donate-detail-label{color:var(--muted);flex-shrink:0;width:5rem;}
  .donate-detail-value{color:var(--ink);font-weight:600;flex:1;}
  .donate-copy{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:1.75rem;
    height:1.75rem;
    flex-shrink:0;
    background:#fff;
    border:1px solid var(--blue-soft);
    border-radius:6px;
    color:var(--blue-deep);
    cursor:pointer;
    transition:border-color .15s, color .15s, background .15s;
  }
  .donate-copy:hover{border-color:var(--blue);color:var(--blue-shadow);}
  .donate-copy .icon-check{display:none;}
  .donate-copy.copied{background:#eafaf0;border-color:#2f9e5c;color:#1f7a45;}
  .donate-copy.copied .icon-copy{display:none;}
  .donate-copy.copied .icon-check{display:inline-flex;}
  .donate-thanks{
    font-size:0.82rem;
    color:var(--muted);
    text-align:center;
    margin:0;
  }
</style>

<script>
  const fab = document.getElementById('donate-fab') as HTMLButtonElement | null;
  const dialog = document.getElementById('donate-dialog') as HTMLDialogElement | null;

  fab?.addEventListener('click', () => dialog?.showModal());

  dialog?.addEventListener('click', (e) => {
    const rect = dialog.getBoundingClientRect();
    const inside =
      e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
    if (!inside) dialog.close();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy-value]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.dataset.copyValue ?? '';
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        return;
      }
      btn.classList.add('copied');
      window.setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>
