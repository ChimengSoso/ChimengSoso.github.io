---
---
<button type="button" class="donate-fab" id="donate-fab" aria-haspopup="dialog" aria-controls="donate-dialog">
  <span class="donate-fab-emoji" aria-hidden="true">🍲</span>
  <span class="donate-fab-text">เลี้ยงชาบูผมหน่อย</span>
</button>

<dialog id="donate-dialog" class="donate-dialog" aria-labelledby="donate-title">
  <form class="donate-form">
    <button type="button" class="donate-close" aria-label="ปิดหน้าต่างนี้">&times;</button>
    <h2 id="donate-title" class="donate-title">เลี้ยงชาบูผมสักมื้อ 🍲</h2>
    <p class="donate-desc">
      ถ้าเรื่องราวในเว็บนี้พอทำให้วันของคุณอุ่นขึ้นสักนิด แล้วอยากส่งกำลังใจกลับมาบ้าง
      สแกน PromptPay ด้านล่างได้เลยครับ เท่าไหร่ก็ได้ ทุกน้ำใจอบอุ่นเสมอ 🍲
    </p>
    <div class="donate-qr-frame">
      <img
        src="/promptpay-qr.png"
        alt="PromptPay QR code สำหรับโอนเงินให้ ChimengSoso เบอร์ 061-068-8064"
        class="donate-qr"
        loading="lazy"
      />
    </div>
    <div class="donate-detail">
      <div class="donate-detail-row">
        <span class="donate-detail-label">พร้อมเพย์</span>
        <span class="donate-detail-value">061-068-8064</span>
        <button type="button" class="donate-copy" data-copy-value="0610688064" title="คัดลอกเบอร์พร้อมเพย์" aria-label="คัดลอกเบอร์พร้อมเพย์">
          <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </button>
      </div>
      <div class="donate-detail-row">
        <span class="donate-detail-label">ชื่อบัญชี</span>
        <span class="donate-detail-value">วรกันต์ อะทะ<br /><span class="donate-detail-en">Worakun Ata</span></span>
      </div>
      <div class="donate-detail-row">
        <span class="donate-detail-label">ธนาคาร</span>
        <span class="donate-detail-value">ไทยพาณิชย์ (SCB)</span>
      </div>
    </div>
    <p class="donate-thanks">ขอบคุณที่แวะมาอ่านนะครับ 🙏</p>
  </form>
</dialog>

<style>
  .donate-fab{
    position:fixed;
    right:1.25rem;
    bottom:1.25rem;
    z-index:40;
    display:inline-flex;
    align-items:center;
    width:3.1rem;
    height:3.1rem;
    justify-content:center;
    background:var(--blue-deep);
    color:#fff;
    border:none;
    border-radius:999px;
    padding:0;
    overflow:hidden;
    font-family:"Sarabun",system-ui,sans-serif;
    font-size:0.85rem;
    font-weight:600;
    cursor:pointer;
    box-shadow:0 10px 24px -6px rgba(22,63,120,0.55);
    animation:donate-nudge 9s ease-in-out infinite;
    transition:width .3s cubic-bezier(.16,1,.3,1), background .15s ease, box-shadow .15s ease;
  }
  .donate-fab:hover,
  .donate-fab:focus-visible{
    /* Deliberately generous and fixed (not measured) -- an exact pixel-fit computed
       from the rendered text risked subpixel rounding clipping the trailing glyph. */
    width:13.5rem;
    justify-content:flex-start;
    padding:0 1rem 0 0.95rem;
    background:var(--blue-shadow);
    box-shadow:0 14px 28px -6px rgba(22,63,120,0.65);
    /* No `transform` here on purpose (not even a hover lift) -- animating or even just
       setting `transform` on this element forces the label text onto its own
       GPU-composited layer, and thin Thai vowel/tone marks (สระอู, etc.) were being
       lost whenever that happened. Stop the wiggle outright instead of pausing it,
       since a paused animation still overrides `transform` with its frozen keyframe. */
    animation:none;
  }
  .donate-fab-emoji{
    font-size:1.85rem;
    line-height:1;
    flex-shrink:0;
    font-family:"Apple Color Emoji","Segoe UI Emoji","Noto Color Emoji",system-ui,sans-serif;
  }
  .donate-fab-text{
    max-width:0;
    overflow-x:hidden;
    overflow-y:visible;
    line-height:2;
    white-space:nowrap;
    margin-left:0;
    /* overflow-y must stay visible, not hidden: Sarabun's stacked Thai tone/vowel
       marks (ไม้โท, สระอู, etc.) sit taller/lower than the "normal" line-height box,
       so a tight `overflow:hidden` here was slicing the tops/bottoms off them even
       though the parent pill (.donate-fab) is 3.1rem tall and has plenty of headroom
       to contain them uncropped. The extra `line-height` gives the marks room to
       clear the glyph's own em-box before the (still horizontally clipped) edge.
       No transition on max-width/margin-left either, and no `opacity` -- animating
       this box at the same time the parent pill animates its `width` double-clips
       the text while it's mid-reflow, which was a second source of the same missing-
       chunk symptom. This box switches state instantly on :hover; the parent's
       `width` transition + `overflow:hidden` is the only moving clip edge. */
  }
  .donate-fab:hover .donate-fab-text,
  .donate-fab:focus-visible .donate-fab-text{
    max-width:none;
    margin-left:0.5rem;
  }
  @keyframes donate-nudge{
    0%, 82%, 100%{transform:scale(1) rotate(0deg);}
    85%{transform:scale(1.1) rotate(-6deg);}
    88%{transform:scale(1.1) rotate(6deg);}
    91%{transform:scale(1.04) rotate(-3deg);}
    94%{transform:scale(1) rotate(0deg);}
  }
  @media (prefers-reduced-motion: reduce){
    .donate-fab{animation:none;}
  }
  @media (hover:none){
    .donate-fab:hover{
      width:3.1rem;
      justify-content:center;
      padding:0;
    }
    .donate-fab:hover .donate-fab-text{max-width:0;margin-left:0;}
  }

  .donate-dialog{
    position:fixed;
    top:50%;
    left:50%;
    margin:0;
    border:none;
    border-radius:20px;
    padding:0;
    width:min(22rem, 90vw);
    max-height:85vh;
    overflow-y:auto;
    box-shadow:0 24px 48px -12px rgba(19,30,48,0.45);
    opacity:1;
    transform:translate(-50%, -50%) scale(1);
    /* Declared here (not just read via var() below) so static CSS analysis can resolve
       them; JS overrides both per open/close via inline style to aim the genie origin. */
    --genie-x:0px;
    --genie-y:0px;
    /* No default transition -- JS sets direction-specific easing:
       open = decelerate (maximize feel), close = accelerate (minimize feel).
       The inline style is cleared after each animation so nothing leaks. */
  }
  .donate-dialog.donate-dialog-enter,
  .donate-dialog.donate-dialog-exit{
    opacity:0;
    /* --genie-x/--genie-y point the shrunk dialog at the FAB's screen position.
       JS sets these just before each open/close so the genie origin is accurate. */
    transform:translate(calc(-50% + var(--genie-x, 0px)), calc(-50% + var(--genie-y, 0px))) scale(0.1);
  }
  .donate-dialog::backdrop{
    background:rgba(19,30,48,0.55);
    backdrop-filter:blur(2px);
    opacity:1;
    transition:opacity .22s ease;
  }
  .donate-dialog.donate-dialog-enter::backdrop,
  .donate-dialog.donate-dialog-exit::backdrop{
    opacity:0;
  }
  @media (prefers-reduced-motion: reduce){
    .donate-dialog::backdrop{transition:none;}
  }
  .donate-form{
    position:relative;
    padding:1.75rem 1.5rem 1.5rem;
    font-family:"Sarabun",system-ui,sans-serif;
  }
  .donate-close{
    position:absolute;
    top:0.75rem;
    right:0.85rem;
    background:none;
    border:none;
    font-size:1.5rem;
    line-height:1;
    color:var(--muted);
    cursor:pointer;
    padding:0.25rem;
  }
  .donate-close:hover{color:var(--ink);}
  .donate-title{
    font-size:1.15rem;
    font-weight:700;
    color:var(--ink);
    margin:0 1.5rem 0.6rem 0;
  }
  .donate-desc{
    font-size:0.85rem;
    color:var(--muted);
    line-height:1.65;
    margin:0 0 1.1rem;
  }
  .donate-qr-frame{
    max-width:14rem;
    margin:0 auto 1.1rem;
    padding:0.5rem;
    border-radius:20px;
    background:linear-gradient(135deg, var(--blue), var(--blue-deep) 55%, var(--blue-shadow));
    box-shadow:0 12px 24px -8px rgba(15,44,86,0.35);
  }
  .donate-qr{
    display:block;
    width:100%;
    border-radius:14px;
  }
  .donate-detail{
    background:var(--blue-tint);
    border-radius:12px;
    padding:0.9rem 1rem;
    margin-bottom:1rem;
  }
  .donate-detail-row{
    display:flex;
    align-items:center;
    gap:0.5rem;
    font-size:0.85rem;
    padding:0.3rem 0;
  }
  .donate-detail-row + .donate-detail-row{border-top:1px dashed var(--blue-soft);}
  .donate-detail-label{color:var(--muted);flex-shrink:0;width:5rem;}
  .donate-detail-en{color:var(--muted);font-weight:500;}
  .donate-detail-value{color:var(--ink);font-weight:600;flex:1;}
  .donate-copy{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:1.75rem;
    height:1.75rem;
    flex-shrink:0;
    background:#fff;
    border:1px solid var(--blue-soft);
    border-radius:6px;
    color:var(--blue-deep);
    cursor:pointer;
    transition:border-color .15s, color .15s, background .15s;
  }
  .donate-copy:hover{border-color:var(--blue);color:var(--blue-shadow);}
  .donate-copy .icon-check{display:none;}
  .donate-copy.copied{background:#eafaf0;border-color:#2f9e5c;color:#1f7a45;}
  .donate-copy.copied .icon-copy{display:none;}
  .donate-copy.copied .icon-check{display:inline-flex;}
  .donate-thanks{
    font-size:0.82rem;
    color:var(--muted);
    text-align:center;
    margin:0;
  }
</style>

<script>
  // Registered once via astro:page-load (see StarfieldBackground.astro for why) --
  // DonateButton is not transition:persist'ed, so every navigation swaps in a fresh
  // fab/dialog pair that needs its own listeners bound, not just the first one ever
  // seen when this module first evaluated.
  document.addEventListener('astro:page-load', () => {
  const fab = document.getElementById('donate-fab') as HTMLButtonElement | null;
  const dialog = document.getElementById('donate-dialog') as HTMLDialogElement | null;
  const closeBtn = document.querySelector('.donate-close') as HTMLButtonElement | null;
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!fab || !dialog) return;

  function aimGenieAtFab() {
    if (!fab || !dialog) return;
    const fabRect = fab.getBoundingClientRect();
    const dialogRect = dialog.getBoundingClientRect();
    const dx = (fabRect.left + fabRect.width / 2) - (dialogRect.left + dialogRect.width / 2);
    const dy = (fabRect.top + fabRect.height / 2) - (dialogRect.top + dialogRect.height / 2);
    dialog.style.setProperty('--genie-x', `${dx}px`);
    dialog.style.setProperty('--genie-y', `${dy}px`);
  }

  fab?.addEventListener('click', () => {
    if (!dialog) return;
    dialog.showModal();
    if (reducedMotion) return;
    aimGenieAtFab();
    dialog.classList.add('donate-dialog-enter');
    dialog.getBoundingClientRect(); // force layout so browser registers the enter state
    // Double rAF: first frame fires before paint (browser hasn't committed enter state),
    // second frame fires after -- only then is there a painted "from" state to transition
    // away from. Single rAF skips the paint and the dialog pops straight to final.
    requestAnimationFrame(() => requestAnimationFrame(() => {
      // Open = decelerate: bursts out of FAB quickly, settles gently into center (maximize feel).
      // Inline style is cleared after the animation so it doesn't interfere with close.
      dialog.style.transition = 'opacity .36s ease-out, transform .42s cubic-bezier(0,0,0.2,1)';
      dialog.classList.remove('donate-dialog-enter');
      function onOpenEnd(e: TransitionEvent) {
        // Re-guard: TS drops the outer non-null narrowing inside this hoisted
        // function declaration (same reason aimGenieAtFab guards `dialog`).
        if (!dialog || e.propertyName !== 'transform') return;
        dialog.removeEventListener('transitionend', onOpenEnd);
        dialog.style.transition = '';
      }
      dialog.addEventListener('transitionend', onOpenEnd);
    }));
  });

  function closeWithAnimation() {
    if (!dialog || !dialog.open || dialog.classList.contains('donate-dialog-exit')) return;
    if (reducedMotion) { dialog.close(); return; }
    aimGenieAtFab();
    // Close = accelerate: starts gently then rushes into the FAB (minimize feel).
    // Duration (.25s) is slightly longer than the backdrop (.22s) so that dialog.close()
    // is called only after the backdrop has already faded out completely.
    dialog.style.transition = 'opacity .22s ease-in, transform .25s cubic-bezier(0.36,0,0.66,0)';
    dialog.classList.add('donate-dialog-exit');
    function onCloseEnd(e: TransitionEvent) {
      // Re-guard: TS drops the outer non-null narrowing inside this hoisted
      // function declaration (same reason aimGenieAtFab guards `dialog`).
      if (!dialog || e.propertyName !== 'transform') return;
      dialog.removeEventListener('transitionend', onCloseEnd);
      dialog.classList.remove('donate-dialog-exit');
      dialog.style.transition = '';
      dialog.close();
    }
    dialog.addEventListener('transitionend', onCloseEnd);
  }

  closeBtn?.addEventListener('click', closeWithAnimation);

  dialog?.addEventListener('cancel', (e) => {
    e.preventDefault();
    closeWithAnimation();
  });

  dialog?.addEventListener('click', (e) => {
    const rect = dialog.getBoundingClientRect();
    const inside =
      e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
    if (!inside) closeWithAnimation();
  });

  document.querySelectorAll<HTMLButtonElement>('[data-copy-value]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.dataset.copyValue ?? '';
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        return;
      }
      btn.classList.add('copied');
      window.setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
  });
</script>
