---
---
<div class="secret-progress" id="secret-progress" hidden aria-hidden="true"></div>
<div class="secret-console-overlay" id="secret-console" hidden>
  <div class="secret-console-window" role="dialog" aria-modal="true" aria-label="Divine gatekeeper console">
    <div class="secret-console-header">
      <span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span>
      <span class="secret-console-title">gatekeeper@chi</span>
    </div>
    <div class="secret-console-log" id="secret-console-log"></div>
    <form class="secret-console-form" id="secret-console-form" autocomplete="off">
      <span class="secret-console-prompt" id="secret-console-prompt-label">username:</span>
      <input class="secret-console-input" id="secret-console-input" type="text" autocomplete="off" spellcheck="false" />
      <button type="button" class="secret-console-eye" id="secret-console-eye" hidden aria-label="แสดง/ซ่อน password">
        <svg id="secret-console-eye-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </button>
    </form>
    <div class="secret-console-hint">กด Esc หรือคลิกนอกกรอบนี้เพื่อออก</div>
  </div>
</div>

<style>
  .secret-progress {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 90;
    background: rgba(20, 26, 41, 0.85);
    border: 1px solid #2a3350;
    border-radius: 8px;
    padding: 0.4rem 0.7rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: #9aa7bd;
  }
  .secret-progress[hidden] { display: none; }
  .secret-console-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 10, 20, 0.75);
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .secret-console-overlay[hidden] { display: none; }
  .secret-console-overlay.is-visible { opacity: 1; }
  .secret-console-window {
    width: min(32rem, 100%);
    background: #1c2536;
    border: 1px solid #2a3350;
    border-radius: 14px;
    overflow: hidden;
    font-family: "JetBrains Mono", monospace;
    box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.6);
    transform: scale(0.94) translateY(10px);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .secret-console-overlay.is-visible .secret-console-window {
    transform: scale(1) translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .secret-console-overlay, .secret-console-window { transition: none; }
  }
  .secret-console-header {
    display: flex;
    align-items: center;
    gap: .6rem;
    background: #141a29;
    padding: .55rem .75rem .55rem .9rem;
    border-bottom: 1px solid #2a3350;
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; display: block; }
  .dot-red { background: #ff5f56; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #27c93f; }
  .secret-console-title {
    margin-left: .25rem;
    font-size: .72rem;
    color: #7b869c;
  }
  .secret-console-log {
    padding: 1rem 1.1rem 0;
    color: #e7ecf6;
    font-size: 0.85rem;
    line-height: 1.7;
    max-height: 40vh;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  /* :global() is required here -- these classes are assigned to <div>s
     created at runtime via document.createElement, which never receive
     Astro's scoped-style data-astro-cid-* attribute the way elements
     written directly in this component's template do. Without :global(),
     these selectors compile to require that attribute on .log-denied etc.
     too, so they silently never match anything created by appendLog(). */
  .secret-console-log :global(.log-denied) { color: #ff6b6b; }
  .secret-console-log :global(.log-granted) { color: #4ade80; }
  .secret-console-log :global(.log-info) { color: #7b869c; }
  .secret-console-log :global(.log-checking) {
    color: #9aa7bd;
    animation: secret-console-pulse 1s ease-in-out infinite;
  }
  @keyframes secret-console-pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .secret-console-log :global(.log-checking) { animation: none; }
  }
  .secret-console-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    /* no top padding + same line-height as the log: the active prompt row
       reads as just the next log line, not a separate distant block */
    padding: 0 1.1rem 0.9rem;
    color: #e7ecf6;
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .secret-console-prompt { color: #7dd3fc; flex-shrink: 0; }
  .secret-console-input {
    flex: 1;
    min-width: 0;
    background: none;
    border: none;
    outline: none;
    color: #e7ecf6;
    font: inherit;
    caret-color: #4ade80;
    /* override profile.css's body-wide user-select: none (there to stop the
       black-hole drag from starting a text selection) so text typed here can
       still be mouse-selected */
    user-select: text;
    -webkit-user-select: text;
  }
  .secret-console-input:disabled { opacity: 0.5; }
  .secret-console-form[hidden] { display: none; }
  /* suppress browser-native password reveal button (Edge/Chrome on Windows) */
  .secret-console-input::-ms-reveal { display: none; }
  .secret-console-input::-webkit-credentials-auto-fill-button { display: none; }
  .secret-console-eye {
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 0 0 0 0.25rem;
    cursor: pointer;
    color: #e7ecf6;
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .secret-console-eye:hover { opacity: 1; }
  .secret-console-eye[hidden] { display: none; }
  .secret-console-hint {
    padding: 0 1.1rem 0.9rem;
    font-size: 0.72rem;
    color: #5c6a85;
  }
</style>

<script>
  // Konami-triggered fake login console. `document` is never recreated by
  // ClientRouter (unlike this component's own DOM, which gets torn down and
  // rebuilt every time the user navigates away from `/` and back), so the
  // Konami detector and its counters are registered once at module top level
  // -- same pattern as index.astro's global click-to-close-reveal listener --
  // while anything touching #secret-console's actual elements re-queries the
  // live DOM on every call instead of closing over a reference that will go
  // stale after the next navigation.
  import { TOKEN_KEY, createToken } from '../lib/divineLoreToken';
  import { loadProgress } from '../lib/starClues';

  type PenaltyState = { required: number; expiresAt: number };

  const STORAGE_KEY = 'secretConsolePenalty';
  const PENALTY_TTL_MS = 24 * 60 * 60 * 1000;
  const KONAMI = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'KeyB', 'KeyA'];
  const CLOSE_ANIMATION_MS = 250;
  const CHECK_DELAY_MS = 700;
  const DENIED_CLOSE_DELAY_MS = 3500;
  const GRANTED_REDIRECT_DELAY_MS = 600;
  const USERNAME_PROMPT = 'username:';
  const PASSWORD_PROMPT = 'password:';
  const WELCOME_LINE = 'ผู้พิทักษ์: ยืนยันตัวตนก่อนเข้าสู่ศาสตร์แห่งเทพ';
  // Inner SVG of #secret-console-eye-icon for each visibility state: plain eye
  // while the password is masked ("click to reveal"), slashed eye while it's
  // revealed ("click to hide"). The masked variant must match the markup above,
  // which is the initial state.
  const EYE_MASKED_ICON = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  const EYE_REVEALED_ICON = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';

  function getRequiredCount(): number {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return 1;
    try {
      const state: PenaltyState = JSON.parse(raw);
      if (Date.now() > state.expiresAt) return 1;
      return state.required;
    } catch {
      return 1;
    }
  }

  // Returns the new required count so callers can tell the user how many
  // more full Konami entries are now needed before the console reopens.
  function bumpPenalty(): number {
    const state: PenaltyState = { required: getRequiredCount() * 2, expiresAt: Date.now() + PENALTY_TTL_MS };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    return state.required;
  }

  function normalize(s: string): string {
    return s.trim().toLowerCase().split('').sort().join('');
  }

  function reduceMotion(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  // Shown outside the (hidden-until-unlocked) console itself, so the
  // remaining-attempts count is visible while still in the middle of
  // entering the Konami code, not just after the console has already opened.
  function updateProgressBadge(): void {
    const badge = document.getElementById('secret-progress');
    if (!badge) return;
    const required = getRequiredCount();
    if (required <= 1) {
      badge.hidden = true;
      return;
    }
    const remaining = Math.max(required - completedThisVisit, 0);
    badge.textContent = `รหัสลับ: เหลืออีก ${remaining} ครั้ง`;
    badge.hidden = false;
  }

  // Returns the created line so callers can remove/replace it later (used by
  // the "checking..." interim line, which gets swapped out for the result).
  function appendLog(log: HTMLElement, text: string, className?: string): HTMLDivElement {
    const line = document.createElement('div');
    if (className) line.className = className;
    line.textContent = text;
    log.appendChild(line);
    log.scrollTop = log.scrollHeight;
    return line;
  }

  type ConsoleElements = {
    overlay: HTMLElement;
    log: HTMLElement;
    promptLabel: HTMLElement;
    form: HTMLFormElement;
    input: HTMLInputElement;
    eyeBtn: HTMLButtonElement;
    eyeIcon: HTMLElement;
  };

  // Re-queried per call (never cached at module level): the console's DOM is
  // torn down and rebuilt on every navigation back to `/`, so held references
  // would go stale -- see the module comment at the top of this script.
  function getConsoleElements(): ConsoleElements | null {
    const overlay = document.getElementById('secret-console');
    const log = document.getElementById('secret-console-log');
    const promptLabel = document.getElementById('secret-console-prompt-label');
    const form = document.getElementById('secret-console-form') as HTMLFormElement | null;
    const input = document.getElementById('secret-console-input') as HTMLInputElement | null;
    const eyeBtn = document.getElementById('secret-console-eye') as HTMLButtonElement | null;
    const eyeIcon = document.getElementById('secret-console-eye-icon');
    if (!overlay || !log || !promptLabel || !form || !input || !eyeBtn || !eyeIcon) return null;
    return { overlay, log, promptLabel, form, input, eyeBtn, eyeIcon };
  }

  // Keeps the input's type and the eye icon in lockstep -- they must never be
  // set independently, or the icon ends up showing the wrong state (which is
  // exactly what happened when the toggle handler and the reset paths each
  // wrote input.type on their own).
  function setPasswordMasked(els: ConsoleElements, masked: boolean): void {
    els.input.type = masked ? 'password' : 'text';
    els.eyeIcon.innerHTML = masked ? EYE_MASKED_ICON : EYE_REVEALED_ICON;
  }

  // Shared by openConsole() and the Esc-during-password branch: back to a
  // fresh username prompt with only the gatekeeper welcome line in the log.
  function resetToUsernamePhase(els: ConsoleElements): void {
    els.log.innerHTML = '';
    appendLog(els.log, WELCOME_LINE);
    delete els.form.dataset.username;
    els.promptLabel.textContent = USERNAME_PROMPT;
    els.input.type = 'text';
    els.eyeIcon.innerHTML = EYE_MASKED_ICON;
    els.input.value = '';
    els.input.disabled = false;
    els.form.hidden = false;
    els.eyeBtn.hidden = true;
    els.input.focus();
  }

  let closeTimer: ReturnType<typeof setTimeout> | null = null;
  let deniedCloseTimer: ReturnType<typeof setTimeout> | null = null;

  function openConsole(): void {
    const els = getConsoleElements();
    if (!els) return;

    if (closeTimer) {
      clearTimeout(closeTimer);
      closeTimer = null;
    }
    // A still-pending auto-close from a recent ACCESS DENIED must not slam
    // this freshly reopened console shut mid-use.
    if (deniedCloseTimer) {
      clearTimeout(deniedCloseTimer);
      deniedCloseTimer = null;
    }

    resetToUsernamePhase(els);
    els.overlay.hidden = false;

    const badge = document.getElementById('secret-progress');
    if (badge) badge.hidden = true;

    if (reduceMotion()) {
      els.overlay.classList.add('is-visible');
    } else {
      els.overlay.classList.remove('is-visible');
      void els.overlay.offsetHeight; // force a reflow so the removal above is committed before re-adding the class, otherwise the browser coalesces both and no transition plays
      els.overlay.classList.add('is-visible');
    }
    // Again after resetToUsernamePhase(): its focus() call was a no-op while
    // the overlay was still hidden.
    els.input.focus();
  }

  function closeConsole(): void {
    const overlay = document.getElementById('secret-console');
    if (!overlay || overlay.hidden) return;

    overlay.classList.remove('is-visible');
    if (reduceMotion()) {
      overlay.hidden = true;
      return;
    }
    closeTimer = setTimeout(() => {
      overlay.hidden = true;
      closeTimer = null;
    }, CLOSE_ANIMATION_MS);
  }

  let konamiPos = 0;
  let completedThisVisit = 0;

  document.addEventListener('keydown', (e) => {
    const overlay = document.getElementById('secret-console');
    if (!overlay) return; // component only renders on `/`

    if (!overlay.hidden) {
      if (e.key === 'Escape') {
        const els = getConsoleElements();
        // If in password phase, Esc goes back to username instead of closing.
        if (els && els.promptLabel.textContent === PASSWORD_PROMPT) {
          resetToUsernamePhase(els);
        } else {
          closeConsole();
        }
      } else if (e.key === 'Tab') {
        // Trap focus: Tab must never escape to the page behind the console.
        // Instead it toggles between the two phases -- username phase: acts
        // like Enter (submit, move on to password); password phase: back to
        // retyping the username (same as Esc).
        e.preventDefault();
        const els = getConsoleElements();
        if (!els || els.form.hidden) return; // form is hidden while "checking..."/denied -- just swallow the key
        if (els.promptLabel.textContent === PASSWORD_PROMPT) {
          resetToUsernamePhase(els);
        } else {
          els.form.requestSubmit();
        }
      }
      return;
    }

    if (!KONAMI.includes(e.code)) {
      konamiPos = 0;
      return;
    }
    // Swallow the key so it doesn't scroll the page (arrows) or, worse, leak
    // into the console's own <input> if this keypress is the one that
    // completes the sequence and focuses it (openConsole() below runs
    // synchronously inside this same handler).
    e.preventDefault();

    const expected = KONAMI[konamiPos];
    if (e.code === expected) {
      konamiPos++;
      if (konamiPos === KONAMI.length) {
        konamiPos = 0;
        completedThisVisit++;
        if (completedThisVisit >= getRequiredCount()) {
          // Keep completedThisVisit at the satisfied threshold so closing the
          // console without submitting (Esc / click-outside) only requires one
          // more Konami sequence to reopen, not the full penalty count again.
          // It's reset to 0 only on ACCESS DENIED (see submit handler).
          completedThisVisit = getRequiredCount();
          openConsole();
        } else {
          updateProgressBadge();
        }
      }
    } else {
      konamiPos = e.code === KONAMI[0] ? 1 : 0;
    }
  });

  // The <form> itself is recreated every time index.astro's body is
  // re-rendered (it isn't transition:persist'ed), so its submit handler is
  // (re-)attached per astro:page-load, matching initTilt/initReveal in
  // index.astro rather than living at module top level.
  document.addEventListener('astro:page-load', () => {
    const els = getConsoleElements();
    if (!els) return;
    const { overlay, form, input, log, promptLabel, eyeBtn } = els;

    updateProgressBadge();

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeConsole();
    });

    // Keep focus in the input while clicking the eye button -- without this the
    // button steals focus on mousedown and the input's caret position is lost.
    eyeBtn.addEventListener('mousedown', (e) => e.preventDefault());

    eyeBtn.addEventListener('click', () => {
      // Switching input.type makes the browser reset the caret to the start of
      // the value, so capture the selection first and restore it after. The
      // reset lands *after* this handler returns (Chromium schedules it as a
      // follow-up task), so a synchronous setSelectionRange alone gets
      // overwritten -- restore again on the next frame.
      const { selectionStart, selectionEnd, selectionDirection } = input;
      setPasswordMasked(els, input.type !== 'password');
      input.focus();
      const restoreSelection = () => {
        if (selectionStart !== null && selectionEnd !== null) {
          input.setSelectionRange(selectionStart, selectionEnd, selectionDirection ?? 'none');
        }
      };
      restoreSelection();
      // Once as a queued task and once on the next frame: the browser's own
      // deferred reset may land in either slot depending on engine, and a
      // repeated setSelectionRange with the same values is harmless.
      setTimeout(restoreSelection, 0);
      requestAnimationFrame(restoreSelection);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const value = input.value;
      const enteringPassword = promptLabel.textContent === PASSWORD_PROMPT;

      if (!enteringPassword) {
        form.dataset.username = value;
        appendLog(log, `username: ${value}`);
        promptLabel.textContent = PASSWORD_PROMPT;
        setPasswordMasked(els, true);
        input.value = '';
        eyeBtn.hidden = false;
        input.focus();
        return;
      }

      const username = form.dataset.username ?? '';
      const password = value;
      // restore to masked before logging so the displayed count matches what was typed
      setPasswordMasked(els, true);
      eyeBtn.hidden = true;
      appendLog(log, `password: ${'•'.repeat(password.length)}`);
      form.hidden = true;
      input.value = '';
      input.disabled = true;

      const isAnagram = normalize(username).length > 0 && normalize(username) === normalize(password);
      const hasChi = username.toLowerCase().includes('chi');
      const checkingLine = appendLog(log, 'กำลังตรวจสอบ...', 'log-checking');

      setTimeout(() => {
        checkingLine.remove();
        input.disabled = false;

        if (isAnagram && hasChi) {
          appendLog(log, 'ACCESS GRANTED', 'log-granted');
          sessionStorage.setItem(TOKEN_KEY, createToken(username));
          // A real login wipes the slate clean -- no lingering penalty from
          // earlier wrong guesses once the puzzle has actually been solved.
          localStorage.removeItem(STORAGE_KEY);
          // Nod to players who reached this console by following the emerald-star
          // clues (progress > 0). Hold the redirect a beat longer so the line is
          // actually readable before the page changes.
          const followedStars = loadProgress() > 0;
          if (followedStars) {
            appendLog(log, 'ผู้พิทักษ์: เจ้าตามแสงดาวมาสินะ… สมแล้วที่ไขได้', 'log-info');
          }
          setTimeout(() => {
            window.location.href = '/divine-lore/';
          }, followedStars ? 1800 : GRANTED_REDIRECT_DELAY_MS);
        } else {
          appendLog(log, 'ACCESS DENIED', 'log-denied');
          const nextRequired = bumpPenalty();
          completedThisVisit = 0;
          appendLog(log, `ต้องกดรหัสลับให้ครบอีก ${nextRequired} ครั้งถึงจะลองใหม่ได้`, 'log-info');
          updateProgressBadge();
          // keep form hidden while the denied message is showing; closeConsole
          // will hide the whole overlay anyway, so no need to un-hide it here.
          deniedCloseTimer = setTimeout(() => {
            deniedCloseTimer = null;
            closeConsole();
          }, DENIED_CLOSE_DELAY_MS);
        }
      }, CHECK_DELAY_MS);
    });
  });
</script>
