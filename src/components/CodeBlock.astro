---
import { Code } from 'astro:components';

interface Props {
  code: string;
  lang: string;
  title?: string;
}

const { code, lang, title } = Astro.props;
const label = title ?? lang;
---
<div class="code-window">
  <div class="code-window-header">
    <span class="code-window-dots" aria-hidden="true">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </span>
    <span class="code-window-label">{label}</span>
    <button class="copy-btn" type="button" data-copy-btn title="คัดลอกโค้ด" aria-label="คัดลอกโค้ด">
      <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      <span class="copy-btn-text">คัดลอก</span>
    </button>
  </div>
  <Code code={code} lang={lang} theme="dracula" />
</div>

<style>
  .code-window{
    margin:1.125rem 0;
    border-radius:14px;
    overflow:hidden;
    border:1px solid #2a3350;
  }
  .code-window :global(pre.astro-code){
    margin:0;
    border-radius:0;
  }
  .code-window-header{
    display:flex;
    align-items:center;
    gap:.6rem;
    background:#141a29;
    padding:.55rem .75rem .55rem .9rem;
    border-bottom:1px solid #2a3350;
  }
  .code-window-dots{display:flex;gap:6px;flex-shrink:0;}
  .dot{width:11px;height:11px;border-radius:50%;display:block;}
  .dot-red{background:#ff5f56;}
  .dot-yellow{background:#ffbd2e;}
  .dot-green{background:#27c93f;}
  .code-window-label{
    margin-left:.25rem;
    font-size:.72rem;
    color:#7b869c;
    font-family:"Fira Code","Fira Mono",monospace;
    flex:1;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
  }
  .copy-btn{
    display:flex;
    align-items:center;
    gap:.35rem;
    background:none;
    border:1px solid #333c54;
    color:#9aa7bd;
    border-radius:6px;
    padding:.28rem .55rem;
    font-size:.72rem;
    font-family:"Sarabun",system-ui,sans-serif;
    cursor:pointer;
    flex-shrink:0;
    transition:color .15s, border-color .15s, background .15s;
  }
  .copy-btn:hover{color:#e7ecf6;border-color:#4d72a9;background:#1c2536;}
  .copy-btn .icon-check{display:none;}
  .copy-btn.copied{color:#4ade80;border-color:#2f9e5c;}
  .copy-btn.copied .icon-copy{display:none;}
  .copy-btn.copied .icon-check{display:block;}
</style>

<script>
  // Registered once via astro:page-load (see StarfieldBackground.astro for why) so
  // copy buttons on every article still work after a client-side navigation, not
  // just on the page that happened to be loaded when this module first evaluated.
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLButtonElement>('[data-copy-btn]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const wrapper = btn.closest('.code-window');
        const codeEl = wrapper?.querySelector('pre.astro-code code');
        const text = codeEl?.textContent ?? '';
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          return;
        }
        const label = btn.querySelector('.copy-btn-text');
        const prevLabel = label?.textContent;
        btn.classList.add('copied');
        if (label) label.textContent = 'คัดลอกแล้ว';
        window.setTimeout(() => {
          btn.classList.remove('copied');
          if (label && prevLabel) label.textContent = prevLabel;
        }, 1500);
      });
    });
  });
</script>
