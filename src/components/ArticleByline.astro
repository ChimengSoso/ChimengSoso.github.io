---
interface Props {
  /** Original publish date, Thai-formatted (e.g. "1 กรกฎาคม 2026"). */
  published: string;
  /** Last-updated date; omitted or equal to `published` shows only the publish date. */
  updated?: string;
}
const { published, updated } = Astro.props;
const showUpdated = updated && updated !== published;
---
<p class="article-meta">
  เผยแพร่ {published}{showUpdated ? ` · อัปเดตล่าสุด ${updated}` : ''}
</p>

<style>
  .article-meta{
    font-size:0.8rem;
    color:var(--muted);
    margin:-1rem 0 2.5rem;
    letter-spacing:.2px;
  }
</style>
